<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-primary mb-6">멤버 관리</h1>

  <div class="bg-surface rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-divider">
      <thead class="bg-elev">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase">이름</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase">이메일</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase">역할</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-tertiary uppercase">작업</th>
        </tr>
      </thead>
      <tbody class="bg-surface divide-y divide-divider">
        <% @memberships.each do |membership| %>
          <tr>
            <td class="px-6 py-4 text-sm text-primary"><%= membership.user.name %></td>
            <td class="px-6 py-4 text-sm text-tertiary"><%= membership.user.email %></td>
            <td class="px-6 py-4 text-sm text-tertiary">
              <%= membership.role %>
            </td>
            <td class="px-6 py-4 text-right text-sm">
              <% unless membership.role == 'owner' %>
                <%= link_to '제거', workspace_membership_path(@workspace, membership), method: :delete, data: { turbo_confirm: '정말 제거하시겠습니까?' }, class: 'text-danger hover:text-danger' %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
