<%# Locals: transaction (required) %>
<button data-action="click->comment-panel#open:stop"
        data-comment-panel-transaction-id-param="<%= transaction.id %>"
        data-comment-panel-url-param="<%= workspace_transaction_comments_path(transaction.workspace, transaction) %>"
        data-comment-panel-merchant-param="<%= transaction.merchant %>"
        data-comment-panel-date-param="<%= transaction.date&.strftime('%m.%d') %>"
        data-comment-panel-amount-param="<%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>"
        data-comment-panel-row-id-param="<%= dom_id(transaction) %>"
        data-comment-panel-trigger
        class="inline-flex items-center gap-0.5
               <%= transaction.comments_count.to_i > 0 ? 'text-gray-500' : 'text-gray-400 opacity-0 group-hover:opacity-100' %>
               hover:text-gray-700 transition-all"
        title="댓글">
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
  </svg>
  <% if transaction.comments_count.to_i > 0 %>
    <span class="text-xs font-medium tabular-nums"><%= transaction.comments_count %></span>
  <% end %>
</button>
