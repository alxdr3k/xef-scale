<%# Locals: comment (required), current_user_id (optional) %>
<% uid = local_assigns.fetch(:current_user_id, nil) || (defined?(current_user) && current_user&.id) %>
<% colors = %w[bg-category-8 bg-category-2 bg-category-4 bg-category-6 bg-category-1 bg-category-7] %>
<% dot_color = colors[comment.user_id % colors.length] %>

<div id="<%= dom_id(comment) %>"
     data-controller="comment"
     class="group/comment py-2.5">
  <div class="flex items-start gap-2">
    <span class="w-2 h-2 rounded-full mt-1.5 shrink-0 <%= dot_color %>"></span>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <span class="text-xs font-medium text-primary"><%= comment.user.name || comment.user.email.split('@').first %></span>
        <span class="text-[11px] text-disabled">
          <%= comment.created_at.strftime('%m/%d %H:%M') %>
          <% if comment.edited_at.present? %>
            <span class="text-disabled"><%= t("comments.comment.edited") %></span>
          <% end %>
        </span>
        <% if uid && comment.user_id == uid %>
          <div class="ml-auto flex items-center gap-1 opacity-0 group-hover/comment:opacity-100 transition-opacity">
            <button data-action="click->comment#edit:stop"
                    class="text-[11px] text-disabled hover:text-secondary cursor-pointer"><%= t("comments.comment.edit") %></button>
            <button data-action="click->comment#delete:stop"
                    data-comment-url-value="<%= workspace_transaction_comment_path(comment.commentable_transaction.workspace, comment.commentable_transaction, comment) %>"
                    data-turbo-confirm="<%= t("comments.comment.delete_confirm") %>"
                    class="text-[11px] text-disabled hover:text-danger cursor-pointer"><%= t("comments.comment.delete") %></button>
          </div>
        <% end %>
      </div>

      <%# Display mode %>
      <div data-comment-target="display" class="text-sm text-secondary mt-0.5 whitespace-pre-wrap break-words"><%= comment.body %></div>

      <%# Edit mode %>
      <div data-comment-target="editor" class="hidden mt-1">
        <form data-action="submit->comment#update:prevent"
              data-comment-url-value="<%= workspace_transaction_comment_path(comment.commentable_transaction.workspace, comment.commentable_transaction, comment) %>">
          <textarea data-comment-target="editInput"
                    class="w-full text-sm border border-divider rounded-md px-2 py-1.5 resize-none focus:ring-1 focus:ring-action focus:border-transparent"
                    rows="2"><%= comment.body %></textarea>
          <div class="flex gap-1.5 mt-1">
            <button type="submit" class="text-xs font-medium text-action-on bg-action hover:bg-action-hover px-2.5 py-1 rounded"><%= t("comments.comment.save") %></button>
            <button type="button" data-action="click->comment#cancelEdit:stop" class="text-xs text-tertiary hover:text-secondary px-2 py-1"><%= t("comments.comment.cancel") %></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
