<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">초대 관리</h1>
    <%= button_to '새 초대 링크', workspace_invitations_path(@workspace), method: :post, params: { workspace_invitation: { expires_at: 7.days.from_now, max_uses: 10 } }, class: 'bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700' %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">토큰</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">만료</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">사용 횟수</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">작업</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @invitations.each do |invitation| %>
          <tr>
            <td class="px-6 py-4 text-sm text-gray-900 font-mono"><%= invitation.token[0..8] %>...</td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= invitation.expires_at&.strftime('%Y-%m-%d %H:%M') || '없음' %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= invitation.current_uses %> / <%= invitation.max_uses || '∞' %></td>
            <td class="px-6 py-4 text-right text-sm">
              <%= link_to '삭제', workspace_invitation_path(@workspace, invitation), method: :delete, data: { confirm: '정말 삭제하시겠습니까?' }, class: 'text-red-600 hover:text-red-900' %>
            </td>
          </tr>
        <% end %>

        <% if @invitations.empty? %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-gray-500">초대 링크가 없습니다.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
