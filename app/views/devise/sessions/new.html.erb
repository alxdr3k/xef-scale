<% content_for :title, t("devise.sessions.new.title") %>

<div class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%# Codex PR #213 P1: gradient hero는 theme 안 따라가므로 토큰(light-dark) 대신 고정색 사용. %>
      <%= link_to root_path, class: "inline-block" do %>
        <h1 class="text-3xl font-bold text-white"><%= app_name %></h1>
      <% end %>
      <p class="mt-2 text-indigo-100"><%= t("devise.sessions.new.subtitle") %></p>
    </div>

    <div class="bg-surface rounded-2xl shadow-xl p-8">
      <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
          class: "w-full inline-flex items-center justify-center px-4 py-3 border border-divider rounded-xl text-sm font-medium text-secondary bg-surface hover:bg-elev transition-colors shadow-sm cursor-pointer mb-6" do %>
        <svg class="w-5 h-5 mr-3 flex-shrink-0" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <%= t("devise.sessions.new.google") %>
      <% end %>

      <div class="relative mb-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-divider"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-3 bg-surface text-tertiary"><%= t("devise.sessions.new.or_email") %></span>
        </div>
      </div>

      <%= form_with(model: resource, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, t("devise.sessions.new.email_label"), class: "block text-sm font-medium text-secondary mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full px-3 py-2.5 border border-divider rounded-xl text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-action focus-visible:border-transparent transition-colors" %>
          </div>

          <div>
            <%= f.label :password, t("devise.sessions.new.password_label"), class: "block text-sm font-medium text-secondary mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full px-3 py-2.5 border border-divider rounded-xl text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-action focus-visible:border-transparent transition-colors" %>
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, id: "user_remember_me",
                  class: "rounded border-divider text-action focus:ring-action" %>
              <%= f.label :remember_me, t("devise.sessions.new.remember_me"),
                  class: "text-sm text-secondary cursor-pointer" %>
            </div>
            <%= link_to t("devise.sessions.new.forgot_password"), new_user_password_path,
                class: "text-sm text-action hover:text-action" %>
          </div>
        </div>

        <div class="mt-6">
          <%= f.submit t("devise.sessions.new.submit"), class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl text-sm font-semibold text-action-on bg-action hover:bg-action-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-action transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <p class="mt-6 text-center text-sm text-tertiary">
        <%= t("devise.sessions.new.no_account") %>
        <%= link_to t("devise.sessions.new.sign_up"), new_user_registration_path,
            class: "font-medium text-action hover:text-action" %>
      </p>
    </div>
  </div>
</div>
