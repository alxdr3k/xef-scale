<% content_for :title, t("devise.passwords.new.title") %>

<div class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%# Codex PR #213 P1 패턴: gradient hero는 theme 안 따라가므로 토큰(light-dark) 대신 고정색 사용. %>
      <%= link_to root_path, class: "inline-block" do %>
        <h1 class="text-3xl font-bold text-white"><%= app_name %></h1>
      <% end %>
      <p class="mt-2 text-indigo-100"><%= t("devise.passwords.new.subtitle") %></p>
    </div>

    <div class="bg-surface rounded-2xl shadow-xl p-8">
      <%= form_with(model: resource, url: password_path(resource_name)) do |f| %>
        <% if resource.errors.any? %>
          <div class="mb-4 p-3 bg-danger-subtle border border-danger rounded-xl">
            <ul class="text-sm text-danger space-y-1">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <p class="text-sm text-secondary mb-4"><%= t("devise.passwords.new.hint") %></p>

        <div>
          <%= f.label :email, t("devise.passwords.new.email_label"), class: "block text-sm font-medium text-secondary mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2.5 border border-divider rounded-xl text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-action focus-visible:border-transparent transition-colors" %>
        </div>

        <div class="mt-6">
          <%= f.submit t("devise.passwords.new.submit"), class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl text-sm font-semibold text-action-on bg-action hover:bg-action-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-action transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <p class="mt-6 text-center text-sm text-tertiary">
        <%= link_to t("devise.passwords.new.back_to_sign_in"), new_user_session_path,
            class: "font-medium text-action hover:text-action" %>
      </p>
    </div>
  </div>
</div>
