<% content_for :title, "비밀번호 찾기" %>

<div class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-block" do %>
        <h1 class="text-3xl font-bold text-white">지출 추적</h1>
      <% end %>
      <p class="mt-2 text-indigo-100">비밀번호를 재설정합니다</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-8">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <% if resource.errors.any? %>
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl">
            <ul class="text-sm text-red-600 space-y-1">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <p class="text-sm text-gray-600 mb-4">가입 시 사용한 이메일 주소를 입력하면 비밀번호 재설정 링크를 보내드립니다.</p>

        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors" %>
        </div>

        <div class="mt-6">
          <%= f.submit "재설정 링크 보내기", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <p class="mt-6 text-center text-sm text-gray-500">
        <%= link_to "로그인으로 돌아가기", new_user_session_path,
            class: "font-medium text-indigo-600 hover:text-indigo-500" %>
      </p>
    </div>
  </div>
</div>
