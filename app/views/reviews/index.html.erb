<%#
  검토함 인덱스 (ADR-0004) — IA 1번 시민.

  본 PR은 *IA 골조*만 다룬다 (preflight §3.3, "PR B"):
  - 세그먼트 탭 [파싱 결과 N | 중복 후보 M]
  - 각 탭은 행 형태로 항목 노출 (구체 행 디자인은 후속 화면 PR)
  - "+ 새로 가져오기" 액션은 현재 parsing_sessions/index로 링크
    (검토함 시트 통합은 후속 PR; ADR-0004 §"라우트 매핑" — 기존 path 그대로 유지)

  세부 검토는 기존 helper `review_workspace_parsing_session_path(ws, session)` 사용.
%>
<div class="max-w-4xl mx-auto" data-controller="review-tabs">
  <div class="flex items-baseline justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary"><%= t("reviews.index.title") %></h1>
      <p class="text-secondary text-sm mt-1">
        <%= t("reviews.index.subtitle") %>
      </p>
    </div>
    <%# Phase 3.3: "+ 새로 가져오기"는 시트를 연다. parsing_sessions/index로의 하드 링크는 폐기.
        Codex hotfix A: import은 write action이므로 read-only 멤버에게 노출 금지. %>
    <% if current_user.can_write?(@workspace) %>
      <%= render 'shared/input_sheet', workspace: @workspace %>
    <% end %>
  </div>

  <%# 세그먼트 탭 — segmented_tabs 채택은 Phase 3.x. 본 PR은 인라인.
      GPT 적대적 리뷰 §2.7 (P0 #6) — @initial_tab 으로 calendar quick filter
      등 외부 진입로가 미리 선택한 탭을 SSR 단계에서 반영. JS 가 disabled
      되어도 첫 페인트에서 의도된 탭이 보인다. %>
  <% sessions_active = @initial_tab == "sessions" %>
  <% duplicates_active = @initial_tab == "duplicates" %>
  <div class="border-b border-divider mb-4 flex gap-6" role="tablist">
    <button type="button"
            data-action="click->review-tabs#select"
            data-review-tabs-target="tab"
            data-tab="sessions"
            class="pb-3 -mb-px text-sm font-medium border-b-2 <%= sessions_active ? 'border-action text-primary' : 'border-transparent text-secondary hover:text-primary' %>"
            role="tab" aria-selected="<%= sessions_active %>">
      <%= t("reviews.index.tab_pending") %>
      <span class="ml-1 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-meta rounded-full bg-action-subtle text-action">
        <%= @pending_sessions_count %>
      </span>
    </button>
    <button type="button"
            data-action="click->review-tabs#select"
            data-review-tabs-target="tab"
            data-tab="duplicates"
            class="pb-3 -mb-px text-sm font-medium border-b-2 <%= duplicates_active ? 'border-action text-primary' : 'border-transparent text-secondary hover:text-primary' %>"
            role="tab" aria-selected="<%= duplicates_active %>">
      <%= t("reviews.index.tab_duplicates") %>
      <span class="ml-1 inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-meta rounded-full bg-elev text-secondary">
        <%= @pending_duplicates_count %>
      </span>
    </button>
  </div>

  <%# 파싱 결과 탭 %>
  <section data-review-tabs-target="panel" data-tab="sessions" role="tabpanel" <%= "hidden" unless sessions_active %>>
    <% if @pending_sessions.any? %>
      <ul class="divide-y divide-divider bg-surface rounded-lg shadow-sm">
        <% @pending_sessions.each do |session| %>
          <li class="px-4 py-3 hover:bg-elev">
            <%= link_to review_workspace_parsing_session_path(@workspace, session),
                class: "flex items-center justify-between gap-3" do %>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-primary truncate">
                  <% if session.text_paste? %>
                    <%= t("reviews.index.session_text_paste") %>
                  <% else %>
                    <%= session.processed_file&.original_filename || t("reviews.index.session_image_fallback") %>
                  <% end %>
                </p>
                <p class="text-meta text-secondary mt-0.5">
                  <%= t("reviews.index.session_pending_count", count: (@pending_tx_counts[session.id] || 0)) %>
                  <% dup_count = @pending_dup_counts[session.id] || 0 %>
                  <% if dup_count.positive? %>
                    <%= t("reviews.index.session_duplicate_info", count: dup_count) %>
                  <% end %>
                  <% issue_count = @open_issue_counts[session.id] || 0 %>
                  <% if issue_count.positive? %>
                    <%= t("reviews.index.session_issue_info", count: issue_count) %>
                  <% end %>
                  <%= t("reviews.index.session_relative_time", relative: time_ago_in_words(session.created_at)) %>
                </p>
              </div>
              <svg class="w-5 h-5 text-tertiary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            <% end %>
          </li>
        <% end %>
      </ul>
      <% if @pending_sessions_count > @pending_sessions.size %>
        <p class="text-meta text-tertiary text-center mt-2">
          <%= t("reviews.index.pagination_hint", shown: @pending_sessions.size, total: @pending_sessions_count) %>
        </p>
      <% end %>
    <% else %>
      <div class="px-6 py-12 text-center text-secondary bg-surface rounded-lg">
        <p class="text-base"><%= t("reviews.index.empty_pending_title") %></p>
        <p class="text-meta mt-1"><%= t("reviews.index.empty_pending_hint") %></p>
      </div>
    <% end %>
  </section>

  <%# 중복 후보 탭 — sessions_active 일 때만 hidden. %>
  <section data-review-tabs-target="panel" data-tab="duplicates" role="tabpanel" <%= "hidden" unless duplicates_active %>>
    <% if @pending_duplicates.any? %>
      <ul class="divide-y divide-divider bg-surface rounded-lg shadow-sm">
        <% @pending_duplicates.each do |dup| %>
          <li class="px-4 py-3">
            <%= link_to review_workspace_parsing_session_path(@workspace, dup.parsing_session),
                class: "flex items-center justify-between gap-3 hover:bg-elev" do %>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-primary truncate">
                  <%= dup.new_transaction&.merchant.presence || t("reviews.index.duplicate_new_transaction_fallback") %>
                </p>
                <p class="text-meta text-secondary mt-0.5">
                  <%= t("reviews.index.duplicate_session_label", id: dup.parsing_session_id, relative: time_ago_in_words(dup.created_at)) %>
                </p>
              </div>
              <svg class="w-5 h-5 text-tertiary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            <% end %>
          </li>
        <% end %>
      </ul>
      <% if @pending_duplicates_count > @pending_duplicates.size %>
        <p class="text-meta text-tertiary text-center mt-2">
          <%= t("reviews.index.pagination_hint", shown: @pending_duplicates.size, total: @pending_duplicates_count) %>
        </p>
      <% end %>
    <% else %>
      <div class="px-6 py-12 text-center text-secondary bg-surface rounded-lg">
        <p class="text-base"><%= t("reviews.index.empty_duplicates_title") %></p>
      </div>
    <% end %>
  </section>
</div>
