<%# Import issue repair surface (B4).
    Each open `missing_required_fields` issue gets a small inline form so the
    user can fill the missing values and promote the row into the pending
    review queue. Ambiguous duplicate issues are handled by the existing
    DuplicateConfirmation flow today; rendered as info-only here. %>
<% return if open_import_issues.blank? %>

<div class="bg-surface rounded-lg shadow mb-6">
  <div class="px-4 py-3 border-b border-divider">
    <h2 class="text-base font-semibold text-primary">
      <%= t("reviews.import_issues.heading") %><%= t("reviews.import_issues.count_html", count: open_import_issues.size).html_safe %>
    </h2>
    <p class="text-xs text-tertiary mt-1">
      <%= t("reviews.import_issues.subtitle") %>
    </p>
  </div>

  <ul class="divide-y divide-divider">
    <% open_import_issues.each do |issue| %>
      <li class="px-4 py-3">
        <% if issue.missing_required_fields? %>
          <%# Two sibling forms — nesting a button_to (its own <form>) inside
              the resolve form_with produces invalid HTML and can break the
              outer submit. Layout the dismiss control alongside instead. %>
          <div class="grid grid-cols-1 md:grid-cols-4 gap-2 items-end">
            <%= form_with url: workspace_import_issue_path(workspace, issue), method: :patch, local: true,
                          scope: :import_issue,
                          id: "import-issue-resolve-#{issue.id}",
                          class: "md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-2 items-end" do |f| %>
              <div>
                <label class="block text-xs text-tertiary mb-1"><%= t("reviews.import_issues.date_label") %></label>
                <%= f.date_field :date, value: issue.date,
                      class: "w-full px-2 py-1 border border-divider rounded text-sm",
                      required: issue.missing_fields.include?("date") %>
              </div>
              <div>
                <label class="block text-xs text-tertiary mb-1"><%= t("reviews.import_issues.merchant_label") %></label>
                <%= f.text_field :merchant, value: issue.merchant,
                      class: "w-full px-2 py-1 border border-divider rounded text-sm",
                      placeholder: t("reviews.import_issues.merchant_placeholder") %>
              </div>
              <div>
                <label class="block text-xs text-tertiary mb-1"><%= t("reviews.import_issues.amount_label") %></label>
                <%= f.number_field :amount, value: issue.amount,
                      class: "w-full px-2 py-1 border border-divider rounded text-sm",
                      placeholder: "0" %>
              </div>
            <% end %>
            <div class="flex items-center gap-2">
              <%# Submit refers to the sibling resolve form via form= attribute. %>
              <button type="submit" form="import-issue-resolve-<%= issue.id %>"
                      class="px-3 py-1 bg-action text-action-on text-sm rounded hover:bg-action-hover cursor-pointer">
                <%= t("reviews.import_issues.apply") %>
              </button>
              <%= button_to t("reviews.import_issues.dismiss"), workspace_import_issue_path(workspace, issue),
                    method: :patch,
                    params: { resolution_action: "dismiss" },
                    class: "px-3 py-1 border border-divider text-secondary text-sm rounded hover:bg-elev inline-block",
                    form: { class: "inline-block" },
                    data: { turbo_confirm: t("reviews.import_issues.dismiss_confirm") } %>
            </div>
          </div>
          <% if issue.missing_fields.any? %>
            <p class="text-xs text-warning mt-1">
              <%= t("reviews.import_issues.missing_prefix",
                    fields: issue.missing_fields.map { |f|
                      { "date" => t("reviews.import_issues.field_date"),
                        "merchant" => t("reviews.import_issues.field_merchant"),
                        "amount" => t("reviews.import_issues.field_amount") }[f] || f
                    }.join(", ")) %>
            </p>
          <% end %>
        <% else %>
          <%# Ambiguous duplicate or other types — not user-resolvable in B4 yet. %>
          <p class="text-sm text-secondary">
            <%= issue.merchant.presence || t("reviews.import_issues.no_merchant_fallback") %> · <%= t("reviews.import_issues.amount_won", amount: issue.amount) %>
          </p>
          <p class="text-xs text-tertiary mt-0.5">
            <%= t("reviews.import_issues.duplicate_hint") %>
          </p>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
