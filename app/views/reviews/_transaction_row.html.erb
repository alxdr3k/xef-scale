<% read_only = local_assigns.fetch(:read_only, false) %>
<% categories = local_assigns.fetch(:categories, nil) || @categories %>
<% institutions = local_assigns.fetch(:institutions, nil) %>
<% editable = !read_only && !transaction.deleted? %>
<% update_url = editable ? update_transaction_workspace_parsing_session_path(@workspace, @parsing_session, transaction_id: transaction.id) : nil %>

<tr id="<%= dom_id(transaction) %>"
    data-bulk-select-target="row"
    data-transaction-id="<%= transaction.id %>"
    data-deleted="<%= transaction.deleted? %>"
    <% unless read_only || transaction.deleted? %>
      data-action="click->bulk-select#toggleRow"
    <% end %>
    class="group/row <%= 'bg-red-50 opacity-60' if transaction.deleted? %>
           transition-colors duration-150
           <%= 'cursor-pointer' unless read_only || transaction.deleted? %>">

  <%= render 'shared/transaction_cells/date_cell', transaction: transaction, editable: editable, update_url: update_url %>
  <%= render 'shared/transaction_cells/merchant_cell', transaction: transaction, editable: editable, update_url: update_url %>
  <%= render 'shared/transaction_cells/amount_cell', transaction: transaction, editable: editable, update_url: update_url %>
  <%= render 'shared/transaction_cells/category_cell', transaction: transaction, editable: !read_only, categories: categories, show_management_links: !read_only, workspace: @workspace %>
  <%= render 'shared/transaction_cells/institution_cell', transaction: transaction, editable: editable, update_url: update_url, institutions: institutions %>

  <%= render 'shared/transaction_cells/comment_badge_cell', transaction: transaction %>

</tr>
