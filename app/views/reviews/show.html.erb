<div class="max-w-7xl mx-auto" data-controller="bulk-select note-panel comment-panel" data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick click@document->comment-panel#handleOutsideClick">
  <%= link_to '← 업로드 목록', workspace_parsing_sessions_path(@workspace),
      class: 'text-indigo-600 hover:text-indigo-800 mb-4 inline-block' %>

  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">거래 검토</h1>
      <p class="text-gray-600">
        <% if @parsing_session.text_paste? %>
          텍스트 붙여넣기
        <% elsif @parsing_session.processed_file %>
          <%= @parsing_session.processed_file.filename %>
        <% else %>
          파일 정보 없음
        <% end %>
      </p>
    </div>

    <div class="flex items-center space-x-2">
      <%= render 'shared/status_badge', status: @parsing_session.review_status, type: :review %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">전체</div>
      <div class="text-2xl font-bold text-gray-900"><%= @parsing_session.total_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">성공</div>
      <div class="text-2xl font-bold text-green-600"><%= @parsing_session.success_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">총 금액</div>
      <div class="text-2xl font-bold text-indigo-600">
        <%= number_to_currency(@transactions.excluding_coupon.sum(&:amount), unit: '₩', precision: 0) %>
      </div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">상태</div>
      <div class="text-lg font-bold">
        <% if @read_only %>
          읽기 전용
        <% else %>
          편집 가능
        <% end %>
      </div>
    </div>
  </div>

  <!-- Duplicate Section -->
  <% unless @read_only %>
    <%= render "reviews/duplicate_section",
        duplicate_confirmations: @duplicate_confirmations,
        workspace: @workspace,
        parsing_session: @parsing_session %>
  <% end %>

  <!-- Session Action Bar (세션 전체 액션만) -->
  <% unless @read_only %>
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <div class="flex justify-end items-center gap-3">
        <% if @parsing_session.review_pending? %>
          <%= form_with url: discard_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: '모든 거래를 취소하고 업로드를 폐기하시겠습니까? 이 작업은 되돌릴 수 없습니다.' } do %>
            <button type="submit" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">
              전체 취소
            </button>
          <% end %>
          <% commit_msg = @pagy.pages > 1 ?
               "전체 #{@total_commit_count}건 중 현재 #{@transactions.count}건 표시 중입니다. 커밋하면 전체 #{@total_commit_count}건이 거래 내역에 반영됩니다." :
               "#{@total_commit_count}건의 거래를 거래 내역에 반영하시겠습니까?" %>
          <%= form_with url: commit_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: commit_msg } do %>
            <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
              거래 내역 반영
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @read_only && @parsing_session.review_committed? %>
    <% summary = @parsing_session.commit_summary %>
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div class="space-y-2 text-sm text-gray-700">
          <div class="text-base font-semibold text-gray-900">
            <%= summary[:committed] %>건이 거래 내역에 반영되었습니다.
          </div>
          <% if summary[:originals_replaced].positive? %>
            <div>중복 <%= summary[:originals_replaced] %>건은 새 거래로 교체되었습니다.</div>
          <% end %>
          <% if summary[:originals_kept].positive? %>
            <div>중복 <%= summary[:originals_kept] %>건은 기존 거래만 남겼습니다.</div>
          <% end %>
          <% if summary[:duplicates_kept_both].positive? %>
            <div>중복 <%= summary[:duplicates_kept_both] %>건은 양쪽 모두 보관했습니다.</div>
          <% end %>
          <% if summary[:excluded].positive? %>
            <div><%= summary[:excluded] %>건은 이번 가져오기에서 제외했습니다.</div>
          <% end %>
          <% if summary[:uncategorized].positive? %>
            <div class="text-amber-700"><%= summary[:uncategorized] %>건은 분류가 필요합니다.</div>
          <% end %>
          <div class="text-xs text-gray-500 pt-1">
            확정일: <%= @parsing_session.committed_at&.strftime('%Y-%m-%d %H:%M') %>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <%= link_to '거래 내역 보기',
              workspace_transactions_path(@workspace, year: Date.current.year, month: Date.current.month),
              class: 'px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700' %>
          <%= form_with url: rollback_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: '이번 가져오기를 모두 되돌리시겠습니까? 이 작업은 되돌릴 수 없습니다.' } do %>
            <button type="submit" class="px-4 py-2 bg-white border border-red-600 text-red-600 rounded-lg hover:bg-red-50">
              가져오기 되돌리기
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% unless @read_only %>
    <%# 숨겨진 일괄 처리 폼 %>
    <%= form_with url: bulk_update_workspace_parsing_session_path(@workspace, @parsing_session),
        method: :post, data: { turbo: false, bulk_form: true } do %>
      <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
      <input type="hidden" name="bulk_action" value="">
      <input type="hidden" name="category_id" value="">
    <% end %>

    <!-- Selection Toolbar -->
    <div data-bulk-select-target="toolbar"
         class="bg-white rounded-t-lg shadow-sm border-b border-gray-200 px-4 py-2 flex items-center gap-2 min-h-[44px]">
      <input type="checkbox"
             data-bulk-select-target="toolbarCheckbox"
             data-action="change->bulk-select#toggleSelectAll"
             class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">

      <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-gray-500">
        <span>전체 선택</span>
      </div>

      <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
        <span class="text-sm font-medium text-indigo-700 mr-2">
          <span data-bulk-select-target="toolbarCount">0</span>개 선택됨
        </span>

        <div class="w-px h-5 bg-gray-300"></div>

        <button type="button" data-action="click->bulk-select#deleteSelected"
                class="tooltip p-1.5 text-gray-500 hover:text-red-600 hover:bg-red-50 rounded transition-colors" aria-label="삭제">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>

        <button type="button" data-action="click->bulk-select#markAllowance"
                class="tooltip p-1.5 text-gray-500 hover:text-yellow-600 hover:bg-yellow-50 rounded transition-colors" aria-label="용돈 표시">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </button>

        <button type="button" data-action="click->bulk-select#unmarkAllowance"
                class="tooltip p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded transition-colors" aria-label="용돈 해제">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
          </svg>
        </button>

        <div class="w-px h-5 bg-gray-300"></div>

        <div class="flex items-center gap-1">
          <select name="category_id" class="text-xs rounded border-gray-300 py-1 pl-2 pr-6">
            <option value="">카테고리...</option>
            <% @categories.each do |cat| %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% end %>
          </select>
          <button type="button" data-action="click->bulk-select#changeCategory"
                  class="px-2 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
            적용
          </button>
        </div>

        <div class="w-px h-5 bg-gray-300"></div>

        <div class="relative">
          <button type="button" data-action="click->bulk-select#toggleMore"
                  class="tooltip p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded transition-colors" aria-label="더보기">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
            </svg>
          </button>

          <div data-bulk-select-target="moreMenu"
               class="hidden absolute top-full mt-1 right-0 z-10
                      bg-white rounded-lg shadow-xl border border-gray-200
                      py-1 min-w-[160px] text-gray-700">
            <button type="button" data-action="click->bulk-select#deselectAll"
                    class="w-full px-4 py-2 text-left text-sm hover:bg-gray-100 transition-colors">
              선택 해제
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Transactions Table -->
  <div class="bg-white <%= @read_only ? 'rounded-lg' : 'rounded-b-lg' %> shadow overflow-visible">
    <div class="overflow-visible">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">날짜</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">내역</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">금액</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-36">카테고리</th>
            <th class="px-2 py-3 text-center text-xs font-medium text-gray-500 uppercase w-16">출처</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase w-16">댓글</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" id="transactions-review-list">
          <% @transactions.each do |tx| %>
            <%= render 'reviews/transaction_row', transaction: tx, read_only: @read_only,
                categories: @categories %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

  <%= render 'shared/slideover' %>
  <%= render 'shared/note_panel' %>
  <%= render 'shared/comment_panel' %>
</div>
