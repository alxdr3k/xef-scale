<div class="max-w-7xl mx-auto" data-controller="bulk-select note-panel comment-panel" data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick click@document->comment-panel#handleOutsideClick">
  <%= link_to '← 업로드 목록', workspace_parsing_sessions_path(@workspace),
      class: 'text-indigo-600 hover:text-indigo-800 mb-4 inline-block' %>

  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">거래 검토</h1>
      <p class="text-gray-600">
        <% if @parsing_session.text_paste? %>
          텍스트 붙여넣기
        <% elsif @parsing_session.processed_file %>
          <%= @parsing_session.processed_file.filename %>
        <% else %>
          파일 정보 없음
        <% end %>
      </p>
    </div>

    <div class="flex items-center space-x-2">
      <% if @parsing_session.review_pending? %>
        <span class="px-3 py-1 text-sm rounded-full bg-yellow-100 text-yellow-800">검토 대기</span>
      <% elsif @parsing_session.review_committed? %>
        <span class="px-3 py-1 text-sm rounded-full bg-green-100 text-green-800">확정됨</span>
      <% elsif @parsing_session.review_rolled_back? %>
        <span class="px-3 py-1 text-sm rounded-full bg-red-100 text-red-800">롤백됨</span>
      <% elsif @parsing_session.review_discarded? %>
        <span class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-800">취소됨</span>
      <% end %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">전체</div>
      <div class="text-2xl font-bold text-gray-900"><%= @parsing_session.total_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">성공</div>
      <div class="text-2xl font-bold text-green-600"><%= @parsing_session.success_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">총 금액</div>
      <div class="text-2xl font-bold text-indigo-600">
        <%= number_to_currency(@transactions.excluding_coupon.sum(&:amount), unit: '₩', precision: 0) %>
      </div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">상태</div>
      <div class="text-lg font-bold">
        <% if @read_only %>
          읽기 전용
        <% else %>
          편집 가능
        <% end %>
      </div>
    </div>
  </div>

  <!-- Duplicate Section -->
  <% unless @read_only %>
    <%= render "reviews/duplicate_section",
        duplicate_confirmations: @duplicate_confirmations,
        workspace: @workspace,
        parsing_session: @parsing_session %>
  <% end %>

  <!-- Session Action Bar (세션 전체 액션만) -->
  <% unless @read_only %>
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <div class="flex justify-end items-center gap-3">
        <% if @parsing_session.review_pending? %>
          <%= form_with url: discard_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: '모든 거래를 취소하고 업로드를 폐기하시겠습니까? 이 작업은 되돌릴 수 없습니다.' } do %>
            <button type="submit" class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50">
              전체 취소
            </button>
          <% end %>
          <%= form_with url: commit_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: "#{@transactions.count}건의 거래를 거래 내역에 반영하시겠습니까?" } do %>
            <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700">
              거래 내역 반영
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @read_only && @parsing_session.review_committed? %>
    <div class="bg-white rounded-lg shadow p-4 mb-6">
      <div class="flex justify-between items-center">
        <div class="text-gray-600">
          <span class="font-medium">확정일:</span>
          <%= @parsing_session.committed_at&.strftime('%Y-%m-%d %H:%M') %>
        </div>
        <%= form_with url: rollback_workspace_parsing_session_path(@workspace, @parsing_session),
            method: :post, class: 'inline-block', data: { turbo_confirm: '모든 거래를 롤백하시겠습니까? 이 작업은 되돌릴 수 없습니다.' } do %>
          <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
            전체 롤백
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Transactions Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <% unless @read_only %>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-16">
                <button type="button" data-action="click->bulk-select#toggleSelectAll"
                        class="text-xs text-indigo-600 hover:text-indigo-800 font-medium whitespace-nowrap">
                  <span data-bulk-select-target="selectAllLabel">전체 선택</span>
                </button>
              </th>
            <% end %>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">날짜</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">내역</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">금액</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase w-36">카테고리</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">금융기관</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase">용돈</th>
            <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase w-16">댓글</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200" id="transactions-review-list">
          <% @transactions.each do |tx| %>
            <%= render 'reviews/transaction_row', transaction: tx, read_only: @read_only,
                categories: @categories, institutions: @institutions %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

  <%# 플로팅 액션 바 (선택 시에만 표시) %>
  <% unless @read_only %>
    <%# 숨겨진 일괄 처리 폼 %>
    <%= form_with url: bulk_update_workspace_parsing_session_path(@workspace, @parsing_session),
        method: :post, data: { turbo: false, bulk_form: true } do %>
      <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
      <input type="hidden" name="bulk_action" value="">
      <input type="hidden" name="category_id" value="">
    <% end %>

    <div data-bulk-select-target="floatingBar"
         class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50
                bg-gray-900 text-white rounded-full shadow-2xl
                px-5 py-3 flex items-center gap-3
                transition-all duration-200 ease-out
                translate-y-20 opacity-0 pointer-events-none">

      <%# 선택 카운트 %>
      <span class="text-sm font-medium whitespace-nowrap">
        <span data-bulk-select-target="floatingCount">0</span>개 선택됨
      </span>

      <div class="w-px h-5 bg-gray-600"></div>

      <%# 선택 해제 %>
      <button type="button" data-action="click->bulk-select#deselectAll"
              class="p-1.5 hover:bg-gray-700 rounded-full transition-colors" title="선택 해제">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <%# 삭제 %>
      <button type="button" data-action="click->bulk-select#deleteSelected"
              class="px-4 py-1.5 bg-red-500 hover:bg-red-600 rounded-full
                     text-sm font-medium transition-colors">
        삭제
      </button>

      <%# 더보기 메뉴 %>
      <div class="relative">
        <button type="button" data-action="click->bulk-select#toggleMore"
                class="p-1.5 hover:bg-gray-700 rounded-full transition-colors" title="더보기">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
          </svg>
        </button>

        <div data-bulk-select-target="moreMenu"
             class="hidden absolute bottom-full mb-2 right-0
                    bg-white rounded-lg shadow-xl border border-gray-200
                    py-1 min-w-[180px] text-gray-700">
          <button type="button" data-action="click->bulk-select#markAllowance"
                  class="w-full px-4 py-2.5 text-left text-sm hover:bg-gray-100 transition-colors">
            용돈 표시
          </button>
          <button type="button" data-action="click->bulk-select#unmarkAllowance"
                  class="w-full px-4 py-2.5 text-left text-sm hover:bg-gray-100 transition-colors">
            용돈 해제
          </button>
          <div class="border-t border-gray-200 my-1"></div>
          <div class="px-4 py-2">
            <label class="block text-xs text-gray-500 mb-1">카테고리 변경</label>
            <div class="flex gap-1">
              <select name="category_id" class="text-sm rounded border-gray-300 flex-1 min-w-0">
                <option value="">선택...</option>
                <% @categories.each do |cat| %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% end %>
              </select>
              <button type="button" data-action="click->bulk-select#changeCategory"
                      class="px-2 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700 shrink-0">
                적용
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= render 'shared/slideover' %>
  <%= render 'shared/note_panel' %>
  <%= render 'shared/comment_panel' %>
</div>
