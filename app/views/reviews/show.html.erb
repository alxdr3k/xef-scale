<%# Phase 5 slice 3: review-keyboard 컨트롤러로 j/k row navigation (ADR-0008 / ui-redesign-plan §3.3). %>
<div class="max-w-7xl mx-auto"
     data-controller="bulk-select note-panel comment-panel review-keyboard"
     data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick click@document->comment-panel#handleOutsideClick keydown@window->review-keyboard#handleKey"
     data-bulk-select-delete-payment-confirm-template-value="<%= t("common.js_bulk.delete_payment_confirm_template") %>"
     data-bulk-select-select-all-label-value="<%= t("common.js_bulk.select_all_label") %>"
     data-bulk-select-deselect-all-label-value="<%= t("common.js_bulk.deselect_all_label") %>"
     data-comment-panel-load-error-value="<%= t("common.js_comment.load_error") %>"
     data-review-keyboard-exclude-confirm-value="<%= t("common.js_review_keyboard.exclude_confirm") %>">
  <%= link_to t("reviews.show.back"), workspace_parsing_sessions_path(@workspace),
      class: 'text-action hover:text-action-hover mb-4 inline-block' %>

  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary"><%= t("reviews.show.title") %></h1>
      <p class="text-secondary">
        <% if @parsing_session.text_paste? %>
          <%= t("reviews.show.text_paste_source") %>
        <% elsif @parsing_session.processed_file %>
          <%= @parsing_session.processed_file.filename %>
          <%= render "shared/blob_purged_badge", processed_file: @parsing_session.processed_file %>
        <% else %>
          <%= t("reviews.show.no_file_info") %>
        <% end %>
      </p>
    </div>

    <div class="flex items-center space-x-2">
      <%= render 'shared/status_badge', status: @parsing_session.review_status, type: :review %>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("reviews.show.stat_total") %></div>
      <div class="text-2xl font-bold text-primary"><%= t("reviews.show.count_suffix", count: (@parsing_session.total_count || 0)) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("reviews.show.stat_success") %></div>
      <div class="text-2xl font-bold text-positive"><%= t("reviews.show.count_suffix", count: (@parsing_session.success_count || 0)) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("reviews.show.stat_amount") %></div>
      <div class="text-2xl font-bold text-action">
        <%= number_to_currency(@transactions.excluding_coupon.sum(&:amount), unit: '₩', precision: 0) %>
      </div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("reviews.show.stat_status") %></div>
      <div class="text-lg font-bold">
        <% if @read_only %>
          <%= t("reviews.show.status_read_only") %>
        <% else %>
          <%= t("reviews.show.status_editable") %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Import Issue Repair Section (B4) -->
  <% unless @read_only %>
    <%= render "reviews/import_issues_section",
        open_import_issues: @open_import_issues,
        workspace: @workspace %>
  <% end %>

  <!-- Duplicate Section -->
  <% unless @read_only %>
    <%= render "reviews/duplicate_section",
        duplicate_confirmations: @duplicate_confirmations,
        workspace: @workspace,
        parsing_session: @parsing_session %>
  <% end %>

  <!-- Session Action Bar (세션 전체 액션만) -->
  <% unless @read_only %>
    <div class="bg-surface rounded-lg shadow p-4 mb-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:justify-end sm:items-center">
        <% if @parsing_session.review_pending? %>
          <%# GPT 적대적 리뷰 §2.6.1 (P0 #5) — commit_blocked일 때 사유 명시.
              미해결 중복 / 미해결 import issue 가 있으면 commit 자체를 비활성
              버튼으로 보여주고, "왜 못 누르는지" 를 한 줄로 명시한다. 서버
              가드는 reviews_controller#commit에 그대로 남아 있어 defense
              in depth. %>
          <% if @commit_blocked %>
            <div class="flex-1 text-sm text-warning sm:text-left text-center"
                 role="status" aria-live="polite">
              <% @commit_block_reasons.each do |reason| %>
                <% case reason[:kind]
                   when :duplicates %>
                  <div><%= t("risk.commit_locked", count: reason[:count]) %></div>
                <% when :issues %>
                  <div><%= t("reviews.show.commit_locked_issues", count: reason[:count]) %></div>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <%= form_with url: discard_workspace_parsing_session_path(@workspace, @parsing_session),
              method: :post, class: 'inline-block', data: { turbo_confirm: t("reviews.show.cancel_all_confirm") } do %>
            <button type="submit" class="px-4 py-2 border border-divider text-secondary rounded-lg hover:bg-elev">
              <%= t("reviews.show.cancel_all") %>
            </button>
          <% end %>

          <%# Codex PR #248 P2-a: form.requestSubmit() 은 submitter 없이 호출되면
              disabled button 을 우회한다. blocked 일 때는 form 과 commitForm
              target 자체를 렌더하지 않아 `c` 키 단축키가 자연스럽게 no-op
              (review_keyboard_controller는 hasCommitFormTarget 가드를 가짐). %>
          <% if @commit_blocked %>
            <button type="button"
                    disabled
                    aria-disabled="true"
                    class="px-4 py-2 bg-positive text-action-on rounded-lg opacity-50 cursor-not-allowed">
              <%= t("reviews.show.commit") %>
            </button>
          <% else %>
            <% commit_msg = @pagy.pages > 1 ?
                 t("reviews.show.commit_confirm_partial", total: @total_commit_count, shown: @transactions.count) :
                 t("reviews.show.commit_confirm_full", count: @total_commit_count) %>
            <%# Phase 5 slice 4: c 키 단축키 — review_keyboard_controller가
                data-review-keyboard-target="commitForm"으로 requestSubmit. %>
            <%= form_with url: commit_workspace_parsing_session_path(@workspace, @parsing_session),
                method: :post, class: 'inline-block',
                data: { turbo_confirm: commit_msg, review_keyboard_target: "commitForm" } do %>
              <button type="submit"
                      aria-disabled="false"
                      class="px-4 py-2 bg-positive text-action-on rounded-lg hover:bg-positive cursor-pointer">
                <%= t("reviews.show.commit") %>
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @read_only && @parsing_session.review_committed? %>
    <% summary = @parsing_session.commit_summary %>
    <div class="bg-surface rounded-lg shadow p-4 mb-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div class="space-y-2 text-sm text-secondary">
          <div class="text-base font-semibold text-primary">
            <%= t("reviews.show.summary.committed", count: summary[:committed]) %>
          </div>
          <% if summary[:originals_replaced].positive? %>
            <div><%= t("reviews.show.summary.originals_replaced", count: summary[:originals_replaced]) %></div>
          <% end %>
          <% if summary[:originals_kept].positive? %>
            <div><%= t("reviews.show.summary.originals_kept", count: summary[:originals_kept]) %></div>
          <% end %>
          <% if summary[:duplicates_kept_both].positive? %>
            <div><%= t("reviews.show.summary.duplicates_kept_both", count: summary[:duplicates_kept_both]) %></div>
          <% end %>
          <% if summary[:excluded].positive? %>
            <div><%= t("reviews.show.summary.excluded", count: summary[:excluded]) %></div>
          <% end %>
          <% if summary[:uncategorized].positive? %>
            <div class="text-warning"><%= t("reviews.show.summary.uncategorized", count: summary[:uncategorized]) %></div>
          <% end %>
          <div class="text-xs text-tertiary pt-1">
            <%= t("reviews.show.summary.committed_at", date: @parsing_session.committed_at&.strftime('%Y-%m-%d %H:%M')) %>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <%= link_to t("reviews.show.view_transactions"),
              workspace_transactions_path(@workspace, year: Date.current.year, month: Date.current.month),
              class: 'px-4 py-2 bg-action text-action-on rounded-lg hover:bg-action-hover' %>
          <%# rollback은 write 권한 action — member_read는 dead-end 버튼이 안 보여야. %>
          <% if current_user.can_write?(@workspace) %>
            <%= form_with url: rollback_workspace_parsing_session_path(@workspace, @parsing_session),
                method: :post, class: 'inline-block', data: { turbo_confirm: t("reviews.show.rollback_confirm") } do %>
              <button type="submit" class="px-4 py-2 bg-surface border border-danger text-danger rounded-lg hover:bg-danger-subtle">
                <%= t("reviews.show.rollback") %>
              </button>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% unless @read_only %>
    <%# 숨겨진 일괄 처리 폼 — Phase 5 slice 6: 'd' 키 단축키도 이 폼을 재사용해
        transaction_excluded event 기록을 포함한 기존 bulk_update delete path를
        그대로 사용한다. %>
    <%= form_with url: bulk_update_workspace_parsing_session_path(@workspace, @parsing_session),
        method: :post, data: { turbo: false, bulk_form: true, review_keyboard_target: "excludeForm" } do %>
      <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
      <input type="hidden" name="bulk_action" value="">
      <input type="hidden" name="category_id" value="">
    <% end %>

    <!-- Selection Toolbar -->
    <div data-bulk-select-target="toolbar"
         class="bg-surface rounded-t-lg shadow-sm border-b border-divider px-4 py-2 flex items-center gap-2 min-h-[44px]">
      <input type="checkbox"
             data-bulk-select-target="toolbarCheckbox"
             data-action="change->bulk-select#toggleSelectAll"
             class="h-4 w-4 rounded border-divider text-action focus:ring-action cursor-pointer">

      <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-tertiary">
        <span><%= t("reviews.show.bulk_select_all") %></span>
      </div>

      <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
        <span class="text-sm font-medium text-action mr-2">
          <span data-bulk-select-target="toolbarCount">0</span><%= t("reviews.show.bulk_count_label") %>
        </span>

        <div class="w-px h-5 bg-divider"></div>

        <button type="button" data-action="click->bulk-select#deleteSelected"
                class="tooltip p-1.5 text-tertiary hover:text-danger hover:bg-danger-subtle rounded transition-colors" aria-label="<%= t("reviews.show.bulk_delete") %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>

        <button type="button" data-action="click->bulk-select#markAllowance"
                class="tooltip p-1.5 text-tertiary hover:text-warning hover:bg-warning-subtle rounded transition-colors" aria-label="<%= t("reviews.show.bulk_allowance") %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </button>

        <button type="button" data-action="click->bulk-select#unmarkAllowance"
                class="tooltip p-1.5 text-tertiary hover:text-secondary hover:bg-elev rounded transition-colors" aria-label="<%= t("reviews.show.bulk_allowance_off") %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
          </svg>
        </button>

        <div class="w-px h-5 bg-divider"></div>

        <div class="flex items-center gap-1">
          <select name="category_id" class="text-xs rounded border-divider py-1 pl-2 pr-6">
            <option value=""><%= t("reviews.show.bulk_category_placeholder") %></option>
            <% @categories.each do |cat| %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% end %>
          </select>
          <button type="button" data-action="click->bulk-select#changeCategory"
                  class="px-2 py-1 bg-action text-action-on rounded text-xs hover:bg-action-hover">
            <%= t("reviews.show.bulk_apply") %>
          </button>
        </div>

        <div class="w-px h-5 bg-divider"></div>

        <div class="relative">
          <button type="button" data-action="click->bulk-select#toggleMore"
                  class="tooltip p-1.5 text-tertiary hover:text-secondary hover:bg-elev rounded transition-colors" aria-label="<%= t("reviews.show.bulk_more") %>">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
            </svg>
          </button>

          <div data-bulk-select-target="moreMenu"
               class="hidden absolute top-full mt-1 right-0 z-10
                      bg-surface rounded-lg shadow-xl border border-divider
                      py-1 min-w-[160px] text-secondary">
            <button type="button" data-action="click->bulk-select#deselectAll"
                    class="w-full px-4 py-2 text-left text-sm hover:bg-elev transition-colors">
              <%= t("reviews.show.bulk_clear") %>
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Transactions Table -->
  <div class="bg-surface <%= @read_only ? 'rounded-lg' : 'rounded-b-lg' %> shadow overflow-visible">
    <div class="overflow-visible">
      <table class="min-w-full divide-y divide-divider">
        <thead class="bg-elev">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("reviews.show.th_date") %></th>
            <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("reviews.show.th_merchant") %></th>
            <th class="px-4 py-3 text-right text-xs font-medium text-tertiary uppercase"><%= t("reviews.show.th_amount") %></th>
            <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase w-36"><%= t("reviews.show.th_category") %></th>
            <th class="px-2 py-3 text-center text-xs font-medium text-tertiary uppercase w-16"><%= t("reviews.show.th_source") %></th>
            <th class="px-4 py-3 text-center text-xs font-medium text-tertiary uppercase w-16"><%= t("reviews.show.th_comments") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-divider" id="transactions-review-list">
          <% @transactions.each do |tx| %>
            <%# Phase 5 slice 3: reviewable: true → row가 tabindex=0으로 키보드 focusable.
                review-keyboard 컨트롤러의 j/k navigation 대상. %>
            <%= render 'transactions/transaction_row', transaction: tx, read_only: @read_only,
                categories: @categories, reviewable: true %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

  <%= render 'shared/slideover' %>
  <%= render 'shared/note_panel' %>
  <%= render 'shared/comment_panel' %>
  <%# Phase 5 slice 5: 키보드 단축키 도움말 overlay (? 단축키로 토글). %>
  <%= render 'shared/keyboard_shortcuts_help', workspace: @workspace %>
</div>
