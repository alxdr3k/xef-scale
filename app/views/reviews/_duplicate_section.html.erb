<%= turbo_frame_tag "duplicate-section" do %>
  <% if duplicate_confirmations.any? %>
    <div class="mb-6" data-controller="duplicate-review">
      <!-- Warning Banner -->
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-3">
            <!-- Warning Icon -->
            <svg class="w-6 h-6 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
              <h3 class="font-semibold text-amber-800">
                중복이 의심되는 거래 <span id="duplicate-count" data-duplicate-review-target="count"><%= duplicate_confirmations.count %></span>건을 발견했습니다
              </h3>
              <p class="text-sm text-amber-700 mt-1">장부에 어떻게 반영할지 각 항목에서 선택하거나 일괄 처리할 수 있습니다. 일괄 교체는 개별 확인 없이 적용되므로 주의해 주세요.</p>
            </div>
          </div>

          <!-- Bulk Action Buttons -->
          <div class="flex items-center gap-2 flex-shrink-0" data-duplicate-review-target="bulkActions">
            <%= form_with url: bulk_resolve_duplicates_workspace_parsing_session_path(workspace, parsing_session),
                method: :post,
                class: "flex items-center gap-2",
                data: { turbo_frame: "duplicate-section" } do |f| %>
              <button type="submit" name="decision" value="keep_original"
                      class="px-3 py-1.5 text-sm border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors cursor-pointer"
                      title="새로 가져온 거래를 모두 제외합니다. 총액은 변하지 않습니다."
                      data-turbo-confirm="모든 중복 거래를 기존 거래로 유지하시겠습니까? 새 거래는 장부에 반영되지 않습니다.">
                기존 거래만 남기기
              </button>
              <button type="submit" name="decision" value="keep_new"
                      class="px-3 py-1.5 text-sm border border-indigo-300 text-indigo-700 rounded-lg hover:bg-indigo-50 transition-colors cursor-pointer"
                      title="기존 거래를 숨기고 새 거래로 교체합니다. 되돌리려면 개별 항목을 복원해야 합니다."
                      data-turbo-confirm="⚠️ 기존 거래 전체를 새 거래로 교체합니다. 이 작업은 개별 확인 없이 일괄 적용됩니다. 계속할까요?">
                새 거래로 전체 교체
              </button>
              <button type="submit" name="decision" value="keep_both"
                      class="px-3 py-1.5 text-sm border border-blue-300 text-blue-700 rounded-lg hover:bg-blue-50 transition-colors cursor-pointer"
                      title="두 거래 모두 장부에 남습니다. 이번 달 총액이 늘어납니다."
                      data-turbo-confirm="모든 중복 거래를 둘 다 남기시겠습니까? 장부 총액이 증가합니다.">
                둘 다 남기기
              </button>
            <% end %>

            <!-- Collapse Toggle -->
            <button type="button"
                    class="p-1.5 text-amber-600 hover:bg-amber-100 rounded-lg transition-colors ml-2 cursor-pointer"
                    data-action="click->duplicate-review#toggleCollapse"
                    data-duplicate-review-target="toggleButton"
                    title="접기/펼치기">
              <svg class="w-5 h-5 transition-transform" data-duplicate-review-target="toggleIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Duplicate Cards List -->
        <div class="mt-4 space-y-4" data-duplicate-review-target="cardList">
          <% duplicate_confirmations.each do |confirmation| %>
            <%= render "reviews/duplicate_card",
                confirmation: confirmation,
                workspace: workspace,
                parsing_session: parsing_session %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
