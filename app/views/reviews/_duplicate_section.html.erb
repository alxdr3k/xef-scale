<%= turbo_frame_tag "duplicate-section" do %>
  <% if duplicate_confirmations.any? %>
    <div class="mb-6" data-controller="duplicate-review">
      <!-- Warning Banner -->
      <div class="bg-warning-subtle border border-warning rounded-lg p-4">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-3">
            <!-- Warning Icon -->
            <svg class="w-6 h-6 text-warning flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div>
              <h3 class="font-semibold text-warning">
                <%= t("reviews.duplicate_section.banner_html", count: duplicate_confirmations.count).html_safe %>
              </h3>
              <p class="text-sm text-warning mt-1"><%= t("reviews.duplicate_section.banner_hint") %></p>
            </div>
          </div>

          <!-- Bulk Action Buttons -->
          <div class="flex items-center gap-2 flex-shrink-0" data-duplicate-review-target="bulkActions">
            <%= form_with url: bulk_resolve_duplicates_workspace_parsing_session_path(workspace, parsing_session),
                method: :post,
                class: "flex items-center gap-2",
                data: { turbo_frame: "duplicate-section" } do |f| %>
              <button type="submit" name="decision" value="keep_original"
                      class="px-3 py-1.5 text-sm border border-divider text-secondary rounded-lg hover:bg-elev transition-colors cursor-pointer"
                      title="<%= t("reviews.duplicate_section.bulk_keep_original_title") %>"
                      data-turbo-confirm="<%= t("reviews.duplicate_section.bulk_keep_original_confirm") %>">
                <%= t("reviews.duplicate_section.bulk_keep_original") %>
              </button>
              <button type="submit" name="decision" value="keep_new"
                      class="px-3 py-1.5 text-sm border border-action text-action rounded-lg hover:bg-action-subtle transition-colors cursor-pointer"
                      title="<%= t("reviews.duplicate_section.bulk_keep_new_title") %>"
                      data-turbo-confirm="<%= t("reviews.duplicate_section.bulk_keep_new_confirm") %>">
                <%= t("reviews.duplicate_section.bulk_keep_new") %>
              </button>
              <button type="submit" name="decision" value="keep_both"
                      class="px-3 py-1.5 text-sm border border-info text-info rounded-lg hover:bg-info-subtle transition-colors cursor-pointer"
                      title="<%= t("reviews.duplicate_section.bulk_keep_both_title") %>"
                      data-turbo-confirm="<%= t("reviews.duplicate_section.bulk_keep_both_confirm") %>">
                <%= t("reviews.duplicate_section.bulk_keep_both") %>
              </button>
            <% end %>

            <!-- Collapse Toggle -->
            <button type="button"
                    class="p-1.5 text-warning hover:bg-warning-subtle rounded-lg transition-colors ml-2 cursor-pointer"
                    data-action="click->duplicate-review#toggleCollapse"
                    data-duplicate-review-target="toggleButton"
                    title="<%= t("reviews.duplicate_section.collapse_toggle") %>">
              <svg class="w-5 h-5 transition-transform" data-duplicate-review-target="toggleIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Duplicate Cards List -->
        <div class="mt-4 space-y-4" data-duplicate-review-target="cardList">
          <% duplicate_confirmations.each do |confirmation| %>
            <%= render "reviews/duplicate_card",
                confirmation: confirmation,
                workspace: workspace,
                parsing_session: parsing_session %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
