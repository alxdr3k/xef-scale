<%= turbo_frame_tag dom_id(confirmation) do %>
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden"
       data-duplicate-review-target="card">
    <!-- Comparison Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-gray-200">
      <!-- Original Transaction (Left) -->
      <div class="p-4">
        <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">기존 거래</div>
        <% original = confirmation.original_transaction %>
        <div class="space-y-2">
          <div class="font-medium text-gray-900 text-lg truncate" title="<%= original.description %>">
            <%= original.description %>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <span><%= original.date&.strftime('%Y.%m.%d') %></span>
            <span class="text-gray-400">&middot;</span>
            <span class="font-semibold text-gray-900"><%= number_to_currency(original.amount, unit: '₩', precision: 0) %></span>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            <% if original.financial_institution %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                <%= original.financial_institution.name %>
              </span>
            <% end %>
            <% if original.category %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
                <%= original.category.name %>
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- New Transaction (Right) - Highlighted -->
      <div class="p-4 bg-amber-50">
        <div class="text-xs font-medium text-amber-600 uppercase tracking-wide mb-3">새 거래</div>
        <% new_tx = confirmation.new_transaction %>
        <div class="space-y-2">
          <div class="font-medium text-gray-900 text-lg truncate" title="<%= new_tx.description %>">
            <%= new_tx.description %>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <span><%= new_tx.date&.strftime('%Y.%m.%d') %></span>
            <span class="text-gray-400">&middot;</span>
            <span class="font-semibold text-gray-900"><%= number_to_currency(new_tx.amount, unit: '₩', precision: 0) %></span>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            <% if new_tx.financial_institution %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">
                <%= new_tx.financial_institution.name %>
              </span>
            <% end %>
            <% if new_tx.category %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
                <%= new_tx.category.name %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="bg-gray-50 px-4 py-3 border-t border-gray-200">
      <div class="flex items-center justify-end gap-2">
        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- Skip (keep_original) -->
          <button type="submit" name="decision" value="keep_original"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            건너뛰기
          </button>
        <% end %>

        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- Keep Both -->
          <button type="submit" name="decision" value="keep_both"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-blue-300 text-blue-700 rounded-lg hover:bg-blue-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            둘 다 유지
          </button>
        <% end %>

        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- Replace (keep_new) -->
          <button type="submit" name="decision" value="keep_new"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            교체
          </button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
