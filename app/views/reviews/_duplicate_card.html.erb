<%= turbo_frame_tag dom_id(confirmation) do %>
  <% original = confirmation.original_transaction %>
  <% new_tx = confirmation.new_transaction %>
  <% merchant_diff = original.merchant != new_tx.merchant %>
  <% category_diff = original.category_id != new_tx.category_id %>
  <% confidence = confirmation.match_confidence.presence || "medium" %>
  <% confidence_label, confidence_classes = case confidence
                                            when "high"
                                              [ t("reviews.duplicate_card.confidence_high"), "bg-danger-subtle text-danger border-danger" ]
                                            when "low"
                                              [ t("reviews.duplicate_card.confidence_low"), "bg-elev text-secondary border-divider" ]
                                            else
                                              [ t("reviews.duplicate_card.confidence_medium"), "bg-warning-subtle text-warning border-warning" ]
                                            end %>
  <div class="bg-surface rounded-lg border border-divider shadow-sm overflow-hidden"
       data-duplicate-review-target="card">
    <div class="px-4 pt-3 pb-1 flex items-center justify-between">
      <span class="inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full border <%= confidence_classes %>">
        <%= confidence_label %>
        <% if confirmation.match_score %>
          <span class="text-[10px] font-normal opacity-75"><%= t("reviews.duplicate_card.match_score", score: confirmation.match_score) %></span>
        <% end %>
      </span>
    </div>
    <!-- Comparison Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-divider">
      <!-- Original Transaction (Left) -->
      <div class="p-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-medium text-tertiary uppercase tracking-wide"><%= t("reviews.duplicate_card.original_label") %></span>
          <% if original.parsing_session %>
            <% orig_session = original.parsing_session %>
            <% if orig_session.review_pending? || orig_session.review_committed? %>
              <span class="inline-flex items-center gap-0.5 text-[10px]">
                #<%= orig_session.id %>
                <%= render 'shared/status_badge', status: orig_session.review_status, type: :review %>
              </span>
            <% end %>
          <% end %>
        </div>
        <div class="space-y-2">
          <div class="font-medium text-lg truncate <%= merchant_diff ? 'text-warning bg-warning-subtle px-1 -mx-1 rounded' : 'text-primary' %>" title="<%= original.merchant %>">
            <%= original.merchant %>
          </div>
          <div class="flex items-center gap-2 text-sm text-secondary">
            <span><%= original.date&.strftime('%Y.%m.%d') %></span>
            <span class="text-tertiary">&middot;</span>
            <span class="font-semibold text-primary"><%= number_to_currency(original.amount, unit: '₩', precision: 0) %></span>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            <%= render 'shared/category_badge', category: original.category, highlighted: category_diff %>
          </div>
        </div>
      </div>

      <!-- New Transaction (Right) - Highlighted -->
      <div class="p-4 bg-warning-subtle">
        <div class="text-xs font-medium text-warning uppercase tracking-wide mb-3"><%= t("reviews.duplicate_card.new_label") %></div>
        <div class="space-y-2">
          <div class="font-medium text-lg truncate <%= merchant_diff ? 'text-warning bg-warning-subtle px-1 -mx-1 rounded' : 'text-primary' %>" title="<%= new_tx.merchant %>">
            <%= new_tx.merchant %>
          </div>
          <div class="flex items-center gap-2 text-sm text-secondary">
            <span><%= new_tx.date&.strftime('%Y.%m.%d') %></span>
            <span class="text-tertiary">&middot;</span>
            <span class="font-semibold text-primary"><%= number_to_currency(new_tx.amount, unit: '₩', precision: 0) %></span>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            <%= render 'shared/category_badge', category: new_tx.category, highlighted: category_diff %>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="bg-elev px-4 py-3 border-t border-divider">
      <div class="flex items-center justify-end gap-2">
        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- keep_original: drop the new transaction, leave the ledger unchanged -->
          <button type="submit" name="decision" value="keep_original"
                  title="<%= t("reviews.duplicate_card.keep_original_title") %>"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-divider text-secondary rounded-lg hover:bg-elev transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <%= t("reviews.duplicate_card.keep_original") %>
          </button>
        <% end %>

        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- keep_both: both rows remain in the ledger, monthly total increases -->
          <button type="submit" name="decision" value="keep_both"
                  title="<%= t("reviews.duplicate_card.keep_both_title") %>"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-info text-info rounded-lg hover:bg-info-subtle transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <%= t("reviews.duplicate_card.keep_both") %>
          </button>
        <% end %>

        <%= form_with url: workspace_parsing_session_duplicate_confirmation_path(workspace, parsing_session, confirmation),
            method: :patch,
            class: "inline-flex",
            data: { turbo_frame: dom_id(confirmation) } do |f| %>
          <!-- keep_new: hide the existing transaction and use the new one instead -->
          <button type="submit" name="decision" value="keep_new"
                  title="<%= t("reviews.duplicate_card.keep_new_title") %>"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-action text-action-on rounded-lg hover:bg-action-hover transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <%= t("reviews.duplicate_card.keep_new") %>
          </button>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
