<%#
  Phase 3.5 (ADR-0004 / ui-redesign-plan §3.5) — 더보기 페이지.
  그룹 리스트 카드 진입점만. 세부 화면은 기존 경로 유지.
%>
<div class="max-w-2xl mx-auto pb-12">
  <%# ProfileRow %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-primary"><%= @workspace.name %></h1>
    <% if @membership %>
      <p class="text-meta text-secondary mt-1">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-elev text-secondary">
          <%= case @membership.role
              when "owner" then t("workspace_more.role_owner")
              when "co_owner" then t("workspace_more.role_co_owner")
              when "member_write" then t("workspace_more.role_member_write")
              when "member_read" then t("workspace_more.role_member_read")
              else @membership.role
              end %>
        </span>
      </p>
    <% end %>
  </div>

  <%# Group 1: 이 워크스페이스 %>
  <section class="mb-6">
    <h2 class="text-sm font-semibold text-secondary uppercase tracking-wider mb-2 px-1"><%= t("workspace_more.section_this_workspace") %></h2>
    <div class="bg-surface rounded-lg shadow-sm overflow-hidden divide-y divide-divider">
      <%= link_to workspace_path(@workspace), class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
        <span class="text-primary"><%= t("workspace_more.workspace_info") %></span>
        <%= render 'shared/chevron' %>
      <% end %>
      <% if current_user.admin_of?(@workspace) %>
        <%= link_to settings_workspace_path(@workspace), class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
          <span class="text-primary"><%= t("workspace_more.workspace_settings") %></span>
          <%= render 'shared/chevron' %>
        <% end %>
      <% end %>
      <%= link_to workspaces_path, class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
        <span class="text-primary"><%= t("workspace_more.workspace_switch") %></span>
        <%= render 'shared/chevron' %>
      <% end %>
    </div>
  </section>

  <%# Group 2: 내 계정 %>
  <section class="mb-6">
    <h2 class="text-sm font-semibold text-secondary uppercase tracking-wider mb-2 px-1"><%= t("workspace_more.section_my_account") %></h2>
    <div class="bg-surface rounded-lg shadow-sm overflow-hidden divide-y divide-divider">
      <%# Phase 5: 화면 테마 — User#theme. 라디오 폼이 user_settings#update에 POST. %>
      <%= form_with url: user_settings_path, method: :patch,
            data: { controller: "theme", action: "change->theme#submit" } do |f| %>
        <fieldset class="px-4 py-3">
          <legend class="text-primary font-medium mb-2"><%= t("workspace_more.theme_label") %></legend>
          <div class="flex gap-2" role="radiogroup" aria-label="<%= t("workspace_more.theme_aria") %>">
            <% User::THEMES.each do |theme| %>
              <% checked = current_user.theme == theme %>
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="user[theme]" value="<%= theme %>" class="sr-only peer"
                       <%= 'checked' if checked %>
                       data-theme-target="input"
                       data-action="change->theme#apply">
                <span class="block text-center text-sm py-2 rounded-md border border-divider peer-checked:border-action peer-checked:bg-action-subtle peer-checked:text-action">
                  <%= case theme
                      when "auto" then t("workspace_more.theme_auto")
                      when "light" then t("workspace_more.theme_light")
                      when "dark" then t("workspace_more.theme_dark")
                      end %>
                </span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% end %>
      <%= link_to user_settings_path, class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
        <span class="text-primary"><%= t("workspace_more.account_settings") %></span>
        <%= render 'shared/chevron' %>
      <% end %>
      <%= link_to notifications_path, class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
        <span class="text-primary"><%= t("workspace_more.notifications") %></span>
        <%= render 'shared/chevron' %>
      <% end %>
    </div>
  </section>

  <%# Group 3: 도구 %>
  <section class="mb-6">
    <h2 class="text-sm font-semibold text-secondary uppercase tracking-wider mb-2 px-1"><%= t("workspace_more.section_tools") %></h2>
    <div class="bg-surface rounded-lg shadow-sm overflow-hidden divide-y divide-divider">
      <%= link_to allowances_path, class: "flex items-center justify-between px-4 py-3 hover:bg-elev" do %>
        <span class="text-primary"><%= t("workspace_more.allowances") %></span>
        <%= render 'shared/chevron' %>
      <% end %>
    </div>
  </section>

  <%# Group 4: 위험한 작업 %>
  <% if current_user.admin_of?(@workspace) %>
    <section>
      <h2 class="text-sm font-semibold text-danger uppercase tracking-wider mb-2 px-1"><%= t("workspace_more.section_danger") %></h2>
      <div class="bg-surface rounded-lg shadow-sm overflow-hidden divide-y divide-divider">
        <%= button_to workspace_path(@workspace),
              method: :delete,
              data: { turbo_confirm: t("workspace_more.delete_confirm") },
              class: "w-full flex items-center justify-between px-4 py-3 hover:bg-elev text-left" do %>
          <span class="text-danger"><%= t("workspace_more.delete_workspace") %></span>
          <%= render 'shared/chevron' %>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# Sign out %>
  <section class="mt-6">
    <div class="bg-surface rounded-lg shadow-sm overflow-hidden">
      <%= button_to destroy_user_session_path,
            method: :delete,
            class: "w-full flex items-center justify-between px-4 py-3 hover:bg-elev text-left" do %>
        <span class="text-primary"><%= t("workspace_more.sign_out") %></span>
      <% end %>
    </div>
  </section>
</div>
