<div class="max-w-4xl mx-auto">
  <%= link_to t("parsing_sessions.show.back"), workspace_parsing_sessions_path(@workspace), class: 'text-action hover:text-action-hover mb-4 inline-block' %>

  <h1 class="text-2xl font-bold text-primary mb-2"><%= t("parsing_sessions.show.title") %></h1>
  <p class="text-secondary mb-6">
    <%= @parsing_session.processed_file.original_filename %>
    <%= render "shared/blob_purged_badge", processed_file: @parsing_session.processed_file %>
  </p>

  <!-- Summary -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("parsing_sessions.show.stat_total") %></div>
      <div class="text-2xl font-bold text-primary"><%= t("parsing_sessions.show.count_suffix", count: (@parsing_session.total_count || 0)) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("parsing_sessions.show.stat_success") %></div>
      <div class="text-2xl font-bold text-positive"><%= t("parsing_sessions.show.count_suffix", count: (@parsing_session.success_count || 0)) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("parsing_sessions.show.stat_duplicate") %></div>
      <div class="text-2xl font-bold text-warning"><%= t("parsing_sessions.show.count_suffix", count: (@parsing_session.duplicate_count || 0)) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary"><%= t("parsing_sessions.show.stat_error") %></div>
      <div class="text-2xl font-bold text-danger"><%= t("parsing_sessions.show.count_suffix", count: (@parsing_session.error_count || 0)) %></div>
    </div>
  </div>

  <!-- Duplicate Confirmations -->
  <% if @duplicate_confirmations.any? %>
    <div class="bg-surface rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-divider">
        <h2 class="text-lg font-semibold text-primary"><%= t("parsing_sessions.show.duplicate_section_title") %></h2>
        <p class="text-sm text-tertiary"><%= t("parsing_sessions.show.duplicate_section_hint") %></p>
      </div>

      <div class="divide-y divide-divider">
        <% @duplicate_confirmations.each do |dc| %>
          <div class="p-6" id="<%= dom_id(dc) %>">
            <% if dc.pending? %>
              <div class="grid grid-cols-2 gap-4 mb-4">
                <!-- Original Transaction -->
                <div class="border rounded-lg p-4">
                  <div class="text-xs text-tertiary mb-2"><%= t("parsing_sessions.show.duplicate_existing") %></div>
                  <div class="font-medium text-primary"><%= dc.original_transaction.merchant %></div>
                  <div class="text-sm text-tertiary">
                    <%= dc.original_transaction.formatted_date %>
                    · <%= number_to_currency(dc.original_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>

                <!-- New Transaction -->
                <div class="border rounded-lg p-4 border-warning bg-warning-subtle">
                  <div class="text-xs text-tertiary mb-2"><%= t("parsing_sessions.show.duplicate_new") %></div>
                  <div class="font-medium text-primary"><%= dc.new_transaction.merchant %></div>
                  <div class="text-sm text-tertiary">
                    <%= dc.new_transaction.formatted_date %>
                    · <%= number_to_currency(dc.new_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>
              </div>

              <div class="flex space-x-3">
                <%= button_to t("parsing_sessions.show.keep_both"),
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_both'),
                    method: :patch,
                    class: 'px-4 py-2 border border-divider rounded-md text-secondary hover:bg-elev' %>
                <%= button_to t("parsing_sessions.show.keep_existing"),
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_original'),
                    method: :patch,
                    class: 'px-4 py-2 border border-divider rounded-md text-secondary hover:bg-elev' %>
                <%= button_to t("parsing_sessions.show.keep_new"),
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_new'),
                    method: :patch,
                    class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover' %>
              </div>
            <% else %>
              <div class="text-tertiary">
                <span class="font-medium"><%= t("parsing_sessions.show.processed_label") %></span>
                <% case dc.status %>
                <% when 'keep_both' %>
                  <%= t("parsing_sessions.show.keep_both") %>
                <% when 'keep_original' %>
                  <%= t("parsing_sessions.show.keep_existing") %>
                <% when 'keep_new' %>
                  <%= t("parsing_sessions.show.keep_new") %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-surface rounded-lg shadow p-6 text-center">
      <div class="text-4xl mb-4">✅</div>
      <p class="text-secondary"><%= t("parsing_sessions.show.empty") %></p>
    </div>
  <% end %>
</div>
