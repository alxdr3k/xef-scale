<div class="max-w-4xl mx-auto">
  <%= link_to '← 목록으로', workspace_parsing_sessions_path(@workspace), class: 'text-indigo-600 hover:text-indigo-800 mb-4 inline-block' %>

  <h1 class="text-2xl font-bold text-gray-900 mb-2">파싱 결과</h1>
  <p class="text-gray-600 mb-6"><%= @parsing_session.processed_file.original_filename %></p>

  <!-- Summary -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">전체</div>
      <div class="text-2xl font-bold text-gray-900"><%= @parsing_session.total_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">성공</div>
      <div class="text-2xl font-bold text-green-600"><%= @parsing_session.success_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">중복</div>
      <div class="text-2xl font-bold text-yellow-600"><%= @parsing_session.duplicate_count || 0 %>건</div>
    </div>
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-sm text-gray-500">오류</div>
      <div class="text-2xl font-bold text-red-600"><%= @parsing_session.error_count || 0 %>건</div>
    </div>
  </div>

  <%= render "shared/import_issues_notice", import_issues: @import_issues %>

  <!-- Duplicate Confirmations -->
  <% if @duplicate_confirmations.any? %>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">중복 확인</h2>
        <p class="text-sm text-gray-500">새로 추가된 결제와 기존 결제가 중복됩니다. 어떻게 처리할지 선택해 주세요.</p>
      </div>

      <div class="divide-y divide-gray-200">
        <% @duplicate_confirmations.each do |dc| %>
          <div class="p-6" id="<%= dom_id(dc) %>">
            <% if dc.pending? %>
              <div class="grid grid-cols-2 gap-4 mb-4">
                <!-- Original Transaction -->
                <div class="border rounded-lg p-4">
                  <div class="text-xs text-gray-500 mb-2">기존 결제</div>
                  <div class="font-medium text-gray-900"><%= dc.original_transaction.merchant %></div>
                  <div class="text-sm text-gray-500">
                    <%= dc.original_transaction.formatted_date %>
                    · <%= number_to_currency(dc.original_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>

                <!-- New Transaction -->
                <div class="border rounded-lg p-4 border-yellow-300 bg-yellow-50">
                  <div class="text-xs text-gray-500 mb-2">새 결제</div>
                  <div class="font-medium text-gray-900"><%= dc.new_transaction.merchant %></div>
                  <div class="text-sm text-gray-500">
                    <%= dc.new_transaction.formatted_date %>
                    · <%= number_to_currency(dc.new_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>
              </div>

              <div class="flex space-x-3">
                <%= button_to '둘 다 유지',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_both'),
                    method: :patch,
                    class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
                <%= button_to '기존 결제 유지',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_original'),
                    method: :patch,
                    class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
                <%= button_to '새 결제로 교체',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_new'),
                    method: :patch,
                    class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700' %>
              </div>
            <% else %>
              <div class="text-gray-500">
                <span class="font-medium">처리됨:</span>
                <% case dc.status %>
                <% when 'keep_both' %>
                  둘 다 유지
                <% when 'keep_original' %>
                  기존 결제 유지
                <% when 'keep_new' %>
                  새 결제로 교체
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-6 text-center">
      <div class="text-4xl mb-4">✅</div>
      <p class="text-gray-600">중복 결제가 없습니다.</p>
    </div>
  <% end %>
</div>
