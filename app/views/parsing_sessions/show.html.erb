<div class="max-w-4xl mx-auto">
  <%= link_to '← 목록으로', workspace_parsing_sessions_path(@workspace), class: 'text-action hover:text-action-hover mb-4 inline-block' %>

  <h1 class="text-2xl font-bold text-primary mb-2">파싱 결과</h1>
  <p class="text-secondary mb-6">
    <%= @parsing_session.processed_file.original_filename %>
    <%= render "shared/blob_purged_badge", processed_file: @parsing_session.processed_file %>
  </p>

  <!-- Summary -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary">전체</div>
      <div class="text-2xl font-bold text-primary"><%= @parsing_session.total_count || 0 %>건</div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary">성공</div>
      <div class="text-2xl font-bold text-positive"><%= @parsing_session.success_count || 0 %>건</div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary">중복</div>
      <div class="text-2xl font-bold text-warning"><%= @parsing_session.duplicate_count || 0 %>건</div>
    </div>
    <div class="bg-surface rounded-lg shadow p-4">
      <div class="text-sm text-tertiary">오류</div>
      <div class="text-2xl font-bold text-danger"><%= @parsing_session.error_count || 0 %>건</div>
    </div>
  </div>

  <!-- Duplicate Confirmations -->
  <% if @duplicate_confirmations.any? %>
    <div class="bg-surface rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-divider">
        <h2 class="text-lg font-semibold text-primary">중복 확인</h2>
        <p class="text-sm text-tertiary">새로 추가된 결제와 기존 결제가 중복됩니다. 어떻게 처리할지 선택해 주세요.</p>
      </div>

      <div class="divide-y divide-divider">
        <% @duplicate_confirmations.each do |dc| %>
          <div class="p-6" id="<%= dom_id(dc) %>">
            <% if dc.pending? %>
              <div class="grid grid-cols-2 gap-4 mb-4">
                <!-- Original Transaction -->
                <div class="border rounded-lg p-4">
                  <div class="text-xs text-tertiary mb-2">기존 결제</div>
                  <div class="font-medium text-primary"><%= dc.original_transaction.merchant %></div>
                  <div class="text-sm text-tertiary">
                    <%= dc.original_transaction.formatted_date %>
                    · <%= number_to_currency(dc.original_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>

                <!-- New Transaction -->
                <div class="border rounded-lg p-4 border-warning bg-warning-subtle">
                  <div class="text-xs text-tertiary mb-2">새 결제</div>
                  <div class="font-medium text-primary"><%= dc.new_transaction.merchant %></div>
                  <div class="text-sm text-tertiary">
                    <%= dc.new_transaction.formatted_date %>
                    · <%= number_to_currency(dc.new_transaction.amount, unit: '₩', precision: 0) %>
                  </div>
                </div>
              </div>

              <div class="flex space-x-3">
                <%= button_to '둘 다 유지',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_both'),
                    method: :patch,
                    class: 'px-4 py-2 border border-divider rounded-md text-secondary hover:bg-elev' %>
                <%= button_to '기존 결제 유지',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_original'),
                    method: :patch,
                    class: 'px-4 py-2 border border-divider rounded-md text-secondary hover:bg-elev' %>
                <%= button_to '새 결제로 교체',
                    workspace_parsing_session_duplicate_confirmation_path(@workspace, @parsing_session, dc, decision: 'keep_new'),
                    method: :patch,
                    class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover' %>
              </div>
            <% else %>
              <div class="text-tertiary">
                <span class="font-medium">처리됨:</span>
                <% case dc.status %>
                <% when 'keep_both' %>
                  둘 다 유지
                <% when 'keep_original' %>
                  기존 결제 유지
                <% when 'keep_new' %>
                  새 결제로 교체
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-surface rounded-lg shadow p-6 text-center">
      <div class="text-4xl mb-4">✅</div>
      <p class="text-secondary">중복 결제가 없습니다.</p>
    </div>
  <% end %>
</div>
