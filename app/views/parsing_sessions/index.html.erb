<div class="max-w-4xl mx-auto" data-controller="bulk-select note-panel onboarding" data-onboarding-page-value="upload" data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">거래 추가</h1>
  <p class="text-gray-600 mb-6">금융 문자를 붙여넣거나 명세서 스크린샷을 올려 거래를 등록하세요.</p>

  <!-- Onboarding Overlay -->
  <div data-onboarding-target="overlay" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg p-4 mb-6">
    <div class="flex justify-between items-start">
      <div>
        <p class="text-sm font-medium text-indigo-900">처음이신가요?</p>
        <p class="text-sm text-indigo-700 mt-1">은행이나 카드사에서 받은 문자 메시지를 아래에 붙여넣으면 AI가 자동으로 거래를 인식합니다.</p>
        <p class="text-xs text-indigo-500 mt-1">여러 문자를 한 번에 붙여넣을 수 있어요.</p>
      </div>
      <button data-action="click->onboarding#dismiss" class="text-indigo-400 hover:text-indigo-600 ml-4 flex-shrink-0">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <!-- Input Methods: Stacked Cards -->
  <div class="space-y-4 mb-8">
    <!-- Card 1: 문자 붙여넣기 (활성) -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-6">
        <%= form_with url: text_parse_workspace_parsing_sessions_path(@workspace), method: :post, local: true, class: 'space-y-4' do %>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
              </svg>
              <h3 class="text-sm font-medium text-gray-900">문자 붙여넣기</h3>
            </div>
            <textarea name="text" id="text" rows="5"
                      class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
                      placeholder="[Web발신]&#10;신한체크 승인 홍*동&#10;50,000원 일시불&#10;03/15 14:30 스타벅스강남점&#10;&#10;여러 문자를 한번에 붙여넣을 수 있습니다."></textarea>
          </div>
          <div class="text-sm text-gray-500">
            카드 승인 문자, 은행 출금 알림 등을 붙여넣으세요. 여러 건을 한번에 붙여넣어도 됩니다.
          </div>
          <div class="flex justify-end">
            <%= submit_tag 'AI 파싱', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Card 2: 스크린샷 업로드 -->
    <div class="bg-white rounded-lg shadow">
      <div class="p-6">
        <%= form_with url: workspace_parsing_sessions_path(@workspace), method: :post, multipart: true, local: true, class: 'space-y-4' do |f| %>
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
            </svg>
            <h3 class="text-sm font-medium text-gray-900">스크린샷 업로드</h3>
          </div>
          <input type="hidden" name="institution_identifier" value="shinhan_card">
          <%= f.file_field :files, multiple: true, accept: "image/jpeg,image/png,image/webp,image/heic",
                class: 'block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100' %>
          <div class="text-sm text-gray-500">
            신한카드 이용대금 명세서 스크린샷(JPG, PNG, WEBP, HEIC)을 올리면 AI가 거래를 인식합니다.
            확정 전까지 거래 내역에는 반영되지 않습니다.
          </div>
          <div class="flex justify-end">
            <%= submit_tag '스크린샷 업로드', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 입력 기록 -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-gray-900">입력 기록</h2>
      <% if @pending_files.any? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
          <svg class="animate-spin -ml-0.5 mr-1.5 h-3 w-3 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <%= @pending_files.size %>개 처리 중
        </span>
      <% end %>
    </div>

    <%# 숨겨진 일괄 처리 폼 %>
    <%= form_with url: bulk_discard_workspace_parsing_sessions_path(@workspace),
        method: :post, data: { turbo: false, bulk_form: true } do %>
      <input type="hidden" name="session_ids" data-bulk-select-target="ids" value="">
    <% end %>

    <!-- Selection Toolbar -->
    <div data-bulk-select-target="toolbar"
         class="border-b border-gray-200 px-4 py-2 flex items-center gap-2 min-h-[44px]">
      <input type="checkbox"
             data-bulk-select-target="toolbarCheckbox"
             data-action="change->bulk-select#toggleSelectAll"
             class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">

      <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-gray-500">
        <span>전체 선택</span>
      </div>

      <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
        <span class="text-sm font-medium text-indigo-700 mr-2">
          <span data-bulk-select-target="toolbarCount">0</span>개 선택됨
        </span>

        <div class="w-px h-5 bg-gray-300"></div>

        <button type="button" data-action="click->bulk-select#discardSelected"
                class="p-1.5 text-gray-500 hover:text-red-600 hover:bg-red-50 rounded transition-colors" title="취소">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
        </button>

        <span class="text-xs text-gray-400">취소</span>
      </div>
    </div>

    <!-- Mobile: Card Layout -->
    <div class="sm:hidden divide-y divide-gray-200">
      <%# Pending files (mobile) %>
      <% @pending_files.each do |processed_file| %>
        <div id="pending_file_card_<%= processed_file.id %>" class="px-4 py-3 bg-blue-50">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-900 truncate flex-1 mr-2"><%= processed_file.original_filename %></span>
            <span class="inline-flex items-center px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-800 flex-shrink-0">
              <svg class="animate-spin -ml-0.5 mr-1 h-3 w-3 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <%= processed_file.status == 'pending' ? '대기중' : '처리중' %>
            </span>
          </div>
          <div class="text-xs text-gray-500 mt-1"><%= time_ago_in_words(processed_file.created_at) %> 전</div>
        </div>
      <% end %>

      <%# Parsing sessions (mobile) %>
      <% @parsing_sessions.each do |parsing_session| %>
        <%= render partial: 'parsing_session_card', locals: { parsing_session: parsing_session, workspace: @workspace } %>
      <% end %>

      <% if @parsing_sessions.empty? && @pending_files.empty? %>
        <div class="px-6 py-12 text-center text-gray-500">
          입력 기록이 없습니다.
        </div>
      <% end %>
    </div>

    <!-- Desktop: Table Layout -->
    <div class="hidden sm:block overflow-x-auto">
      <table class="w-full table-fixed divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-2 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-12">#</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">입력 내용</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-40">상태</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-44">결과</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-28">시간</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <%# 아직 parsing_session이 생성되지 않은 pending/processing 파일들 %>
          <% @pending_files.each do |processed_file| %>
            <tr id="pending_file_row_<%= processed_file.id %>" class="bg-blue-50">
              <td class="px-2 py-4 text-center text-sm text-gray-400">-</td>
              <td class="px-4 py-4 text-sm text-gray-900 truncate">
                <%= processed_file.original_filename %>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">
                  <svg class="animate-spin -ml-0.5 mr-1.5 h-3 w-3 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                  <%= processed_file.status == 'pending' ? '대기중' : '처리중' %>
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">-</td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= time_ago_in_words(processed_file.created_at) %> 전
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium"></td>
            </tr>
          <% end %>

          <%# 기존 parsing_sessions %>
          <% @parsing_sessions.each do |parsing_session| %>
            <%= render partial: 'parsing_session_row', locals: { parsing_session: parsing_session, workspace: @workspace } %>
          <% end %>

          <% if @parsing_sessions.empty? && @pending_files.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                입력 기록이 없습니다.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>

  <%= render 'shared/note_panel' %>
</div>
