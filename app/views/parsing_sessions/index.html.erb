<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">파일 업로드</h1>
  <p class="text-gray-600 mb-6">은행/카드 명세서를 업로드하거나 텍스트를 붙여넣어 거래 내역을 자동으로 등록하세요.</p>

  <!-- Upload Form -->
  <div class="bg-white rounded-lg shadow p-6 mb-8" data-controller="tabs">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">새 거래 추가</h2>

    <!-- Tabs -->
    <div class="border-b border-gray-200 mb-6">
      <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <button type="button" data-tabs-target="tab" data-action="click->tabs#switch"
                class="border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          파일 업로드
        </button>
        <button type="button" data-tabs-target="tab" data-action="click->tabs#switch"
                class="border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          텍스트 붙여넣기
        </button>
      </nav>
    </div>

    <!-- Tab Panel 1: File Upload -->
    <div data-tabs-target="panel" class="hidden">
      <%= form_with url: workspace_parsing_sessions_path(@workspace), method: :post, multipart: true, local: true, class: 'space-y-4' do |f| %>
        <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center overflow-hidden">
          <input type="file" name="file" id="file"
                 accept=".xlsx,.xls,.csv,.pdf"
                 class="hidden"
                 onchange="const name = this.files[0]?.name || '파일을 선택하세요'; document.getElementById('file-name').textContent = decodeURIComponent(name); document.getElementById('file-name').title = decodeURIComponent(name);">
          <label for="file" class="cursor-pointer block">
            <div class="text-4xl mb-4">📄</div>
            <div id="file-name" class="text-gray-600 mb-2 truncate max-w-full px-4">파일을 선택하세요</div>
            <div class="text-sm text-gray-400">Excel(.xlsx, .xls), CSV, PDF 파일 지원</div>
          </label>
        </div>

        <div class="text-sm text-gray-500">
          <strong>지원 금융기관:</strong> 신한카드, 하나카드, 토스뱅크, 카카오뱅크
        </div>

        <div class="flex justify-end">
          <%= submit_tag '업로드', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
        </div>
      <% end %>
    </div>

    <!-- Tab Panel 2: Text Paste -->
    <div data-tabs-target="panel" class="hidden">
      <%= form_with url: create_from_text_workspace_parsing_sessions_path(@workspace), method: :post, local: true, class: 'space-y-4' do |f| %>
        <div>
          <label for="financial_institution" class="block text-sm font-medium text-gray-700 mb-2">
            금융기관 선택
          </label>
          <select name="financial_institution" id="financial_institution"
                  class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
            <option value="shinhan_card">신한카드</option>
          </select>
          <p class="mt-1 text-xs text-gray-500">현재 신한카드만 지원됩니다.</p>
        </div>

        <div>
          <label for="raw_text" class="block text-sm font-medium text-gray-700 mb-2">
            거래 내역 텍스트
          </label>
          <textarea name="raw_text" id="raw_text" rows="12"
                    placeholder="신한카드 명세서에서 거래 내역 부분을 복사하여 붙여넣으세요.&#10;&#10;예시:&#10;25.08.06&#10;본인357&#10;스타벅스 강남점&#10;5,500&#10;25.08.07&#10;본인357&#10;이마트&#10;23,400"
                    class="block w-full min-h-[300px] font-mono text-sm rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"></textarea>
          <p class="mt-2 text-sm text-gray-500">
            <strong>도움말:</strong> 신한카드 앱/웹에서 명세서를 열어 날짜, 가맹점, 금액이 포함된 부분을 복사하세요.
            날짜 형식(YY.MM.DD)과 금액이 자동으로 인식됩니다.
          </p>
        </div>

        <div class="flex justify-end">
          <%= submit_tag '파싱하기', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Upload History -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">업로드 기록</h2>
    </div>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">파일명</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">상태</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">결과</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">업로드 시간</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @parsing_sessions.each do |parsing_session| %>
          <%= render partial: 'parsing_session_row', locals: { parsing_session: parsing_session, workspace: @workspace } %>
        <% end %>

        <% if @parsing_sessions.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
              업로드 기록이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
