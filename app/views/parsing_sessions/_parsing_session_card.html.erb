<div id="<%= dom_id(parsing_session) %>_card"
    <% if parsing_session.can_discard? %>
      data-bulk-select-target="row"
      data-transaction-id="<%= parsing_session.id %>"
      data-action="click->bulk-select#toggleRow"
    <% end %>
    class="px-4 py-3 <%= 'cursor-pointer' if parsing_session.can_discard? %>">
  <div class="flex items-center justify-between">
    <span class="text-sm text-primary truncate flex-1 mr-2">
      <% if parsing_session.text_paste? %>
        <span class="text-secondary"><%= t("parsing_sessions.source_text_paste") %></span>
      <% elsif parsing_session.processed_file %>
        <%= parsing_session.processed_file.original_filename %>
        <%= render "shared/blob_purged_badge", processed_file: parsing_session.processed_file %>
      <% else %>
        <span class="text-tertiary"><%= t("parsing_sessions.no_file_info") %></span>
      <% end %>
    </span>
    <span class="flex-shrink-0">
      <%= render 'shared/status_badge', status: parsing_session.status, type: :processing %>
      <% if parsing_session.completed? %>
        <span class="ml-1"><%= render 'shared/status_badge', status: parsing_session.review_status, type: :review %></span>
      <% end %>
    </span>
  </div>
  <div class="flex items-center justify-between mt-1">
    <span class="text-xs text-tertiary">
      <% if parsing_session.completed? %>
        <%= t("parsing_sessions.success_count", count: parsing_session.success_count) %>
        <% pending_dup_count = parsing_session.duplicate_confirmations.select { |dc| dc.status == "pending" }.size %>
        <% if pending_dup_count > 0 %>
          <%= t("parsing_sessions.duplicate_count", count: pending_dup_count) %>
        <% end %>
        <% if local_assigns[:open_issue_count].to_i > 0 %>
          <%= t("parsing_sessions.issue_count", count: local_assigns[:open_issue_count]) %>
        <% end %>
        <% if parsing_session.error_count.to_i > 0 %>
          <%= t("parsing_sessions.error_count", count: parsing_session.error_count) %>
        <% end %>
      <% end %>
    </span>
    <span class="text-xs text-tertiary"><%= t("parsing_sessions.relative_time", relative: time_ago_in_words(parsing_session.created_at)) %></span>
  </div>
  <% if parsing_session.completed? %>
    <div class="mt-2">
      <% if parsing_session.review_pending? %>
        <%= link_to t("parsing_sessions.actions.review"), review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-action hover:text-action-hover font-medium' %>
      <% else %>
        <%= link_to t("parsing_sessions.actions.detail"), review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-secondary hover:text-primary' %>
      <% end %>
    </div>
  <% elsif parsing_session.has_duplicates? && parsing_session.pending_duplicates.any? %>
    <div class="mt-2">
      <%= link_to t("parsing_sessions.actions.check_duplicates"), workspace_parsing_session_path(workspace, parsing_session),
          class: 'text-xs text-action hover:text-action-hover' %>
    </div>
  <% elsif parsing_session.failed? %>
    <div class="mt-2 flex items-center gap-3">
      <%= button_to t("parsing_sessions.actions.retry"), retry_workspace_parsing_session_path(workspace, parsing_session),
          method: :post,
          class: 'text-xs text-action hover:text-action-hover font-medium bg-transparent border-0 cursor-pointer p-0' %>
      <%= button_to t("parsing_sessions.actions.delete"), workspace_parsing_session_path(workspace, parsing_session),
          method: :delete,
          form: { data: { turbo_confirm: t("parsing_sessions.actions.delete_confirm") } },
          class: 'text-xs text-danger hover:text-danger bg-transparent border-0 cursor-pointer p-0' %>
    </div>
  <% end %>
</div>
