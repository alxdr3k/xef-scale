<div id="<%= dom_id(parsing_session) %>_card"
    <% if parsing_session.can_discard? %>
      data-bulk-select-target="row"
      data-transaction-id="<%= parsing_session.id %>"
      data-action="click->bulk-select#toggleRow"
    <% end %>
    class="px-4 py-3 <%= 'cursor-pointer' if parsing_session.can_discard? %>">
  <div class="flex items-center justify-between gap-3">
    <span class="text-sm text-gray-900 truncate flex-1 mr-2">
      <% if parsing_session.text_paste? %>
        <span class="text-gray-600">문자 입력</span>
      <% elsif parsing_session.processed_file %>
        <%= parsing_session.processed_file.original_filename %>
      <% else %>
        <span class="text-gray-400">파일 정보 없음</span>
      <% end %>
    </span>
    <span class="flex-shrink-0">
      <%= render 'shared/status_badge', status: parsing_session.status, type: :processing %>
      <% if parsing_session.completed? %>
        <span class="ml-1"><%= render 'shared/status_badge', status: parsing_session.review_status, type: :review %></span>
      <% end %>
    </span>
  </div>
  <div class="flex items-center justify-between gap-3 mt-1">
    <span class="text-xs text-gray-500 min-w-0 truncate">
      <% if parsing_session.completed? %>
        성공 <%= parsing_session.success_count %>건
        <% pending_dup_count = parsing_session.duplicate_confirmations.select { |dc| dc.status == "pending" }.size +
                               parsing_session.open_import_issues.select(&:ambiguous_duplicate?).size %>
        <% if pending_dup_count > 0 %>
          · 중복 <%= pending_dup_count %>건
        <% end %>
        <% if parsing_session.error_count.to_i > 0 %>
          · 오류 <%= parsing_session.error_count %>건
        <% end %>
      <% elsif parsing_session.failed? && parsing_session.open_import_issues.any? %>
        수정 필요 <%= parsing_session.open_import_issues.size %>건
      <% end %>
    </span>
    <span class="text-xs text-gray-400 whitespace-nowrap flex-shrink-0"><%= time_ago_in_words(parsing_session.created_at) %> 전</span>
  </div>
  <% if parsing_session.completed? %>
    <div class="mt-2">
      <% if parsing_session.pending_review_transactions? %>
        <%= link_to '검토하기', review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-indigo-600 hover:text-indigo-900 font-medium' %>
      <% elsif parsing_session.open_import_issues.any? %>
        <%= link_to '수정하기',
            workspace_transactions_path(workspace, repair: "required", import_session_id: parsing_session.id),
            class: 'text-xs text-indigo-600 hover:text-indigo-900 font-medium' %>
      <% elsif parsing_session.review_pending? %>
        <%= link_to '검토하기', review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-indigo-600 hover:text-indigo-900 font-medium' %>
      <% else %>
        <%= link_to '상세보기', review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-gray-600 hover:text-gray-900' %>
      <% end %>
    </div>
  <% elsif parsing_session.has_duplicates? && parsing_session.pending_duplicates.any? %>
    <div class="mt-2">
      <%= link_to '중복 확인', workspace_parsing_session_path(workspace, parsing_session),
          class: 'text-xs text-indigo-600 hover:text-indigo-900' %>
    </div>
  <% elsif parsing_session.failed? %>
    <div class="mt-2 flex items-center gap-3">
      <% if parsing_session.open_import_issues.any? %>
        <%= link_to '상세보기', workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-xs text-gray-600 hover:text-gray-900' %>
      <% end %>
      <%= button_to '재시도', retry_workspace_parsing_session_path(workspace, parsing_session),
          method: :post,
          class: 'text-xs text-indigo-600 hover:text-indigo-900 font-medium bg-transparent border-0 cursor-pointer p-0' %>
      <%= button_to '삭제', workspace_parsing_session_path(workspace, parsing_session),
          method: :delete,
          form: { data: { turbo_confirm: "이 세션을 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다." } },
          class: 'text-xs text-red-600 hover:text-red-900 bg-transparent border-0 cursor-pointer p-0' %>
    </div>
  <% end %>
</div>
