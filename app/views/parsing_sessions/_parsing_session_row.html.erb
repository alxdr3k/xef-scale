<tr id="<%= dom_id(parsing_session) %>"
    <% if parsing_session.can_discard? %>
      data-bulk-select-target="row"
      data-transaction-id="<%= parsing_session.id %>"
      data-action="click->bulk-select#toggleRow"
    <% end %>
    class="transition-colors duration-150 <%= 'cursor-pointer' if parsing_session.can_discard? %>">
  <td class="pl-4 pr-2 py-4 w-8">
    <% if parsing_session.can_discard? %>
      <div class="w-1.5 h-8 rounded-full transition-colors duration-150 bg-transparent mx-auto"></div>
    <% end %>
  </td>
  <td class="px-2 py-4 text-center text-sm text-gray-400 font-mono">
    #<%= parsing_session.id %>
  </td>
  <td class="px-4 py-4 text-sm text-gray-900 truncate">
    <% if parsing_session.text_paste? %>
      <span class="text-gray-600">텍스트 붙여넣기</span>
    <% elsif parsing_session.processed_file %>
      <%= parsing_session.processed_file.original_filename %>
    <% else %>
      <span class="text-gray-400">파일 정보 없음</span>
    <% end %>
  </td>
  <td class="px-4 py-4 whitespace-nowrap">
    <% case parsing_session.status %>
    <% when 'pending' %>
      <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-800">대기중</span>
    <% when 'processing' %>
      <span class="inline-flex items-center px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">
        <svg class="animate-spin -ml-0.5 mr-1.5 h-3 w-3 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        처리중
      </span>
    <% when 'completed' %>
      <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-800">완료</span>
    <% when 'failed' %>
      <span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-800">실패</span>
    <% end %>
    <% if parsing_session.completed? %>
      <% case parsing_session.review_status %>
      <% when 'pending_review' %>
        <span class="px-2 py-1 text-xs rounded-full bg-yellow-100 text-yellow-800 ml-1">검토 대기</span>
      <% when 'committed' %>
        <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-800 ml-1">확정</span>
      <% when 'rolled_back' %>
        <span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-800 ml-1">롤백</span>
      <% when 'discarded' %>
        <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-800 ml-1">취소됨</span>
      <% end %>
    <% end %>
  </td>
  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
    <% if parsing_session.completed? %>
      성공 <%= parsing_session.success_count %>건
      <% pending_dup_count = parsing_session.duplicate_confirmations.select { |dc| dc.status == "pending" }.size %>
      <% if pending_dup_count > 0 %>
        · 중복 <%= pending_dup_count %>건
      <% end %>
      <% if parsing_session.error_count.to_i > 0 %>
        · 오류 <%= parsing_session.error_count %>건
      <% end %>
    <% end %>
  </td>
  <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= time_ago_in_words(parsing_session.created_at) %> 전
  </td>
  <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
    <% if parsing_session.completed? %>
      <% if parsing_session.review_pending? %>
        <%= link_to '검토하기', review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-indigo-600 hover:text-indigo-900 font-medium' %>
      <% else %>
        <%= link_to '상세보기', review_workspace_parsing_session_path(workspace, parsing_session),
            class: 'text-gray-600 hover:text-gray-900' %>
      <% end %>
    <% elsif parsing_session.has_duplicates? && parsing_session.pending_duplicates.any? %>
      <%= link_to '중복 확인', workspace_parsing_session_path(workspace, parsing_session),
          class: 'text-indigo-600 hover:text-indigo-900' %>
    <% end %>
  </td>
</tr>
