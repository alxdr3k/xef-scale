<%= turbo_stream.update "flash", partial: "shared/flash" %>

<% if @pending_count == 0 %>
  <%# All duplicates resolved - remove the entire section %>
  <%= turbo_stream.update "duplicate-section", "" %>
<% else %>
  <%# Remove this card with fade out animation %>
  <%= turbo_stream.remove dom_id(@duplicate_confirmation) %>

  <%# Update the counter in the banner %>
  <%= turbo_stream.update "duplicate-count" do %>
    <%= @pending_count %>
  <% end %>
<% end %>
