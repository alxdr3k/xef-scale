<div class="max-h-96 overflow-y-auto">
  <% if notifications.any? %>
    <% notifications.limit(5).each do |notification| %>
      <% if notification.action_url.present? %>
        <%= link_to notification.action_url,
            class: "block px-4 py-3 hover:bg-elev #{notification.unread? ? 'bg-info-subtle' : ''}",
            data: { action: 'click->notifications#markRead', notification_id: notification.id } do %>
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <% case notification.notification_type %>
              <% when 'parsing_complete' %>
                <span class="text-xl">📄</span>
              <% else %>
                <span class="text-xl">🔔</span>
              <% end %>
            </div>
            <div class="ml-3 flex-1">
              <p class="text-sm font-medium text-primary"><%= notification.title %></p>
              <p class="text-xs text-tertiary line-clamp-2"><%= notification.message %></p>
              <p class="text-xs text-disabled mt-1"><%= time_ago_in_words(notification.created_at) %> 전</p>
            </div>
            <% if notification.unread? %>
              <div class="flex-shrink-0 ml-2">
                <span class="h-2 w-2 bg-info rounded-full inline-block"></span>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="block px-4 py-3 <%= notification.unread? ? 'bg-info-subtle' : '' %>">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <span class="text-xl">🔔</span>
            </div>
            <div class="ml-3 flex-1">
              <p class="text-sm font-medium text-primary"><%= notification.title %></p>
              <p class="text-xs text-tertiary"><%= notification.message %></p>
              <p class="text-xs text-disabled mt-1"><%= time_ago_in_words(notification.created_at) %> 전</p>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-4 py-8 text-center text-tertiary text-sm">
      알림이 없습니다.
    </div>
  <% end %>
</div>
