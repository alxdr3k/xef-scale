<%# Locals: notifications (required), pagy (optional) %>
<div id="notification-list">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-primary">알림</h1>
    <% if notifications.any?(&:unread?) %>
      <%= link_to '모두 읽음으로 표시', mark_all_read_notifications_path,
          method: :post, class: 'text-sm text-action hover:text-action',
          data: { turbo_method: :post } %>
    <% end %>
  </div>

  <% if notifications.any? %>
    <div class="bg-surface rounded-lg shadow divide-y divide-divider">
      <% notifications.each do |notification| %>
        <div class="p-4 <%= notification.unread? ? 'bg-info-subtle' : '' %> hover:bg-elev">
          <div class="flex items-start justify-between">
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0">
                <% case notification.notification_type %>
                <% when 'parsing_complete' %>
                  <span class="text-2xl">📄</span>
                <% when 'commit_complete' %>
                  <span class="text-2xl">✅</span>
                <% when 'rollback_complete' %>
                  <span class="text-2xl">↩️</span>
                <% else %>
                  <span class="text-2xl">🔔</span>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <% if notification.action_url.present? %>
                  <%= link_to notification.action_url, class: 'block' do %>
                    <p class="text-sm font-medium text-primary"><%= notification.title %></p>
                    <p class="text-sm text-tertiary mt-1"><%= notification.message %></p>
                  <% end %>
                <% else %>
                  <p class="text-sm font-medium text-primary"><%= notification.title %></p>
                  <p class="text-sm text-tertiary mt-1"><%= notification.message %></p>
                <% end %>
                <p class="text-xs text-disabled mt-2"><%= time_ago_in_words(notification.created_at) %> 전</p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              <% if notification.unread? %>
                <span class="h-2 w-2 bg-info-subtle0 rounded-full"></span>
                <%= link_to mark_read_notification_path(notification), method: :post,
                    class: 'text-xs text-tertiary hover:text-secondary',
                    data: { turbo_method: :post } do %>
                  읽음
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if local_assigns[:pagy] && pagy.pages > 1 %>
      <div class="mt-6">
        <%== pagy_nav(pagy) %>
      </div>
    <% end %>
  <% else %>
    <div class="bg-surface rounded-lg shadow p-12 text-center">
      <span class="text-4xl mb-4 block">🔔</span>
      <p class="text-tertiary">알림이 없습니다.</p>
    </div>
  <% end %>
</div>
