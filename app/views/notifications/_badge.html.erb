<%# count가 0일 때도 span을 렌더링하여 broadcast target 유지 %>
<% count = user.unread_notifications_count(workspace) %>
<% if count > 0 %>
  <span id="notification-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center">
    <%= count > 9 ? '9+' : count %>
  </span>
<% else %>
  <span id="notification-badge" class="hidden"></span>
<% end %>
