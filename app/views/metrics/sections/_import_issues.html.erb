<div class="bg-surface rounded-lg shadow p-4">
  <h2 class="text-base font-semibold text-primary mb-2"><%= t("metrics.sections.import_issues.title") %></h2>
  <% if section[:rows].empty? %>
    <p class="text-sm text-tertiary"><%= t("metrics.sections.import_issues.empty") %></p>
  <% else %>
    <table class="min-w-full divide-y divide-divider text-sm">
      <thead>
        <tr>
          <th class="px-2 py-2 text-left text-xs font-medium text-tertiary uppercase"><%= t("metrics.sections.import_issues.th_source") %></th>
          <th class="px-2 py-2 text-left text-xs font-medium text-tertiary uppercase"><%= t("metrics.sections.import_issues.th_type") %></th>
          <th class="px-2 py-2 text-left text-xs font-medium text-tertiary uppercase"><%= t("metrics.sections.import_issues.th_status") %></th>
          <th class="px-2 py-2 text-right text-xs font-medium text-tertiary uppercase"><%= t("metrics.sections.import_issues.th_count") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-divider">
        <% section[:rows].each do |row| %>
          <tr>
            <td class="px-2 py-1.5 font-mono text-meta text-secondary"><%= row[:source_type] %></td>
            <td class="px-2 py-1.5 font-mono text-meta text-secondary"><%= row[:issue_type] %></td>
            <td class="px-2 py-1.5 font-mono text-meta text-secondary"><%= row[:status] %></td>
            <td class="px-2 py-1.5 text-right tabular-nums text-primary"><%= row[:count] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
