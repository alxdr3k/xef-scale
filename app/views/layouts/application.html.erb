<!DOCTYPE html>
<html lang="ko">
  <head>
    <title><%= content_for(:title) || "지출 추적" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="지출 추적">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-cache-control" content="no-cache">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <% if user_signed_in? %>
      <%= turbo_stream_from current_user %>
      <% if current_workspace %>
        <%= turbo_stream_from current_workspace %>
      <% end %>
      <%= render 'layouts/navbar' %>
    <% end %>

    <main class="<%= user_signed_in? ? 'pt-4 px-4 pb-24' : '' %>">
      <%= yield %>
    </main>

    <!-- Toast Notifications Container -->
    <div id="flash" class="fixed top-6 right-6 z-50 space-y-3 max-w-sm w-full pointer-events-none">
      <%= render 'shared/flash' %>
    </div>
  </body>
</html>
