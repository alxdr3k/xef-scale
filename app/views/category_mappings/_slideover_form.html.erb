<turbo-frame id="slideover-content">
  <h2 class="text-lg font-semibold text-primary mb-6"><%= @mapping.persisted? ? '규칙 수정' : '새 규칙' %></h2>

  <%= form_with model: [@workspace, @mapping],
        url: @mapping.persisted? ? workspace_category_mapping_path(@workspace, @mapping) : workspace_category_mappings_path(@workspace),
        class: 'space-y-4',
        data: { turbo_frame: '_top' } do |f| %>

    <% if @mapping.errors.any? %>
      <div class="bg-danger-subtle border border-danger rounded-md p-4">
        <ul class="text-sm text-danger list-disc list-inside">
          <% @mapping.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">내역 패턴 *</label>
      <%= f.text_field :merchant_pattern,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: '예: 스타벅스, 배달의민족',
            required: true,
            autofocus: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">매칭 방식</label>
      <%= f.select :match_type,
            [["정확히 일치", "exact"], ["포함", "contains"]],
            {},
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      <p class="mt-1 text-xs text-tertiary">
        "정확히 일치": 가맹점명이 패턴과 동일할 때 매칭<br>
        "포함": 가맹점명에 패턴이 포함될 때 매칭
      </p>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">금액 조건</label>
      <%= f.number_field :amount,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: '비워두면 모든 금액에 적용',
            min: 1 %>
      <p class="mt-1 text-xs text-tertiary">특정 금액일 때만 매칭하려면 입력하세요.</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">카테고리 *</label>
      <%= f.collection_select :category_id, @categories, :id, :name,
            { prompt: "카테고리 선택" },
            { class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
              required: true } %>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t border-divider">
      <button type="button"
              data-action="click->slideover#close"
              class="px-4 py-2 text-secondary hover:text-primary">
        취소
      </button>
      <%= f.submit '저장', class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover cursor-pointer' %>
    </div>
  <% end %>
</turbo-frame>
