<turbo-frame id="slideover-content">
  <h2 class="text-lg font-semibold text-primary mb-6"><%= @mapping.persisted? ? t("category_mappings.slideover.edit_title") : t("category_mappings.slideover.new_title") %></h2>

  <%= form_with model: [@workspace, @mapping],
        url: @mapping.persisted? ? workspace_category_mapping_path(@workspace, @mapping) : workspace_category_mappings_path(@workspace),
        class: 'space-y-4',
        data: { turbo_frame: '_top' } do |f| %>

    <% if @mapping.errors.any? %>
      <div class="bg-danger-subtle border border-danger rounded-md p-4">
        <ul class="text-sm text-danger list-disc list-inside">
          <% @mapping.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1"><%= t("category_mappings.slideover.pattern_required") %></label>
      <%= f.text_field :merchant_pattern,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: t("category_mappings.slideover.pattern_placeholder"),
            required: true,
            autofocus: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1"><%= t("category_mappings.slideover.match_type") %></label>
      <%= f.select :match_type,
            [[t("category_mappings.slideover.match_type_exact"), "exact"], [t("category_mappings.slideover.match_type_contains"), "contains"]],
            {},
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      <p class="mt-1 text-xs text-tertiary">
        <%= t("category_mappings.slideover.match_type_hint_html").html_safe %>
      </p>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1"><%= t("category_mappings.slideover.amount") %></label>
      <%= f.number_field :amount,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: t("category_mappings.slideover.amount_placeholder"),
            min: 1 %>
      <p class="mt-1 text-xs text-tertiary"><%= t("category_mappings.slideover.amount_hint") %></p>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1"><%= t("category_mappings.slideover.category_required") %></label>
      <%= f.collection_select :category_id, @categories, :id, :name,
            { prompt: t("category_mappings.slideover.category_prompt") },
            { class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
              required: true } %>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t border-divider">
      <button type="button"
              data-action="click->slideover#close"
              class="px-4 py-2 text-secondary hover:text-primary">
        <%= t("category_mappings.slideover.cancel") %>
      </button>
      <%= f.submit t("category_mappings.slideover.submit"), class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover cursor-pointer' %>
    </div>
  <% end %>
</turbo-frame>
