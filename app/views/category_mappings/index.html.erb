<turbo-frame id="category-mappings-panel">
  <div class="flex justify-between items-center mb-4">
    <%# 필터 버튼 %>
    <div class="flex gap-2">
      <% current_source = params[:source] || "all" %>
      <%= link_to t("category_mappings.index.filter_all"),
            workspace_category_mappings_path(@workspace, source: "all"),
            class: "px-3 py-1.5 text-sm rounded-full #{current_source == 'all' ? 'bg-primary text-inverse' : 'bg-elev text-secondary hover:bg-divider'}",
            data: { turbo_frame: "category-mappings-panel" } %>
      <%# ADR-0011 §Decision 5: 매핑 출처 어휘 동기화. %>
      <%= link_to t("category_mappings.source.manual"),
            workspace_category_mappings_path(@workspace, source: "manual"),
            class: "px-3 py-1.5 text-sm rounded-full #{current_source == 'manual' ? 'bg-action text-action-on' : 'bg-elev text-secondary hover:bg-divider'}",
            data: { turbo_frame: "category-mappings-panel" } %>
      <%= link_to t("category_mappings.source.import"),
            workspace_category_mappings_path(@workspace, source: "import"),
            class: "px-3 py-1.5 text-sm rounded-full #{current_source == 'import' ? 'bg-positive text-action-on' : 'bg-elev text-secondary hover:bg-divider'}",
            data: { turbo_frame: "category-mappings-panel" } %>
      <%= link_to t("category_mappings.source.gemini"),
            workspace_category_mappings_path(@workspace, source: "gemini"),
            class: "px-3 py-1.5 text-sm rounded-full #{current_source == 'gemini' ? 'bg-warning text-action-on' : 'bg-elev text-secondary hover:bg-divider'}",
            data: { turbo_frame: "category-mappings-panel" } %>
    </div>

    <%# 새 규칙 버튼 %>
    <%= link_to new_workspace_category_mapping_path(@workspace),
          class: "bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover text-sm",
          data: { action: "click->slideover#open", turbo_frame: "slideover-content" } do %>
      <%= t("category_mappings.index.new_rule") %>
    <% end %>
  </div>

  <div class="bg-surface rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-divider">
      <thead class="bg-elev">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_pattern") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_match_type") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_amount") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_category") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_source") %></th>
          <th class="px-6 py-3 text-right text-xs font-medium text-tertiary uppercase"><%= t("category_mappings.index.th_action") %></th>
        </tr>
      </thead>
      <tbody id="category-mappings-list" class="bg-surface divide-y divide-divider">
        <% @mappings.each do |mapping| %>
          <%= render "mapping_row", mapping: mapping %>
        <% end %>

        <% if @mappings.empty? %>
          <tr id="no-mappings-row">
            <td colspan="6" class="px-6 py-12 text-center text-tertiary"><%= t("category_mappings.index.empty") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</turbo-frame>
