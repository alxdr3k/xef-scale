<tr id="<%= dom_id(mapping) %>">
  <td class="px-6 py-4 text-sm text-primary"><%= mapping.merchant_pattern %></td>
  <td class="px-6 py-4 text-sm text-tertiary"><%= mapping.match_type_label %></td>
  <td class="px-6 py-4 text-sm text-tertiary">
    <% if mapping.amount.present? %>
      <%= t("category_mappings.row.amount_won", amount: number_with_delimiter(mapping.amount)) %>
    <% else %>
      <span class="text-disabled"><%= t("category_mappings.row.all_amounts") %></span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-sm">
    <% if mapping.category %>
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: <%= mapping.category.color %>"></span>
        <%= mapping.category.name %>
      </span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-sm">
    <%# ADR-0011 §Decision 5: 매핑 출처 어휘를 ko.yml로 분리해 결정 메커니즘과
        단어 충돌을 피한다 ("수동" → "직접 등록", "학습" → "가져온 매핑",
        "AI" → "AI 학습 매핑"). 색상은 의미 신호 유지. %>
    <% case mapping.source %>
    <% when "manual" %>
      <%# Codex PR #217 P2: action-subtle/action 페어는 dark mode에서 #818cf8/#312e81 ≈ 3.83:1로 AA 미달.
          filled (bg-action + text-action-on)으로 contrast 확보 — 색상 신호(indigo) 유지. %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-action text-action-on"><%= t("category_mappings.source.manual") %></span>
    <% when "import" %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-positive-subtle text-positive"><%= t("category_mappings.source.import") %></span>
    <% when "gemini" %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-warning-subtle text-warning"><%= t("category_mappings.source.gemini") %></span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-right text-sm">
    <%= link_to t("category_mappings.row.edit"),
          edit_workspace_category_mapping_path(@workspace, mapping),
          class: 'text-action hover:text-action mr-3',
          data: { action: "click->slideover#open", turbo_frame: "slideover-content" } %>
    <%= link_to t("category_mappings.row.delete"),
          workspace_category_mapping_path(@workspace, mapping),
          data: { turbo_method: :delete, turbo_confirm: t("category_mappings.row.delete_confirm") },
          class: 'text-danger hover:text-danger' %>
  </td>
</tr>
