<div data-controller="slideover"
     data-action="keydown.esc->slideover#closeOnEsc">
  <!-- Backdrop -->
  <div data-slideover-target="backdrop"
       data-action="click->slideover#backdropClick"
       class="hidden fixed inset-0 bg-overlay transition-opacity z-40"></div>

  <!-- Slideover Panel -->
  <div data-slideover-target="panel"
       class="fixed inset-y-0 right-0 w-full max-w-md bg-surface shadow-xl transform translate-x-full transition-transform duration-300 ease-in-out z-50">
    <div class="h-full flex flex-col">
      <!-- Header -->
      <div class="px-6 py-4 border-b border-divider flex justify-between items-center">
        <h2 class="text-lg font-semibold text-primary" id="slideover-title">
          <% if local_assigns[:title] %>
            <%= title %>
          <% end %>
        </h2>
        <button type="button"
                data-action="click->slideover#close"
                class="text-disabled hover:text-tertiary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto p-6">
        <turbo-frame id="slideover-content" data-slideover-target="frame">
          <!-- Content will be loaded here -->
        </turbo-frame>
      </div>
    </div>
  </div>
</div>
