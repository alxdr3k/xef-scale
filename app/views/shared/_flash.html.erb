<% if notice.present? %>
  <div data-controller="toast"
       data-toast-type-value="success"
       data-toast-duration-value="4000"
       data-action="mouseenter->toast#mouseEnter mouseleave->toast#mouseLeave"
       class="pointer-events-auto bg-white rounded-xl shadow-lg ring-1 ring-black/5 overflow-hidden border-l-4 border-emerald-500 transform transition-all duration-300 ease-out"
       role="status"
       aria-live="polite"
       aria-atomic="true">
    <div class="p-4 flex items-start gap-3">
      <!-- Success Icon -->
      <div class="flex-shrink-0 w-5 h-5 text-emerald-500">
        <svg class="w-full h-full" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
      </div>
      <!-- Message -->
      <div class="flex-1 text-sm font-medium text-gray-900">
        <%= notice %>
      </div>
      <!-- Close Button -->
      <button data-action="click->toast#close"
              aria-label="알림 닫기"
              class="flex-shrink-0 inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 rounded transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <!-- Progress Bar -->
    <div class="h-1 bg-emerald-100 overflow-hidden">
      <div data-toast-target="progress"
           class="h-full bg-emerald-500 transition-all ease-linear"
           style="width: 100%;"></div>
    </div>
  </div>
<% end %>

<% if alert.present? %>
  <div data-controller="toast"
       data-toast-type-value="error"
       data-toast-duration-value="0"
       data-action="mouseenter->toast#mouseEnter mouseleave->toast#mouseLeave"
       class="pointer-events-auto bg-white rounded-xl shadow-lg ring-1 ring-black/5 overflow-hidden border-l-4 border-red-500 transform transition-all duration-300 ease-out"
       role="alert"
       aria-live="assertive"
       aria-atomic="true">
    <div class="p-4 flex items-start gap-3">
      <!-- Error Icon -->
      <div class="flex-shrink-0 w-5 h-5 text-red-500">
        <svg class="w-full h-full" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
      </div>
      <!-- Message -->
      <div class="flex-1 text-sm font-medium text-gray-900">
        <%= alert %>
      </div>
      <!-- Close Button -->
      <button data-action="click->toast#close"
              aria-label="알림 닫기"
              class="flex-shrink-0 inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 rounded transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <!-- No progress bar for errors -->
  </div>
<% end %>
