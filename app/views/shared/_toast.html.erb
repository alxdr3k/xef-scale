<% type = local_assigns.fetch(:type, "success").to_s %>
<% message = local_assigns.fetch(:message) %>
<% action_url = local_assigns[:action_url].presence %>
<% action_label = local_assigns.fetch(:action_label, "보기") %>
<%
  styles = {
    "success" => {
      border: "border-emerald-500",
      icon: "text-emerald-500",
      ring: "focus:ring-emerald-500",
      progress_wrap: "bg-emerald-100",
      progress: "bg-emerald-500",
      role: "status",
      live: "polite",
      duration: 4000,
      path: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
    },
    "warning" => {
      border: "border-amber-500",
      icon: "text-amber-500",
      ring: "focus:ring-amber-500",
      progress_wrap: "bg-amber-100",
      progress: "bg-amber-500",
      role: "alert",
      live: "assertive",
      duration: 7000,
      path: "M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l6.518 11.59c.75 1.334-.213 2.986-1.743 2.986H3.482c-1.53 0-2.493-1.652-1.743-2.986l6.518-11.59zM11 13a1 1 0 10-2 0 1 1 0 002 0zm-1-8a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
    },
    "error" => {
      border: "border-red-500",
      icon: "text-red-500",
      ring: "focus:ring-red-500",
      progress_wrap: "bg-red-100",
      progress: "bg-red-500",
      role: "alert",
      live: "assertive",
      duration: 0,
      path: "M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
    }
  }
  style = styles.fetch(type, styles["success"])
  duration = local_assigns.fetch(:duration, style[:duration])
%>

<div data-controller="toast"
     data-toast-type-value="<%= type %>"
     data-toast-duration-value="<%= duration %>"
     data-action="mouseenter->toast#mouseEnter mouseleave->toast#mouseLeave"
     class="pointer-events-auto bg-white rounded-xl shadow-lg ring-1 ring-black/5 overflow-hidden border-l-4 <%= style[:border] %> transform transition-all duration-300 ease-out"
     role="<%= style[:role] %>"
     aria-live="<%= style[:live] %>"
     aria-atomic="true">
  <div class="p-4 flex items-start gap-3">
    <div class="flex-shrink-0 w-5 h-5 <%= style[:icon] %>">
      <svg class="w-full h-full" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="<%= style[:path] %>" clip-rule="evenodd"/>
      </svg>
    </div>

    <div class="flex-1 text-sm font-medium text-gray-900">
      <%= message %>
      <% if action_url %>
        <div class="mt-2">
          <%= link_to action_label, action_url, class: "inline-flex text-sm font-semibold text-amber-700 hover:text-amber-800" %>
        </div>
      <% end %>
    </div>

    <button data-action="click->toast#close"
            aria-label="알림 닫기"
            class="flex-shrink-0 inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 <%= style[:ring] %> focus:ring-offset-2 rounded transition-colors">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </button>
  </div>

  <% if duration.to_i.positive? %>
    <div class="h-1 <%= style[:progress_wrap] %> overflow-hidden">
      <div data-toast-target="progress"
           class="h-full <%= style[:progress] %> transition-all ease-linear"
           style="width: 100%;"></div>
    </div>
  <% end %>
</div>
