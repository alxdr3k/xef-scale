<div data-controller="month-picker" class="relative inline-block">
  <!-- Current Month Display (clickable) -->
  <button type="button"
          data-action="click->month-picker#toggle"
          class="flex items-center space-x-2 px-4 py-2 font-semibold text-lg text-primary hover:bg-elev rounded-lg transition-colors cursor-pointer">
    <span data-month-picker-target="currentDisplay"><%= t("shared.month_picker.year_month", year: year, month: month) %></span>
    <svg class="w-5 h-5 text-tertiary transition-transform" data-month-picker-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <!-- Dropdown Panel -->
  <div data-month-picker-target="dropdown"
       class="hidden absolute left-0 mt-2 bg-surface rounded-lg shadow-lg border border-divider z-50 w-80">

    <!-- Year Selector -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-divider">
      <button type="button"
              data-action="click->month-picker#previousYear"
              class="p-2 hover:bg-elev rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <span data-month-picker-target="yearDisplay" class="font-semibold text-primary"><%= t("shared.month_picker.year_label", year: year) %></span>

      <button type="button"
              data-action="click->month-picker#nextYear"
              class="p-2 hover:bg-elev rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <!-- Month Grid (4x3) -->
    <div class="grid grid-cols-4 gap-2 p-4">
      <% (1..12).each do |m| %>
        <button type="button"
                data-action="click->month-picker#selectMonth"
                data-month="<%= m %>"
                class="px-3 py-2 text-sm font-medium rounded-lg transition-colors cursor-pointer
                       <%= m == month ? 'bg-action text-action-on' : 'text-secondary hover:bg-elev' %>">
          <%= t("shared.month_picker.month_label", month: m) %>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Hidden form fields to store current state -->
  <input type="hidden" data-month-picker-target="currentYear" value="<%= year %>">
  <input type="hidden" data-month-picker-target="currentMonth" value="<%= month %>">
  <input type="hidden" data-month-picker-target="basePath" value="<%= base_path %>">
</div>
