<%#
  InputSheet — 3-way 입력 시트 (ADR-0004, preflight §3.1 Phase 3.3).

  검토함의 "+ 새로 가져오기" 액션 / parsing_sessions/index의 "+ 새로 가져오기"
  버튼이 모두 이 시트를 연다. 입력 폼 자체는 `parsing_sessions/index`에서 이동
  완료 — 페이지에는 *입력 기록*만 남는다 (ui-redesign-plan §3.3).

  데스크탑: 화면 중앙 modal.
  모바일: 화면 하단에서 슬라이드업하는 bottom sheet.
  Stimulus controller `input-sheet`로 토글 (Esc · 백드롭 클릭 · close 버튼).

  Locals:
    workspace (required) — 폼 action 결정용.
%>
<% workspace = local_assigns.fetch(:workspace) %>

<div data-controller="input-sheet"
     data-action="keydown@window->input-sheet#handleKeydown"
     class="contents">
  <%# Trigger 버튼 — 호출자가 외부에 두려면 본 partial 안 trigger를 무시하고
      별도 element에 data-action="click->input-sheet#open"을 연결해도 된다. %>
  <button type="button"
          data-input-sheet-target="trigger"
          data-action="click->input-sheet#open"
          class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-md bg-action text-action-on hover:bg-action-hover">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    새로 가져오기
  </button>

  <%# Backdrop + sheet container.
      z-50: 모바일 하단 nav(z-40) 위에 떠야 nav 탭이 backdrop 위로 노출되어
      실수로 navigation되는 일을 막는다. sheet는 같은 z-50이지만 DOM 순서상
      뒤에 있어 backdrop 위에 자연스럽게 쌓인다. %>
  <div data-input-sheet-target="backdrop"
       data-action="click->input-sheet#close"
       class="hidden fixed inset-0 bg-black/40 z-50"></div>

  <div data-input-sheet-target="sheet"
       role="dialog"
       aria-modal="true"
       aria-labelledby="input-sheet-title"
       class="hidden fixed z-50
              inset-x-0 bottom-0 rounded-t-2xl
              sm:inset-auto sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2
              sm:rounded-2xl sm:w-full sm:max-w-2xl
              bg-surface shadow-xl max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-surface border-b border-divider px-5 py-4 flex items-center justify-between">
      <h2 id="input-sheet-title" class="text-base font-semibold text-primary">새로 가져오기</h2>
      <button type="button"
              data-action="click->input-sheet#close"
              aria-label="닫기"
              class="p-1.5 text-tertiary hover:text-primary hover:bg-elev rounded-md">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="p-5 space-y-4">
      <% if workspace.ai_consent_required? %>
        <%= render 'shared/inline_alert',
            tone: :warning,
            title: '외부 AI 사용 안내',
            body: '붙여넣는 SMS 본문과 업로드한 명세서 이미지는 외부 AI(Google Gemini)로 전송되어 거래로 변환됩니다.' do %>
          <%= link_to '워크스페이스 설정에서 동의 또는 비활성화', settings_workspace_path(workspace),
              class: 'underline font-medium text-warning' %>
        <% end %>
      <% end %>

      <%# 1) 문자 붙여넣기 %>
      <section class="border border-divider rounded-lg p-4">
        <%= form_with url: text_parse_workspace_parsing_sessions_path(workspace), method: :post, local: true, class: 'space-y-3' do %>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-action" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 0 1 1.037-.443 48.282 48.282 0 0 0 5.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
            <h3 class="text-sm font-medium text-primary">문자 붙여넣기</h3>
          </div>
          <textarea name="text" id="text" rows="4"
                    class="block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action text-sm"
                    placeholder="[Web발신]&#10;신한체크 승인 홍*동&#10;50,000원 일시불&#10;03/15 14:30 스타벅스강남점"></textarea>
          <p class="text-meta text-secondary">
            카드 승인 문자·은행 출금 알림 등을 붙여넣으세요. 여러 건을 한 번에 붙여넣어도 됩니다.
          </p>
          <div class="flex justify-end">
            <%= submit_tag '문자로 추가',
                class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer text-sm font-medium' %>
          </div>
        <% end %>
      </section>

      <%# 2) 스크린샷 업로드 %>
      <section class="border border-divider rounded-lg p-4">
        <%= form_with url: workspace_parsing_sessions_path(workspace), method: :post, multipart: true, local: true, class: 'space-y-3' do |f| %>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-action" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
            </svg>
            <h3 class="text-sm font-medium text-primary">스크린샷 업로드</h3>
          </div>
          <input type="hidden" name="institution_identifier" value="shinhan_card">
          <%= f.file_field :files, multiple: true, accept: "image/jpeg,image/png,image/webp,image/heic",
                class: 'block w-full text-sm text-secondary file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-medium file:bg-action-subtle file:text-action hover:file:bg-elev' %>
          <p class="text-meta text-secondary">
            신한카드 이용대금 명세서 스크린샷(JPG·PNG·WEBP·HEIC)을 올리면 AI가 거래를 인식합니다.
            확정 전까지 거래에 반영되지 않습니다.
          </p>
          <div class="flex justify-end">
            <%= submit_tag '스크린샷으로 추가',
                class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer text-sm font-medium' %>
          </div>
        <% end %>
      </section>

      <%# 3) 직접 입력 — 시트 안 폼이 아니라 별도 페이지로 이동 (즉시 committed) %>
      <section class="border border-divider rounded-lg p-4">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-action" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 18.549 2.8a2.121 2.121 0 1 1 3 3L19.862 7.487M16.862 4.487 9.392 11.957a4.5 4.5 0 0 0-1.13 1.897l-.821 2.747 2.747-.821a4.5 4.5 0 0 0 1.897-1.13l7.47-7.47M16.862 4.487 19.862 7.487" />
            </svg>
            <div>
              <h3 class="text-sm font-medium text-primary">직접 입력</h3>
              <p class="text-meta text-secondary mt-0.5">금액·날짜·가맹점을 직접 기록합니다. 즉시 거래에 반영됩니다.</p>
            </div>
          </div>
          <%= link_to '직접 입력',
              new_workspace_transaction_path(workspace),
              class: 'shrink-0 px-3 py-1.5 text-sm font-medium rounded-md bg-elev text-primary hover:bg-page' %>
        </div>
      </section>
    </div>
  </div>
</div>
