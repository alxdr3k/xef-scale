<%#
  RecurringPaymentCard — 반복 결제 Top N 요약 (ui-redesign-plan §3.1, Phase 4).
  RecurringPaymentDetector 결과를 dashboards/monthly에 카드로 노출.

  Locals:
    patterns         (Array<Hash>, required) — detector.detect 결과의 일부 (이미 limit)
    total_count      (Integer, required) — 감지된 전체 패턴 수 (more 안내용)
    monthly_estimate (Integer, required) — 평균 금액 합계 (월 예상)
    manage_path      (String, required) — "관리 →" CTA 링크 (= recurring_dashboard_path)

  patterns가 빈 배열이면 카드 자체 미렌더.
%>
<% patterns         = local_assigns.fetch(:patterns) %>
<% total_count      = local_assigns.fetch(:total_count).to_i %>
<% monthly_estimate = local_assigns.fetch(:monthly_estimate).to_i %>
<% manage_path      = local_assigns.fetch(:manage_path) %>

<% if patterns.any? %>
  <section class="bg-surface rounded-lg shadow-card p-5" aria-label="<%= t("shared.recurring_card.aria") %>">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold text-primary"><%= t("shared.recurring_card.title") %></h2>
      <%= link_to t("shared.recurring_card.manage"), manage_path,
            class: 'text-meta font-medium text-action hover:text-action-hover' %>
    </div>
    <p class="text-meta text-secondary mb-3">
      <%= t("shared.recurring_card.monthly_sum") %> <span class="text-primary font-medium tabular-nums">₩<%= number_with_delimiter(monthly_estimate) %></span>
      <%= t("shared.recurring_card.total_count", count: total_count) %>
    </p>

    <ul class="divide-y divide-divider">
      <% patterns.each do |pattern| %>
        <li class="py-2 flex items-center justify-between gap-3">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-primary truncate"><%= pattern[:merchant] %></p>
            <p class="text-meta text-secondary mt-0.5">
              <%= t("shared.recurring_card.occurrence", count: pattern[:occurrence_count]) %>
              <%= t("shared.recurring_card.last_date_label", date: pattern[:last_date].strftime("%Y.%m.%d")) %>
            </p>
          </div>
          <div class="shrink-0 text-right">
            <p class="text-sm font-semibold text-primary tabular-nums">
              <%= t("shared.recurring_card.per_month", amount: "₩#{number_with_delimiter(pattern[:average_amount])}") %>
            </p>
            <% if pattern[:consistent_amount] %>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-meta font-medium bg-positive-subtle text-positive"><%= t("shared.recurring_card.fixed") %></span>
            <% else %>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-meta font-medium bg-warning-subtle text-warning"><%= t("shared.recurring_card.variable") %></span>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>

    <% if total_count > patterns.size %>
      <p class="text-meta text-tertiary text-center mt-3">
        <%= t("shared.recurring_card.pagination", shown: patterns.size, total: total_count) %>
      </p>
    <% end %>
  </section>
<% end %>
