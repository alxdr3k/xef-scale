<div id="note-panel"
     data-note-panel-target="panel"
     class="hidden fixed w-80 bg-surface rounded-xl shadow-2xl border border-divider/60 z-40
            transition-all duration-200">
  <div class="p-5">
    <!-- Header -->
    <div class="flex items-start justify-between mb-4">
      <div class="flex-1 min-w-0">
        <h3 class="text-sm font-semibold text-primary mb-1"><%= t("shared.note_panel.title") %></h3>
        <p class="text-xs text-tertiary truncate" data-note-panel-target="context"></p>
      </div>
      <button data-action="click->note-panel#close"
              class="p-1.5 -mr-1.5 text-disabled hover:text-secondary rounded-md hover:bg-elev transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Textarea -->
    <textarea data-note-panel-target="input"
              data-action="keydown->note-panel#handleKeydown"
              rows="6"
              class="w-full text-sm text-primary placeholder:text-disabled
                     border border-divider rounded-lg resize-none
                     focus:ring-2 focus:ring-action focus:border-transparent
                     leading-relaxed px-3 py-2.5"
              placeholder="<%= t("shared.note_panel.placeholder") %>"></textarea>

    <!-- Footer -->
    <div class="flex items-center justify-between pt-3 mt-3 border-t border-divider">
      <div class="text-[11px] text-disabled">
        <kbd class="px-1 py-0.5 bg-elev rounded border border-divider text-[10px]">ESC</kbd> <%= t("shared.note_panel.esc_close") %>
        <span class="mx-1">·</span>
        <kbd class="px-1 py-0.5 bg-elev rounded border border-divider text-[10px]">⌘↵</kbd> <%= t("shared.note_panel.save_shortcut") %>
      </div>
      <div class="flex gap-2">
        <button data-action="click->note-panel#close"
                class="px-3 py-1.5 text-xs text-secondary hover:bg-elev rounded-md transition-colors">
          <%= t("shared.note_panel.cancel") %>
        </button>
        <button data-action="click->note-panel#save"
                data-note-panel-target="saveButton"
                class="px-3 py-1.5 text-xs font-medium text-action-on bg-action hover:bg-action-hover rounded-md transition-colors">
          <%= t("shared.note_panel.save") %>
        </button>
      </div>
    </div>
  </div>
</div>
