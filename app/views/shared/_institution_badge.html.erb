<%# Locals: institution (required), highlighted (default: false) %>
<% highlighted = local_assigns.fetch(:highlighted, false) %>
<% if institution %>
  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= highlighted ? 'bg-warning-subtle text-warning' : 'bg-elev text-secondary' %>">
    <%= institution.name %>
  </span>
<% end %>
