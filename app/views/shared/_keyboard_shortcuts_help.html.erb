<%#
  KeyboardShortcutsHelp — 검토함 단축키 도움말 overlay (Phase 5 slice 5, ADR-0008).
  review_keyboard_controller가 ? / Shift+/ 키로 toggle.

  Locals:
    workspace (Workspace, required) — title용

  초기 상태 hidden. Esc / 백드롭 클릭 / X 버튼으로 닫기.
%>
<% workspace = local_assigns.fetch(:workspace) %>

<div data-review-keyboard-target="helpBackdrop"
     data-action="click->review-keyboard#hideHelp"
     class="hidden fixed inset-0 bg-overlay z-50"
     aria-hidden="true"></div>

<div data-review-keyboard-target="helpDialog"
     role="dialog"
     aria-modal="true"
     aria-labelledby="keyboard-help-title"
     class="hidden fixed z-50 inset-x-4 top-1/2 -translate-y-1/2 mx-auto max-w-sm
            sm:inset-auto sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2
            bg-surface rounded-lg shadow-xl p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 id="keyboard-help-title" class="text-base font-semibold text-primary"><%= t("shared.keyboard_help.title") %></h2>
    <button type="button"
            data-action="click->review-keyboard#hideHelp"
            aria-label="<%= t("shared.keyboard_help.close") %>"
            class="p-1.5 text-tertiary hover:text-primary hover:bg-elev rounded-md">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <dl class="space-y-2 text-sm">
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">j</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.j") %></dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">k</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.k") %></dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">c</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.c") %></dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">d</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.d") %></dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">Enter</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.space") %></dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt><kbd class="inline-flex items-center px-2 py-1 rounded border border-divider bg-elev text-meta font-mono">?</kbd></dt>
      <dd class="text-secondary"><%= t("shared.keyboard_help.qmark") %></dd>
    </div>
  </dl>

  <p class="mt-4 text-meta text-tertiary">
    <%= t("shared.keyboard_help.note") %>
  </p>
</div>
