<%# Locals: transaction (required), editable (default: false), update_url (required if editable) %>
<% editable = local_assigns.fetch(:editable, false) %>
<% update_url = local_assigns.fetch(:update_url, nil) %>

<td class="px-4 py-2 h-14">
  <% if editable && update_url %>
    <div class="whitespace-nowrap overflow-hidden text-ellipsis">
      <div data-controller="inline-edit"
           data-inline-edit-url-value="<%= update_url %>"
           data-inline-edit-field-value="merchant"
           data-inline-edit-original-value="<%= transaction.merchant %>"
           class="inline">
        <span data-inline-edit-target="display"
              data-controller="truncate-tooltip"
              data-action="click->inline-edit#edit:stop mouseenter->truncate-tooltip#show mouseleave->truncate-tooltip#hide"
              class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded text-sm font-medium text-gray-900 align-middle">
          <%= transaction.merchant %>
        </span>
        <span data-inline-edit-target="editor" class="hidden">
          <input data-inline-edit-target="input" type="text" value="<%= transaction.merchant %>"
                 data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
                 class="text-sm border-gray-300 rounded px-1 py-0.5 focus:ring-1 focus:ring-indigo-500">
        </span>
      </div>
      <% if transaction.notes.present? %>
        <span data-action="click->note-panel#open:stop"
              data-note-panel-url-param="<%= update_url %>"
              data-note-panel-original-param="<%= transaction.notes || '' %>"
              data-note-panel-merchant-param="<%= transaction.merchant %>"
              data-note-panel-date-param="<%= transaction.formatted_date %>"
              data-note-panel-amount-param="<%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>"
              data-note-panel-row-id-param="<%= dom_id(transaction) %>"
              data-note-panel-trigger
              class="cursor-pointer hover:bg-amber-100 ml-1.5">
          <%= render 'shared/notes_badge', notes: transaction.notes %>
        </span>
      <% else %>
        <span data-action="click->note-panel#open:stop"
              data-note-panel-url-param="<%= update_url %>"
              data-note-panel-original-param=""
              data-note-panel-merchant-param="<%= transaction.merchant %>"
              data-note-panel-date-param="<%= transaction.formatted_date %>"
              data-note-panel-amount-param="<%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>"
              data-note-panel-row-id-param="<%= dom_id(transaction) %>"
              data-note-panel-trigger
              class="cursor-pointer text-gray-400 hover:text-blue-500 opacity-0 group-hover/row:opacity-100 transition-opacity ml-1.5 align-middle inline-block"
              title="메모 추가">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
          </svg>
        </span>
      <% end %>
    </div>
  <% else %>
    <div class="whitespace-nowrap overflow-hidden text-ellipsis">
      <span data-controller="truncate-tooltip"
           data-action="mouseenter->truncate-tooltip#show mouseleave->truncate-tooltip#hide"
           class="text-sm font-medium text-gray-900 align-middle"><%= transaction.merchant %></span>
      <% if transaction.notes.present? %>
        <span class="ml-1.5"><%= render 'shared/notes_badge', notes: transaction.notes %></span>
      <% end %>
    </div>
  <% end %>
</td>
