<%# Locals: transaction (required), editable (default: false), update_url (optional), institutions (optional) %>
<% editable = local_assigns.fetch(:editable, false) %>
<% update_url = local_assigns.fetch(:update_url, nil) %>
<% institutions = local_assigns.fetch(:institutions, nil) %>

<td class="px-4 py-2 h-14 whitespace-nowrap text-sm text-tertiary">
  <% if editable && institutions.present? && update_url && transaction.source_editable? %>
    <%= form_with model: transaction,
        url: update_url,
        method: :patch, data: { controller: 'auto-submit' } do |f| %>
      <%= f.collection_select :financial_institution_id, institutions, :id, :name,
          { include_blank: t("shared.cells.institution.unknown") },
          class: 'text-sm rounded border-divider',
          data: { action: 'change->auto-submit#submit' } %>
    <% end %>
  <% else %>
    <% ps = transaction.parsing_session %>
    <% has_source = ps.present? %>
    <% if has_source %>
      <div data-controller="source-popover" class="relative inline-block">
        <span data-action="click->source-popover#toggle:stop"
              class="cursor-pointer hover:text-secondary hover:underline decoration-dotted underline-offset-2 inline-block truncate max-w-full align-middle">
          <%= transaction.financial_institution&.name || '-' %>
        </span>
        <div data-source-popover-target="popover"
             class="hidden fixed z-50 bg-surface border border-divider rounded-lg shadow-lg p-3 w-56">
          <div class="text-xs text-disabled mb-1"><%= t("shared.cells.institution.original_file") %></div>
          <a href="<%= review_workspace_parsing_session_path(transaction.workspace, ps) %>"
             class="text-sm font-medium text-action hover:text-action hover:underline truncate block"
             data-action="click->source-popover#navigate:stop">
            <%= ps.processed_file&.original_filename || ps.processed_file&.filename || (ps.text_paste? ? t("shared.cells.institution.text_paste_fallback") : t("shared.cells.institution.file_fallback")) %>
          </a>
          <div class="text-xs text-disabled mt-1.5">
            <%= t("shared.cells.institution.uploaded", relative: time_ago_in_words(ps.created_at)) %>
          </div>
          <% if ps.review_committed? %>
            <div class="text-xs text-positive mt-0.5"><%= t("shared.cells.institution.committed") %></div>
          <% end %>
        </div>
      </div>
    <% else %>
      <span class="inline-block truncate max-w-full align-middle">
        <%= transaction.financial_institution&.name || '-' %>
      </span>
    <% end %>
  <% end %>
</td>
