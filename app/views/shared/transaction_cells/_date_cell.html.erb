<%# Locals: transaction (required), editable (default: false), update_url (required if editable) %>
<% editable = local_assigns.fetch(:editable, false) %>
<% update_url = local_assigns.fetch(:update_url, nil) %>
<% needs_date_update = transaction.pending_review? && transaction.installment? && transaction.installment_month && transaction.installment_month > 1 %>

<td class="px-4 py-2 h-14 whitespace-nowrap text-sm text-gray-900">
  <div class="flex items-center gap-1">
    <% if needs_date_update %>
      <span class="relative group cursor-default">
        <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-amber-100 text-amber-600 text-[10px] font-bold">!</span>
        <span class="absolute bottom-full left-0 mb-1 px-2 py-1 text-[11px] rounded bg-gray-800 text-white whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity z-10">날짜를 실제 결제일로 수정해주세요</span>
      </span>
    <% end %>
    <% if editable && update_url %>
      <div data-controller="inline-edit"
           data-inline-edit-url-value="<%= update_url %>"
           data-inline-edit-field-value="date"
           data-inline-edit-original-value="<%= transaction.date.to_s %>">
        <span data-inline-edit-target="display"
              data-action="click->inline-edit#edit:stop"
              class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded <%= 'text-amber-600' if needs_date_update %>">
          <%= transaction.formatted_date %>
        </span>
        <div data-inline-edit-target="editor" class="hidden">
          <input data-inline-edit-target="input" type="date" value="<%= transaction.date.to_s %>"
                 data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
                 class="text-sm border-gray-300 rounded px-1 py-0.5 focus:ring-1 focus:ring-indigo-500 w-[6.5rem]">
        </div>
      </div>
    <% else %>
      <%= transaction.formatted_date %>
    <% end %>
  </div>
</td>
