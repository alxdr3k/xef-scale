<%# Locals: transaction (required), editable (default: false), update_url (required if editable) %>
<% editable = local_assigns.fetch(:editable, false) %>
<% update_url = local_assigns.fetch(:update_url, nil) %>

<td class="px-4 py-2 h-14 whitespace-nowrap text-right">
  <% if editable && update_url %>
    <div class="flex items-center justify-end gap-2">
      <% if transaction.amount.to_i < 0 %>
        <span class="px-1 py-0.5 text-[10px] leading-none rounded bg-danger-subtle text-danger"><%= t("shared.cells.amount.cancel_badge") %></span>
      <% elsif transaction.benefit_type == "할인" && transaction.benefit_amount.to_i > 0 # i18n-allow: model enum 값 비교 %>
        <span class="relative group px-1 py-0.5 text-[10px] leading-none rounded bg-positive-subtle text-positive cursor-default"><%= t("shared.cells.amount.discount_badge") %>
          <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-[11px] rounded bg-primary text-inverse whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity z-10"><%= t("shared.cells.amount.discount_tooltip", original: number_to_currency(transaction.amount + transaction.benefit_amount, unit: '₩', precision: 0), benefit: number_to_currency(transaction.benefit_amount, unit: '₩', precision: 0)) %></span>
        </span>
      <% end %>

      <!-- Payment Type Selector with Installment Popover -->
      <%= form_with model: transaction,
          url: update_url,
          method: :patch,
          data: {
            controller: 'installment-popover',
            installment_popover_url_value: update_url,
            installment_popover_payment_type_value: transaction.payment_type,
            installment_popover_installment_month_value: transaction.installment_month || 1,
            installment_popover_installment_total_value: transaction.installment_total || 2,
            turbo_preserve_scroll: true
          }, class: 'inline-flex relative' do |f| %>
        <% installment_label = transaction.installment? ? t("shared.cells.amount.installment_label", current: transaction.installment_month, total: transaction.installment_total) : t("shared.cells.amount.installment") %>
        <% lump_sum_classes = transaction.lump_sum? ? 'opacity-0 group-hover/row:opacity-100' : '' %>
        <%= f.select :payment_type,
            [[t("shared.cells.amount.lump_sum"), 'lump_sum'], [installment_label, 'installment'], [t("shared.cells.amount.coupon"), 'coupon']],
            {},
            class: "text-[11px] rounded border-0 bg-transparent py-0 pl-0 pr-4 cursor-pointer transition-all focus:ring-1 focus:ring-action focus:opacity-100 font-medium #{transaction.installment? ? 'text-category-7' : transaction.coupon? ? 'text-warning' : 'text-disabled hover:text-secondary'} #{lump_sum_classes}",
            data: { action: 'change->installment-popover#handleChange', installment_popover_target: 'select' } %>

        <!-- Installment Popover (hidden by default) -->
        <div data-installment-popover-target="popover"
             class="hidden absolute top-full left-0 mt-1 z-20 bg-surface border border-divider rounded-lg shadow-lg p-2 flex items-center gap-1.5">
          <input data-installment-popover-target="monthInput" type="number" min="1" max="99"
                 value="<%= transaction.installment_month || 1 %>"
                 data-action="keydown->installment-popover#handleKeydown"
                 class="w-10 text-center text-xs border-divider rounded px-1 py-0.5 focus:ring-1 focus:ring-action">
          <span class="text-xs text-tertiary">/</span>
          <input data-installment-popover-target="totalInput" type="number" min="2" max="99"
                 value="<%= transaction.installment_total || 2 %>"
                 data-action="keydown->installment-popover#handleKeydown"
                 class="w-10 text-center text-xs border-divider rounded px-1 py-0.5 focus:ring-1 focus:ring-action">
          <span class="text-xs text-tertiary"><%= t("shared.cells.amount.session_label") %></span>
          <button type="button" data-action="click->installment-popover#cancel"
                  class="text-[10px] text-disabled hover:text-secondary px-1"><%= t("shared.cells.amount.cancel") %></button>
          <button type="button" data-action="click->installment-popover#confirm"
                  class="text-[10px] text-action-on bg-action hover:bg-action-hover rounded px-1.5 py-0.5"><%= t("shared.cells.amount.confirm") %></button>
        </div>
      <% end %>

      <!-- Amount Editor -->
      <div data-controller="inline-edit"
           data-inline-edit-url-value="<%= update_url %>"
           data-inline-edit-field-value="amount"
           data-inline-edit-original-value="<%= transaction.amount %>">
        <span data-inline-edit-target="display"
              data-action="click->inline-edit#edit:stop"
              class="relative group cursor-pointer hover:bg-elev px-1 -mx-1 rounded text-sm text-primary font-medium tabular-nums inline-block w-28 text-right">
          <span class="<%= 'border-b border-dashed border-divider' if transaction.coupon? %>"><%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %></span>
          <% if transaction.coupon? %>
            <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-[11px] rounded bg-primary text-inverse whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity z-10"><%= t("shared.cells.amount.coupon_tooltip") %></span>
          <% end %>
        </span>
        <div data-inline-edit-target="editor" class="hidden">
          <input data-inline-edit-target="input" type="number" min="1" value="<%= transaction.amount %>"
                 data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
                 class="text-sm border-divider rounded px-1 py-0.5 w-24 focus:ring-1 focus:ring-action">
        </div>
      </div>
    </div>
  <% else %>
    <%# Read-only: badges for installment/coupon, plain amount %>
    <div class="flex items-center justify-end gap-2">
      <% if transaction.installment? %>
        <span class="text-[11px] font-medium text-category-7">
          <%= transaction.installment_badge %>
        </span>
      <% end %>
      <% if transaction.coupon? %>
        <span class="text-[11px] font-medium text-warning">
          <%= t("shared.cells.amount.coupon") %>
        </span>
        <span class="relative group text-sm text-primary font-medium tabular-nums inline-block w-28 text-right cursor-help">
          <span class="border-b border-dashed border-divider"><%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %></span>
          <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-[11px] rounded bg-primary text-inverse whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity z-10"><%= t("shared.cells.amount.coupon_tooltip") %></span>
        </span>
      <% else %>
        <span class="text-sm text-primary font-medium tabular-nums inline-block w-28 text-right">
          <%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>
        </span>
      <% end %>
    </div>
  <% end %>
</td>
