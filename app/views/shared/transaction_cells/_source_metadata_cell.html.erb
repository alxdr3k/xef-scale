<%# Locals: transaction (required) %>
<%# Displays import source hints (가져온 출처) in a collapsible detail.
    This information is NOT used for categorisation or budget calculations. %>
<% meta = transaction.source_metadata.presence %>
<% ps   = transaction.parsing_session %>
<% channel = meta&.[]("source_channel") %>
<% app_raw = meta&.[]("source_app_raw").to_s.strip.presence %>
<% institution_raw = meta&.[]("source_institution_raw").to_s.strip.presence %>
<% sender_raw = meta&.[]("source_sender_raw").to_s.strip.presence %>
<% masked_sender = sender_raw&.gsub(/\d(?=\d{4})/, "*") %>

<td class="px-2 py-2 h-14 whitespace-nowrap text-center text-sm text-disabled">
  <% if meta.present? || ps.present? %>
    <div data-controller="source-popover" class="inline-block">
      <% source_icon_html = render('shared/source_icon', source_type: transaction.source_type) %>
      <button type="button"
              data-action="click->source-popover#toggle:stop"
              aria-label="<%= t("shared.cells.source_metadata.aria") %>"
              title="<%= t("shared.cells.source_metadata.aria") %>"
              class="inline-flex items-center justify-center rounded-md p-1.5 text-disabled transition hover:bg-elev hover:text-secondary">
        <% if source_icon_html.to_s.strip.present? %>
          <%= source_icon_html %>
        <% else %>
          <%# Fallback: source_type이 nil 또는 _source_icon이 매핑하지 않는 값(legacy
              `file_upload` 등)일 때 popover trigger가 빈 버튼으로 보이지 않도록
              circle-info SVG로 폴백. _source_icon이 지원 글리프를 늘리면 자동으로
              그쪽이 우선 렌더되므로 이 fallback은 점점 좁아진다. %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
          </svg>
        <% end %>
      </button>

      <div data-source-popover-target="popover"
           data-action="click->source-popover#blockClick"
           class="hidden fixed z-50 bg-surface border border-divider rounded-lg shadow-lg p-3 w-60 text-left text-xs text-secondary space-y-1.5">
        <div class="font-semibold text-secondary mb-1"><%= t("shared.cells.source_metadata.heading") %></div>

        <% if channel.present? %>
          <div>
            <span class="text-disabled"><%= t("shared.cells.source_metadata.input_method") %></span>
            <%= case channel
                when "pasted_text" then t("shared.cells.source_metadata.pasted_text")
                when "screenshot" then t("shared.cells.source_metadata.screenshot")
                when "manual" then t("shared.cells.source_metadata.manual")
                when "api" then "API"
                else channel
                end %>
          </div>
        <% end %>

        <% if app_raw.present? %>
          <div>
            <span class="text-disabled"><%= t("shared.cells.source_metadata.estimated_source") %></span>
            <%= app_raw %>
          </div>
        <% end %>

        <% if institution_raw.present? %>
          <div>
            <span class="text-disabled"><%= t("shared.cells.source_metadata.original_institution") %></span>
            <%= institution_raw %>
          </div>
        <% end %>

        <% if masked_sender.present? %>
          <div>
            <span class="text-disabled"><%= t("shared.cells.source_metadata.sender") %></span>
            <%= masked_sender %>
          </div>
        <% end %>

        <% if ps.present? %>
          <div>
            <span class="text-disabled"><%= t("shared.cells.source_metadata.session") %></span>
            <%= link_to "##{ps.id} #{ps.text_paste? ? t("shared.cells.source_metadata.session_label_text") : (ps.processed_file&.original_filename || t("shared.cells.source_metadata.session_label_file_fallback"))}",
                review_workspace_parsing_session_path(transaction.workspace, ps),
                class: "text-action hover:underline",
                data: { action: "click->source-popover#navigate:stop" } %>
          </div>
          <% if ps.committed_at.present? %>
            <div class="text-disabled"><%= t("shared.cells.source_metadata.committed_at", date: ps.committed_at.strftime('%Y-%m-%d')) %></div>
          <% end %>
        <% end %>

        <div class="pt-1 text-disabled border-t border-divider text-[10px] leading-tight">
          <%= t("shared.cells.source_metadata.privacy_note") %>
        </div>
      </div>
    </div>
  <% end %>
</td>
