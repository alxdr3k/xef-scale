<%#
  Locals:
    transaction (required)
    editable (default: false)
    categories (optional, falls back to @categories)
    workspace (optional, falls back to @workspace)
    show_management_links (default: false)
    update_url (required when editable) — endpoint for category PATCH
    request_style (default: "id")
      "id"    → workspace#quick_update_category contract { category_id: ... }
      "field" → reviews#update_transaction contract { field: "category_id", value: ... }
    parsing_session_id (optional) — preserved on slideover "+ 새 카테고리 만들기" so
      the create response can re-render the row with session-scoped URLs.
%>
<% editable = local_assigns.fetch(:editable, false) %>
<% categories = local_assigns.fetch(:categories, nil) || @categories %>
<% workspace = local_assigns.fetch(:workspace, nil) || @workspace %>
<% show_management_links = local_assigns.fetch(:show_management_links, false) %>
<% update_url = local_assigns.fetch(:update_url, nil) %>
<% request_style = local_assigns.fetch(:request_style, "id") %>
<% parsing_session_id = local_assigns.fetch(:parsing_session_id, nil) %>

<td class="px-4 py-2 h-14 whitespace-nowrap">
  <% if editable && categories && update_url %>
    <div data-controller="category-selector"
         data-category-selector-transaction-id-value="<%= transaction.id %>"
         data-category-selector-workspace-id-value="<%= workspace.id %>"
         data-category-selector-current-category-id-value="<%= transaction.category_id %>"
         data-category-selector-update-url-value="<%= update_url %>"
         data-category-selector-request-style-value="<%= request_style %>"
         <% if parsing_session_id.present? %>data-category-selector-parsing-session-id-value="<%= parsing_session_id %>"<% end %>
         class="relative">
      <button type="button"
              data-action="click->category-selector#toggle"
              data-category-selector-target="badge"
              class="cursor-pointer hover:ring-2 hover:ring-focus rounded-full transition-all inline-flex items-center gap-1">
        <%= render 'shared/category_source_chip', category: transaction.category, decision: transaction.classification_decision %>
        <svg class="w-3 h-3 shrink-0 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>

      <!-- Dropdown -->
      <div data-category-selector-target="dropdown"
           class="hidden absolute z-50 mt-1 w-48 bg-surface rounded-lg shadow-lg border border-divider py-1 left-0">
        <div class="max-h-60 overflow-y-auto" data-category-selector-target="list">
          <% categories.each do |cat| %>
            <button type="button"
                    data-action="click->category-selector#selectCategory"
                    data-category-id="<%= cat.id %>"
                    class="w-full text-left px-3 py-2 h-14 text-sm hover:bg-elev flex items-center justify-between <%= transaction.category_id == cat.id ? 'bg-action-subtle' : '' %>">
              <span class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background-color: <%= cat.color %>"></span>
                <%= cat.name %>
              </span>
              <% if transaction.category_id == cat.id %>
                <svg class="w-4 h-4 text-action" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              <% end %>
            </button>
          <% end %>

          <% if transaction.category_id.present? %>
            <hr class="my-1">
            <button type="button"
                    data-action="click->category-selector#selectCategory"
                    data-category-id=""
                    class="w-full text-left px-3 py-2 h-14 text-sm text-secondary hover:bg-elev">
              미분류로 설정
            </button>
          <% end %>
        </div>

        <% if show_management_links %>
          <hr class="my-1">
          <button type="button"
                  data-action="click->category-selector#openSlideover"
                  class="w-full text-left px-3 py-2 h-14 text-sm text-action hover:bg-action-subtle">
            + 새 카테고리 만들기
          </button>
          <a href="<%= workspace_categories_path(workspace) %>"
             class="block px-3 py-2 h-14 text-sm text-action hover:bg-action-subtle">
            카테고리 관리
          </a>
        <% end %>
      </div>
    </div>
  <% else %>
    <%# Read-only — category_source_chip이 nil 카테고리도 "미분류" 칩으로 처리 %>
    <%= render 'shared/category_source_chip', category: transaction.category, decision: transaction.classification_decision %>
  <% end %>
</td>
