<%# Locals: notes (required), max_width (optional) %>
<% max_width = local_assigns.fetch(:max_width, '8rem') %>
<% if notes.present? %>
  <span class="bg-warning-subtle text-warning text-xs px-1.5 py-0.5 rounded inline-block truncate align-middle" style="max-width: <%= max_width %>">
    <%= notes %>
  </span>
<% end %>
