<% start_year = year - 6 %>
<% end_year = year + 5 %>

<div data-controller="year-picker"
     data-year-picker-selected-year-value="<%= year %>"
     data-year-picker-start-year-value="<%= start_year %>"
     class="relative inline-block">
  <!-- Current Year Display (clickable) -->
  <button type="button"
          data-action="click->year-picker#toggle"
          class="flex items-center space-x-2 px-4 py-2 font-semibold text-lg text-gray-900 hover:bg-gray-50 rounded-lg transition-colors cursor-pointer">
    <span data-year-picker-target="currentDisplay"><%= year %>년</span>
    <svg class="w-5 h-5 text-gray-500 transition-transform" data-year-picker-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <!-- Dropdown Panel -->
  <div data-year-picker-target="dropdown"
       class="hidden absolute left-0 mt-2 bg-white rounded-lg shadow-lg border border-gray-200 z-50 w-80">

    <!-- Range Selector -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
      <button type="button"
              data-action="click->year-picker#previousRange"
              class="p-2 hover:bg-gray-100 rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <span data-year-picker-target="rangeDisplay" class="font-semibold text-gray-900">
        <%= start_year %>년 - <%= end_year %>년
      </span>

      <button type="button"
              data-action="click->year-picker#nextRange"
              class="p-2 hover:bg-gray-100 rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <!-- Year Grid (4x3) -->
    <div class="grid grid-cols-4 gap-2 p-4" data-year-picker-target="yearGrid">
      <% (start_year..end_year).each do |y| %>
        <button type="button"
                data-action="click->year-picker#selectYear"
                data-year="<%= y %>"
                class="px-3 py-2 text-sm font-medium rounded-lg transition-colors cursor-pointer
                       <%= y == year ? 'bg-indigo-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <%= y %>년
        </button>
      <% end %>
    </div>
  </div>

  <!-- Hidden field for base path -->
  <input type="hidden" data-year-picker-target="basePath" value="<%= base_path %>">
</div>
