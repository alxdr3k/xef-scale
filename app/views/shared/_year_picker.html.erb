<% start_year = year - 6 %>
<% end_year = year + 5 %>

<div data-controller="year-picker"
     data-year-picker-selected-year-value="<%= year %>"
     data-year-picker-start-year-value="<%= start_year %>"
     data-year-picker-year-suffix-value="<%= t("common.year_suffix") %>"
     class="relative inline-block">
  <!-- Current Year Display (clickable) -->
  <button type="button"
          data-action="click->year-picker#toggle"
          class="flex items-center space-x-2 px-4 py-2 font-semibold text-lg text-primary hover:bg-elev rounded-lg transition-colors cursor-pointer">
    <span data-year-picker-target="currentDisplay"><%= t("shared.year_picker.year_label", year: year) %></span>
    <svg class="w-5 h-5 text-tertiary transition-transform" data-year-picker-target="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <!-- Dropdown Panel -->
  <div data-year-picker-target="dropdown"
       class="hidden absolute left-0 mt-2 bg-surface rounded-lg shadow-lg border border-divider z-50 w-80">

    <!-- Range Selector -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-divider">
      <button type="button"
              data-action="click->year-picker#previousRange"
              class="p-2 hover:bg-elev rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <span data-year-picker-target="rangeDisplay" class="font-semibold text-primary">
        <%= t("shared.year_picker.range_label", start_year: start_year, end_year: end_year) %>
      </span>

      <button type="button"
              data-action="click->year-picker#nextRange"
              class="p-2 hover:bg-elev rounded-lg transition-colors cursor-pointer">
        <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <!-- Year Grid (4x3) -->
    <div class="grid grid-cols-4 gap-2 p-4" data-year-picker-target="yearGrid">
      <% (start_year..end_year).each do |y| %>
        <button type="button"
                data-action="click->year-picker#selectYear"
                data-year="<%= y %>"
                class="px-3 py-2 text-sm font-medium rounded-lg transition-colors cursor-pointer
                       <%= y == year ? 'bg-action text-action-on' : 'text-secondary hover:bg-elev' %>">
          <%= t("shared.year_picker.year_label", year: y) %>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Hidden field for base path -->
  <input type="hidden" data-year-picker-target="basePath" value="<%= base_path %>">
</div>
