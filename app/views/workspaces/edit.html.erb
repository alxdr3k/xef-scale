<div class="max-w-lg mx-auto">
  <%= link_to '← 워크스페이스로', @workspace, class: 'text-action hover:text-action mb-4 inline-block' %>

  <h1 class="text-2xl font-bold text-primary mb-6">워크스페이스 수정</h1>

  <div class="bg-surface rounded-lg shadow p-6">
    <%= form_with model: @workspace, local: true, class: 'space-y-4' do |f| %>
      <% if @workspace.errors.any? %>
        <div class="bg-danger-subtle border border-danger rounded-md p-4">
          <h3 class="text-sm font-medium text-danger">
            <%= pluralize(@workspace.errors.count, "error") %> prevented this workspace from being saved:
          </h3>
          <ul class="mt-2 text-sm text-danger list-disc list-inside">
            <% @workspace.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-secondary mb-1">이름</label>
        <%= f.text_field :name, class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>

      <div class="flex justify-end gap-3">
        <%= link_to '취소', @workspace, class: 'px-4 py-2 text-secondary hover:text-primary' %>
        <%= f.submit '저장', class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>
