<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">새 워크스페이스</h1>

  <%= form_with model: @workspace, class: 'space-y-6' do |f| %>
    <% if @workspace.errors.any? %>
      <div class="bg-red-50 border border-red-400 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @workspace.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white shadow rounded-lg p-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">워크스페이스 이름 *</label>
        <%= f.text_field :name, required: true, placeholder: '예: 가족 가계부',
            class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500' %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to '취소', workspaces_path,
          class: 'px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50' %>
      <%= f.submit '만들기',
          class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
    </div>
  <% end %>
</div>
