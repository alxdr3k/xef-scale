<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold text-primary mb-6">새 워크스페이스</h1>

  <%= form_with model: @workspace, class: 'space-y-6' do |f| %>
    <% if @workspace.errors.any? %>
      <div class="bg-danger-subtle border border-danger text-danger px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @workspace.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-surface shadow rounded-lg p-6">
      <div>
        <label class="block text-sm font-medium text-secondary mb-1">워크스페이스 이름 *</label>
        <%= f.text_field :name, required: true, placeholder: '예: 가족 가계부',
            class: 'w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to '취소', workspaces_path,
          class: 'px-4 py-2 border border-divider rounded-md text-secondary hover:bg-elev' %>
      <%= f.submit '만들기',
          class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer' %>
    </div>
  <% end %>
</div>
