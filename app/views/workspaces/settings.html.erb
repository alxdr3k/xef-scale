<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-primary mb-6"><%= t("workspaces.settings.title") %></h1>
  <p class="text-secondary mb-8"><%= @workspace.name %></p>

  <!-- Basic Settings -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-4"><%= t("workspaces.settings.basic_section") %></h2>

    <%= form_with model: @workspace, class: 'space-y-4' do |f| %>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("workspaces.settings.name_label") %></label>
        <%= f.text_field :name, class: 'w-full max-w-md rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>
      <div>
        <%= f.submit t("workspaces.settings.save"), class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>
  </div>

  <!-- AI Settings -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-2"><%= t("workspaces.settings.ai_section") %></h2>
    <p class="text-sm text-secondary mb-4">
      <%= t("workspaces.settings.ai_description") %>
    </p>

    <% unless @workspace.ai_consent_acknowledged_at %>
      <div class="rounded-md bg-warning-subtle border border-warning p-3 mb-4 text-sm text-warning">
        <%= t("workspaces.settings.ai_consent_missing") %>
      </div>
    <% else %>
      <p class="text-xs text-tertiary mb-4">
        <%= t("workspaces.settings.ai_consent_at", at: @workspace.ai_consent_acknowledged_at.strftime('%Y-%m-%d %H:%M')) %>
      </p>
    <% end %>

    <%= form_with model: @workspace, class: 'space-y-3' do |f| %>
      <label class="flex items-start gap-2">
        <%= f.check_box :ai_text_parsing_enabled, class: 'mt-1' %>
        <span>
          <span class="font-medium text-primary"><%= t("workspaces.settings.ai_text_parsing") %></span>
          <span class="block text-xs text-tertiary"><%= t("workspaces.settings.ai_text_parsing_hint") %></span>
        </span>
      </label>
      <label class="flex items-start gap-2">
        <%= f.check_box :ai_image_parsing_enabled, class: 'mt-1' %>
        <span>
          <span class="font-medium text-primary"><%= t("workspaces.settings.ai_image_parsing") %></span>
          <span class="block text-xs text-tertiary"><%= t("workspaces.settings.ai_image_parsing_hint") %></span>
        </span>
      </label>
      <label class="flex items-start gap-2">
        <%= f.check_box :ai_category_suggestions_enabled, class: 'mt-1' %>
        <span>
          <span class="font-medium text-primary"><%= t("workspaces.settings.ai_category_suggestions") %></span>
          <span class="block text-xs text-tertiary"><%= t("workspaces.settings.ai_category_suggestions_hint") %></span>
        </span>
      </label>

      <% unless @workspace.ai_consent_acknowledged_at %>
        <label class="flex items-start gap-2 pt-2">
          <%= check_box_tag "workspace[ai_consent_acknowledged]", "true", false, class: 'mt-1' %>
          <span class="text-sm text-secondary">
            <%= t("workspaces.settings.ai_consent_label") %>
          </span>
        </label>
      <% end %>

      <div>
        <%= f.submit t("workspaces.settings.ai_save"), class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>
  </div>

  <!-- Members -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-4"><%= t("workspaces.settings.members_section") %></h2>

    <table class="min-w-full divide-y divide-divider">
      <thead>
        <tr>
          <th class="text-left text-xs font-medium text-tertiary uppercase tracking-wider pb-3"><%= t("workspaces.settings.th_member") %></th>
          <th class="text-left text-xs font-medium text-tertiary uppercase tracking-wider pb-3"><%= t("workspaces.settings.th_role") %></th>
          <th class="text-right text-xs font-medium text-tertiary uppercase tracking-wider pb-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-divider">
        <% @memberships.each do |membership| %>
          <tr>
            <td class="py-3">
              <div class="flex items-center">
                <% if membership.user.avatar_url.present? %>
                  <img src="<%= membership.user.avatar_url %>" class="w-8 h-8 rounded-full mr-3">
                <% else %>
                  <span class="w-8 h-8 rounded-full bg-action flex items-center justify-center text-action-on text-sm font-medium mr-3">
                    <%= membership.user.name&.first&.upcase || membership.user.email&.first&.upcase %>
                  </span>
                <% end %>
                <div>
                  <div class="font-medium text-primary"><%= membership.user.name || membership.user.email %></div>
                  <% if membership.user.name.present? %>
                    <div class="text-sm text-tertiary"><%= membership.user.email %></div>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="py-3">
              <% if membership.role == 'owner' %>
                <span class="text-sm text-secondary"><%= t("workspaces.settings.owner_label") %></span>
              <% else %>
                <%= form_with model: [@workspace, membership], url: workspace_membership_path(@workspace, membership), local: true do |f| %>
                  <%= f.select :role,
                      [[t("workspaces.settings.role_co_owner"), 'co_owner'], [t("workspaces.settings.role_member_write"), 'member_write'], [t("workspaces.settings.role_member_read"), 'member_read']],
                      {}, { onchange: 'this.form.submit()', class: 'text-sm rounded-md border-divider' } %>
                <% end %>
              <% end %>
            </td>
            <td class="py-3 text-right">
              <% unless membership.role == 'owner' || membership.user == current_user %>
                <%= button_to t("workspaces.settings.remove_member"), workspace_membership_path(@workspace, membership),
                    method: :delete,
                    data: { turbo_confirm: t("workspaces.settings.remove_confirm") },
                    class: 'text-danger hover:text-danger text-sm' %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Invitations -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-4"><%= t("workspaces.settings.invitation_section") %></h2>

    <%= form_with model: [@workspace, WorkspaceInvitation.new], url: workspace_invitations_path(@workspace), local: true, class: 'flex gap-4 mb-4' do |f| %>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("workspaces.settings.expires_label") %></label>
        <%= f.datetime_local_field :expires_at, class: 'rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("workspaces.settings.max_uses_label") %></label>
        <%= f.number_field :max_uses, min: 1, placeholder: t("workspaces.settings.max_uses_placeholder"), class: 'w-24 rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>
      <div class="flex items-end">
        <%= f.submit t("workspaces.settings.create_invitation"), class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>

    <% if @invitations.any? %>
      <table class="min-w-full divide-y divide-divider">
        <thead>
          <tr>
            <th class="text-left text-xs font-medium text-tertiary uppercase tracking-wider pb-3"><%= t("workspaces.settings.th_creator") %></th>
            <th class="text-left text-xs font-medium text-tertiary uppercase tracking-wider pb-3"><%= t("workspaces.settings.th_expires") %></th>
            <th class="text-left text-xs font-medium text-tertiary uppercase tracking-wider pb-3"><%= t("workspaces.settings.th_uses") %></th>
            <th class="text-right text-xs font-medium text-tertiary uppercase tracking-wider pb-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-divider">
          <% @invitations.each do |invitation| %>
            <tr>
              <td class="py-3 text-sm"><%= invitation.invited_by.name || invitation.invited_by.email %></td>
              <td class="py-3 text-sm"><%= invitation.expires_at ? l(invitation.expires_at, format: :short) : t("workspaces.settings.expires_none") %></td>
              <td class="py-3 text-sm"><%= invitation.current_uses %>/<%= invitation.max_uses || '∞' %></td>
              <td class="py-3 text-right">
                <button onclick="navigator.clipboard.writeText('<%= join_workspace_url(invitation.token) %>')" class="text-action hover:text-action-hover text-sm mr-2"><%= t("workspaces.settings.copy") %></button>
                <%= button_to t("workspaces.settings.delete"), workspace_invitation_path(@workspace, invitation),
                    method: :delete, class: 'text-danger hover:text-danger text-sm' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-tertiary text-sm"><%= t("workspaces.settings.no_invitations") %></p>
    <% end %>
  </div>

  <!-- Danger Zone -->
  <div class="bg-surface shadow rounded-lg p-6 border-2 border-danger">
    <h2 class="text-lg font-semibold text-danger mb-4"><%= t("workspaces.settings.danger_section") %></h2>
    <p class="text-secondary mb-4"><%= t("workspaces.settings.danger_hint") %></p>
    <%= button_to t("workspaces.settings.delete_workspace"), workspace_path(@workspace),
        method: :delete,
        data: { turbo_confirm: t("workspaces.settings.delete_confirm", name: @workspace.name) },
        class: 'px-4 py-2 bg-danger text-action-on rounded-md hover:bg-danger' %>
  </div>
</div>
