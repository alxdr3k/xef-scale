<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary"><%= @workspace.name %></h1>
      <p class="text-secondary">
        <%= t("workspaces.show.year_month", year: @year, month: @month) %>
      </p>
    </div>
    <%= link_to t("workspaces.show.view_transactions"), workspace_transactions_path(@workspace, year: @year, month: @month),
        class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover' %>
  </div>

  <!-- Month navigation -->
  <div class="flex items-center gap-4 mb-6">
    <%
      prev_month = @month == 1 ? 12 : @month - 1
      prev_year = @month == 1 ? @year - 1 : @year
      next_month = @month == 12 ? 1 : @month + 1
      next_year = @month == 12 ? @year + 1 : @year
    %>
    <%= link_to t("workspaces.show.prev_month"), workspace_path(@workspace, year: prev_year, month: prev_month),
        class: 'text-action hover:text-action-hover' %>
    <span class="flex-1 text-center text-lg font-medium">
      <%= t("workspaces.show.year_month", year: @year, month: @month) %>
    </span>
    <%= link_to t("workspaces.show.next_month"), workspace_path(@workspace, year: next_year, month: next_month),
        class: 'text-action hover:text-action-hover' %>
  </div>

  <!-- Summary -->
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-surface rounded-lg shadow p-6">
      <div class="text-sm text-tertiary mb-1"><%= t("workspaces.show.stat_count") %></div>
      <div class="text-2xl font-bold text-primary"><%= t("workspaces.show.count_suffix", count: @transactions.count) %></div>
    </div>
    <div class="bg-surface rounded-lg shadow p-6">
      <div class="text-sm text-tertiary mb-1"><%= t("workspaces.show.stat_total") %></div>
      <div class="text-2xl font-bold text-danger">
        <%= number_to_currency(@transactions.excluding_coupon.sum(:amount), unit: '₩', precision: 0) %>
      </div>
    </div>
    <div class="bg-surface rounded-lg shadow p-6">
      <div class="text-sm text-tertiary mb-1"><%= t("workspaces.show.stat_daily_avg") %></div>
      <div class="text-2xl font-bold text-primary">
        <% daily_avg = @transactions.excluding_coupon.any? ? (@transactions.excluding_coupon.sum(:amount) / Date.civil(@year, @month, -1).day) : 0 %>
        <%= number_to_currency(daily_avg, unit: '₩', precision: 0) %>
      </div>
    </div>
  </div>

  <!-- Recent transactions -->
  <div class="bg-surface rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-divider flex justify-between items-center">
      <h2 class="text-lg font-semibold text-primary"><%= t("workspaces.show.recent") %></h2>
      <%= link_to t("workspaces.show.view_all"), workspace_transactions_path(@workspace, year: @year, month: @month),
          class: 'text-action hover:text-action-hover text-sm' %>
    </div>

    <table class="min-w-full divide-y divide-divider">
      <thead class="bg-elev">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider"><%= t("workspaces.show.th_date") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider"><%= t("workspaces.show.th_merchant") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider"><%= t("workspaces.show.th_category") %></th>
          <th class="px-6 py-3 text-right text-xs font-medium text-tertiary uppercase tracking-wider"><%= t("workspaces.show.th_amount") %></th>
        </tr>
      </thead>
      <tbody class="bg-surface divide-y divide-divider">
        <% @transactions.limit(10).each do |transaction| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-primary">
              <%= transaction.formatted_date %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-primary">
              <%= transaction.merchant %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-tertiary">
              <%= render 'shared/category_badge', category: transaction.category %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-primary">
              <%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>
            </td>
          </tr>
        <% end %>

        <% if @transactions.empty? %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-tertiary">
              <%= t("workspaces.show.empty") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
