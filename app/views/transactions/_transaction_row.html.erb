<tr id="<%= dom_id(transaction) %>">
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
    <%= transaction.formatted_date %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <div class="text-sm font-medium text-gray-900"><%= transaction.merchant %></div>
    <% if transaction.description.present? && transaction.description != transaction.merchant %>
      <div class="text-sm text-gray-500"><%= truncate(transaction.description, length: 30) %></div>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <% if transaction.category %>
      <span class="px-2 py-1 text-xs rounded-full" style="background-color: <%= transaction.category.color %>20; color: <%= transaction.category.color %>">
        <%= transaction.category.name %>
      </span>
    <% else %>
      <span class="text-gray-400 text-sm">미분류</span>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= transaction.financial_institution&.name || '-' %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
    <%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-center">
    <%= button_to toggle_allowance_workspace_transaction_path(@workspace, transaction), method: :post,
        class: 'text-lg', data: { turbo_frame: dom_id(transaction) } do %>
      <% if transaction.allowance? %>
        <span class="text-yellow-500" title="용돈 해제">💰</span>
      <% else %>
        <span class="text-gray-300 hover:text-yellow-500" title="용돈 표시">💰</span>
      <% end %>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
    <%= link_to '수정', edit_workspace_transaction_path(@workspace, transaction), class: 'text-indigo-600 hover:text-indigo-900' %>
    <%= button_to '삭제', workspace_transaction_path(@workspace, transaction), method: :delete,
        data: { confirm: '정말 삭제하시겠습니까?' },
        class: 'text-red-600 hover:text-red-900 ml-2' %>
  </td>
</tr>
