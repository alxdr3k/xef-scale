<% update_url = inline_update_workspace_transaction_path(@workspace, transaction) %>

<tr id="<%= dom_id(transaction) %>"
    data-bulk-select-target="row"
    data-transaction-id="<%= transaction.id %>"
    data-action="click->bulk-select#toggleRow"
    class="group/row transition-colors duration-150 cursor-pointer">

  <%= render 'shared/transaction_cells/selection_indicator' %>

  <%= render 'shared/transaction_cells/date_cell', transaction: transaction, editable: true, update_url: update_url %>
  <%= render 'shared/transaction_cells/merchant_cell', transaction: transaction, editable: true, update_url: update_url %>
  <%= render 'shared/transaction_cells/amount_cell', transaction: transaction, editable: true, update_url: update_url %>
  <%= render 'shared/transaction_cells/category_cell', transaction: transaction, editable: true, show_management_links: true, workspace: @workspace %>
  <%= render 'shared/transaction_cells/institution_cell', transaction: transaction %>
  <%= render 'shared/transaction_cells/comment_badge_cell', transaction: transaction %>
</tr>
