<tr id="<%= dom_id(transaction) %>">
  <td data-controller="inline-edit"
      data-inline-edit-url-value="<%= inline_update_workspace_transaction_path(@workspace, transaction) %>"
      data-inline-edit-field-value="date"
      data-inline-edit-original-value="<%= transaction.date.to_s %>"
      class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
    <span data-inline-edit-target="display"
          data-action="click->inline-edit#edit"
          class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded">
      <%= transaction.formatted_date %>
    </span>
    <div data-inline-edit-target="editor" class="hidden flex items-center gap-1">
      <input data-inline-edit-target="input" type="date" value="<%= transaction.date.to_s %>"
             data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
             class="text-sm border-gray-300 rounded px-1 py-0.5 w-full focus:ring-1 focus:ring-indigo-500">
      <button data-action="click->inline-edit#save" class="text-green-600 hover:text-green-800 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      </button>
      <button data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <div data-controller="inline-edit"
         data-inline-edit-url-value="<%= inline_update_workspace_transaction_path(@workspace, transaction) %>"
         data-inline-edit-field-value="merchant"
         data-inline-edit-original-value="<%= transaction.merchant %>">
      <span data-inline-edit-target="display"
            data-action="click->inline-edit#edit"
            class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded text-sm font-medium text-gray-900">
        <%= transaction.merchant %>
      </span>
      <div data-inline-edit-target="editor" class="hidden flex items-center gap-1">
        <input data-inline-edit-target="input" type="text" value="<%= transaction.merchant %>"
               data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
               class="text-sm border-gray-300 rounded px-1 py-0.5 w-full focus:ring-1 focus:ring-indigo-500">
        <button data-action="click->inline-edit#save" class="text-green-600 hover:text-green-800 shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        </button>
        <button data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600 shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    </div>
    <% if transaction.description.present? && transaction.description != transaction.merchant %>
      <div data-controller="inline-edit"
           data-inline-edit-url-value="<%= inline_update_workspace_transaction_path(@workspace, transaction) %>"
           data-inline-edit-field-value="description"
           data-inline-edit-original-value="<%= transaction.description %>">
        <span data-inline-edit-target="display"
              data-action="click->inline-edit#edit"
              class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded text-sm text-gray-500">
          <%= truncate(transaction.description, length: 30) %>
        </span>
        <div data-inline-edit-target="editor" class="hidden flex items-center gap-1">
          <input data-inline-edit-target="input" type="text" value="<%= transaction.description %>"
                 data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
                 class="text-sm border-gray-300 rounded px-1 py-0.5 w-full focus:ring-1 focus:ring-indigo-500">
          <button data-action="click->inline-edit#save" class="text-green-600 hover:text-green-800 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </button>
          <button data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
      </div>
    <% end %>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right">
    <div data-controller="inline-edit"
         data-inline-edit-url-value="<%= inline_update_workspace_transaction_path(@workspace, transaction) %>"
         data-inline-edit-field-value="amount"
         data-inline-edit-original-value="<%= transaction.amount %>">
      <div class="flex items-center justify-end gap-2">
        <% if transaction.installment? %>
          <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-violet-100 text-violet-700 border border-violet-200">
            <%= transaction.installment_badge %>
          </span>
        <% end %>
        <span data-inline-edit-target="display"
              data-action="click->inline-edit#edit"
              class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded text-sm text-gray-900 font-medium">
          <%= number_to_currency(transaction.amount, unit: '₩', precision: 0) %>
        </span>
        <div data-inline-edit-target="editor" class="hidden flex items-center gap-1">
          <input data-inline-edit-target="input" type="number" min="1" value="<%= transaction.amount %>"
                 data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
                 class="text-sm border-gray-300 rounded px-1 py-0.5 w-24 focus:ring-1 focus:ring-indigo-500">
          <button data-action="click->inline-edit#save" class="text-green-600 hover:text-green-800 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </button>
          <button data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600 shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
      </div>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap">
    <div data-controller="category-selector"
         data-category-selector-transaction-id-value="<%= transaction.id %>"
         data-category-selector-workspace-id-value="<%= @workspace.id %>"
         data-category-selector-current-category-id-value="<%= transaction.category_id %>"
         class="relative">
      <button type="button"
              data-action="click->category-selector#toggle"
              data-category-selector-target="badge"
              class="cursor-pointer hover:ring-2 hover:ring-indigo-200 rounded-full transition-all">
        <% if transaction.category %>
          <span class="px-2 py-1 text-xs rounded-full inline-flex items-center gap-1"
                style="background-color: <%= transaction.category.color %>20; color: <%= transaction.category.color %>">
            <%= transaction.category.name %>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </span>
        <% else %>
          <span class="text-gray-400 text-sm inline-flex items-center gap-1 px-2 py-1 rounded-full hover:bg-gray-100">
            미분류
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </span>
        <% end %>
      </button>

      <!-- Dropdown -->
      <div data-category-selector-target="dropdown"
           class="hidden absolute z-50 mt-1 w-48 bg-white rounded-lg shadow-lg border border-gray-200 py-1 left-0">
        <div class="max-h-60 overflow-y-auto">
          <% @categories.each do |cat| %>
            <button type="button"
                    data-action="click->category-selector#selectCategory"
                    data-category-id="<%= cat.id %>"
                    class="w-full text-left px-3 py-2 text-sm hover:bg-gray-50 flex items-center justify-between <%= transaction.category_id == cat.id ? 'bg-indigo-50' : '' %>">
              <span class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background-color: <%= cat.color %>"></span>
                <%= cat.name %>
              </span>
              <% if transaction.category_id == cat.id %>
                <svg class="w-4 h-4 text-indigo-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                </svg>
              <% end %>
            </button>
          <% end %>

          <% if transaction.category_id.present? %>
            <hr class="my-1">
            <button type="button"
                    data-action="click->category-selector#selectCategory"
                    data-category-id=""
                    class="w-full text-left px-3 py-2 text-sm text-gray-500 hover:bg-gray-50">
              미분류로 설정
            </button>
          <% end %>
        </div>

        <hr class="my-1">
        <button type="button"
                data-action="click->category-selector#openSlideover"
                class="w-full text-left px-3 py-2 text-sm text-indigo-600 hover:bg-indigo-50">
          + 새 카테고리 만들기
        </button>
        <a href="<%= workspace_categories_path(@workspace) %>"
           class="block px-3 py-2 text-sm text-gray-500 hover:bg-gray-50">
          카테고리 관리
        </a>
      </div>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
    <%= transaction.financial_institution&.name || '-' %>
  </td>
  <td data-controller="inline-edit"
      data-inline-edit-url-value="<%= inline_update_workspace_transaction_path(@workspace, transaction) %>"
      data-inline-edit-field-value="notes"
      data-inline-edit-original-value="<%= transaction.notes || '' %>"
      class="px-6 py-4">
    <span data-inline-edit-target="display"
          data-action="click->inline-edit#edit"
          class="cursor-pointer hover:bg-gray-50 px-1 -mx-1 rounded text-sm text-gray-500">
      <%= truncate(transaction.notes, length: 20).presence || '메모 추가...' %>
    </span>
    <div data-inline-edit-target="editor" class="hidden flex items-center gap-1">
      <input data-inline-edit-target="input" type="text" value="<%= transaction.notes %>"
             data-action="keydown->inline-edit#handleKeydown blur->inline-edit#handleBlur"
             placeholder="메모..."
             class="text-sm border-gray-300 rounded px-1 py-0.5 w-full focus:ring-1 focus:ring-indigo-500">
      <button data-action="click->inline-edit#save" class="text-green-600 hover:text-green-800 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      </button>
      <button data-action="click->inline-edit#cancel" class="text-gray-400 hover:text-gray-600 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  </td>
  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
    <%= button_to '삭제', workspace_transaction_path(@workspace, transaction),
        method: :delete,
        data: { turbo_confirm: '정말 삭제하시겠습니까?' },
        class: 'text-red-600 hover:text-red-900',
        form: { class: 'inline' } %>
  </td>
</tr>
