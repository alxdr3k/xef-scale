<div class="max-w-7xl mx-auto"
     data-controller="bulk-select duplicate-modal note-panel comment-panel"
     data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick click@document->comment-panel#handleOutsideClick"
     data-duplicate-modal-url-value="<%= duplicates_workspace_transactions_path(@workspace) %>">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">결제 내역</h1>
      <p class="text-gray-600"><%= @workspace.name %></p>
    </div>
    <%= link_to '+ 결제 추가', new_workspace_transaction_path(@workspace),
        class: 'bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700' %>
  </div>

  <% if @open_import_issues_count.positive? %>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-900">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold">수정이 필요한 가져오기 항목 <%= @open_import_issues_count %>건</p>
          <p class="mt-1">이미지 파싱 중 날짜, 가맹점, 금액 중 일부가 부족해 아직 결제 내역에 반영되지 않은 항목입니다.</p>
        </div>
        <% if @repair_filter %>
          <%= link_to "전체 결제 내역 보기", workspace_transactions_path(@workspace),
              class: "inline-flex justify-center rounded-md border border-amber-300 bg-white px-3 py-2 font-medium text-amber-800 hover:bg-amber-100" %>
        <% else %>
          <%= link_to "수정 필요 항목 보기", workspace_transactions_path(@workspace, repair: "required"),
              class: "inline-flex justify-center rounded-md bg-amber-600 px-3 py-2 font-medium text-white hover:bg-amber-700" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @repair_filter %>
    <% if @repair_import_issues.any? %>
      <%= render "shared/import_issues_notice",
          import_issues: @repair_import_issues,
          limit: nil,
          title: "수정 필요한 항목만 표시 중",
          description: "알림에서 들어온 업로드의 누락 항목입니다. 다음 단계에서 이 화면에서 바로 필수값을 채워 결제 내역으로 반영합니다." %>
    <% else %>
      <div class="bg-white rounded-lg shadow p-12 text-center text-gray-500">
        수정이 필요한 가져오기 항목이 없습니다.
      </div>
    <% end %>
  <% else %>
  <!-- Filters -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <%= form_with url: workspace_transactions_path(@workspace), method: :get, local: true,
        class: 'flex flex-wrap gap-4',
        data: { controller: 'auto-filter' } do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">연도</label>
        <%= select_tag :year, options_for_select((Date.current.year - 5..Date.current.year).to_a.reverse, @year),
            class: 'block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">월</label>
        <%= select_tag :month, options_for_select([['-전체-', ''], *((1..12).map { |m| ["#{m}월", m] })], @month),
            class: 'block w-24 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">카테고리</label>
        <%= select_tag :category_id,
            options_for_select([['-전체-', ''], *@categories.map { |c| [c.name, c.id] }], params[:category_id]),
            class: 'block w-32 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">검색</label>
        <%= text_field_tag :q, params[:q], placeholder: '내역 검색...',
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            data: { action: 'input->auto-filter#debounceSubmit' } %>
      </div>
    <% end %>

    <div class="flex items-end">
      <button type="button"
              data-action="click->duplicate-modal#open"
              class="px-4 py-2 text-sm bg-amber-500 text-white rounded-md hover:bg-amber-600">
        중복 검사
      </button>
    </div>
  </div>

  <!-- Summary -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="flex justify-between items-center">
      <div class="text-gray-600">
        총 <strong><%= @pagy.count %></strong>건
      </div>
      <div class="text-xl font-bold text-gray-900">
        합계: <%= number_to_currency(@total_amount, unit: '₩', precision: 0) %>
      </div>
    </div>
  </div>

  <%# 숨겨진 일괄 처리 폼 %>
  <%= form_with url: bulk_update_workspace_transactions_path(@workspace), method: :post, data: { turbo: false, bulk_form: true } do %>
    <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
    <input type="hidden" name="bulk_action" value="">
    <input type="hidden" name="category_id" value="">
  <% end %>

  <!-- Selection Toolbar -->
  <div data-bulk-select-target="toolbar"
       class="bg-white rounded-t-lg shadow-sm border-b border-gray-200 px-4 py-2 flex items-center gap-2 min-h-[44px]">
    <%# 체크박스 %>
    <input type="checkbox"
           data-bulk-select-target="toolbarCheckbox"
           data-action="change->bulk-select#toggleSelectAll"
           class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">

    <%# 기본 상태 (선택 없음) %>
    <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-gray-500">
      <span>전체 선택</span>
    </div>

    <%# 선택 상태 %>
    <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
      <span class="text-sm font-medium text-indigo-700 mr-2">
        <span data-bulk-select-target="toolbarCount">0</span>개 선택됨
      </span>

      <div class="w-px h-5 bg-gray-300"></div>

      <%# 삭제 %>
      <button type="button" data-action="click->bulk-select#deleteSelected"
              class="tooltip p-1.5 text-gray-500 hover:text-red-600 hover:bg-red-50 rounded transition-colors" aria-label="삭제">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      </button>

      <%# 용돈 표시 %>
      <button type="button" data-action="click->bulk-select#markAllowance"
              class="tooltip p-1.5 text-gray-500 hover:text-yellow-600 hover:bg-yellow-50 rounded transition-colors" aria-label="용돈 표시">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </button>

      <div class="w-px h-5 bg-gray-300"></div>

      <%# 카테고리 변경 %>
      <div class="flex items-center gap-1">
        <select name="category_id" class="text-xs rounded border-gray-300 py-1 pl-2 pr-6">
          <option value="">카테고리...</option>
          <% @categories.each do |cat| %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% end %>
        </select>
        <button type="button" data-action="click->bulk-select#changeCategory"
                class="px-2 py-1 bg-indigo-600 text-white rounded text-xs hover:bg-indigo-700">
          적용
        </button>
      </div>

      <div class="w-px h-5 bg-gray-300"></div>

      <%# 더보기 메뉴 %>
      <div class="relative">
        <button type="button" data-action="click->bulk-select#toggleMore"
                class="tooltip p-1.5 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded transition-colors" aria-label="더보기">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </button>

        <div data-bulk-select-target="moreMenu"
             class="hidden absolute top-full mt-1 right-0 z-10
                    bg-white rounded-lg shadow-xl border border-gray-200
                    py-1 min-w-[160px] text-gray-700">
          <button type="button" data-action="click->bulk-select#deselectAll"
                  class="w-full px-4 py-2 text-left text-sm hover:bg-gray-100 transition-colors">
            선택 해제
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Transactions Table -->
  <div class="bg-white rounded-b-lg shadow overflow-visible">
    <table class="w-full table-fixed divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-36">날짜</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">내역</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-52">금액</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-36">카테고리</th>
          <th class="px-2 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-16">출처</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider w-16">댓글</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200" id="transactions-list">
        <% @transactions.each do |tx| %>
          <%= render 'transaction_row', transaction: tx %>
        <% end %>

        <% if @transactions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-500">
              결제 내역이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy, params: request.query_parameters) %>
    </div>
  <% end %>
  <% end %>

  <!-- Slideover for category creation -->
  <%= render 'shared/slideover' %>

  <%= render 'transactions/duplicate_modal' %>

  <%= render 'shared/note_panel' %>
  <%= render 'shared/comment_panel' %>
</div>
