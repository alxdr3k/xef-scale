<div class="max-w-7xl mx-auto"
     data-controller="bulk-select duplicate-modal note-panel comment-panel"
     data-action="click@document->bulk-select#closeMore click@document->note-panel#handleOutsideClick click@document->comment-panel#handleOutsideClick"
     data-duplicate-modal-url-value="<%= duplicates_workspace_transactions_path(@workspace) %>"
     data-duplicate-modal-registered-prefix-value="<%= t("transactions.duplicate_modal.registered_prefix") %>"
     data-duplicate-modal-field-label-date-value="<%= t("transactions.duplicate_modal.field_label_date") %>"
     data-duplicate-modal-field-label-merchant-value="<%= t("transactions.duplicate_modal.field_label_merchant") %>"
     data-duplicate-modal-field-label-description-value="<%= t("transactions.duplicate_modal.field_label_description") %>"
     data-duplicate-modal-field-label-amount-value="<%= t("transactions.duplicate_modal.field_label_amount") %>"
     data-duplicate-modal-field-label-category-value="<%= t("transactions.duplicate_modal.field_label_category") %>"
     data-duplicate-modal-field-label-notes-value="<%= t("transactions.duplicate_modal.field_label_notes") %>"
     data-duplicate-modal-uncategorized-option-value="<%= t("transactions.duplicate_modal.uncategorized_option") %>"
     data-duplicate-modal-summary-title-value="<%= t("transactions.duplicate_modal.summary_title") %>"
     data-duplicate-modal-summary-count-value="<%= t("transactions.duplicate_modal.summary_count") %>"
     data-duplicate-modal-summary-stat-deleted-value="<%= t("transactions.duplicate_modal.summary_stat_deleted") %>"
     data-duplicate-modal-summary-stat-kept-value="<%= t("transactions.duplicate_modal.summary_stat_kept") %>"
     data-duplicate-modal-summary-stat-skipped-value="<%= t("transactions.duplicate_modal.summary_stat_skipped") %>"
     data-duplicate-modal-summary-close-value="<%= t("transactions.duplicate_modal.summary_close") %>">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-2xl font-bold text-primary"><%= t("transactions.index.title") %></h1>
      <p class="text-secondary"><%= @workspace.name %></p>
    </div>
    <%= link_to t("transactions.index.add"), new_workspace_transaction_path(@workspace),
        class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover' %>
  </div>

  <!-- Filters -->
  <div class="bg-surface rounded-lg shadow p-4 mb-6">
    <%= form_with url: workspace_transactions_path(@workspace), method: :get, local: true,
        class: 'flex flex-wrap gap-4',
        data: { controller: 'auto-filter' } do |f| %>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("transactions.index.filter_year") %></label>
        <%= select_tag :year, options_for_select((Date.current.year - 5..Date.current.year).to_a.reverse, @year),
            class: 'block w-24 rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("transactions.index.filter_month") %></label>
        <%= select_tag :month, options_for_select([[t("transactions.index.filter_all"), ''], *((1..12).map { |m| [t("transactions.index.filter_month_label", month: m), m] })], @month),
            class: 'block w-24 rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("transactions.index.filter_category") %></label>
        <%= select_tag :category_id,
            options_for_select([[t("transactions.index.filter_all"), ''], *@categories.map { |c| [c.name, c.id] }], params[:category_id]),
            class: 'block w-32 rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            data: { action: 'change->auto-filter#submitForm' } %>
      </div>

      <div class="flex-1">
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("transactions.index.filter_search") %></label>
        <%= text_field_tag :q, params[:q], placeholder: t("transactions.index.search_placeholder"),
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            data: { action: 'input->auto-filter#debounceSubmit' } %>
      </div>
    <% end %>

    <div class="flex items-end">
      <button type="button"
              data-action="click->duplicate-modal#open"
              class="px-4 py-2 text-sm bg-warning text-action-on rounded-md hover:bg-warning">
        <%= t("transactions.index.duplicate_check") %>
      </button>
    </div>
  </div>

  <!-- Summary -->
  <div class="bg-surface rounded-lg shadow p-4 mb-6">
    <div class="flex justify-between items-center">
      <div class="text-secondary">
        <%= t("transactions.index.total_count_html", count: @pagy.count).html_safe %>
      </div>
      <div class="text-xl font-bold text-primary">
        <%= t("transactions.index.total_amount", amount: number_to_currency(@total_amount, unit: '₩', precision: 0)) %>
      </div>
    </div>
  </div>

  <%# 숨겨진 일괄 처리 폼 %>
  <%= form_with url: bulk_update_workspace_transactions_path(@workspace), method: :post, data: { turbo: false, bulk_form: true } do %>
    <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
    <input type="hidden" name="bulk_action" value="">
    <input type="hidden" name="category_id" value="">
  <% end %>

  <!-- Selection Toolbar -->
  <div data-bulk-select-target="toolbar"
       class="bg-surface rounded-t-lg shadow-sm border-b border-divider px-4 py-2 flex items-center gap-2 min-h-[44px]">
    <%# 체크박스 %>
    <input type="checkbox"
           data-bulk-select-target="toolbarCheckbox"
           data-action="change->bulk-select#toggleSelectAll"
           class="h-4 w-4 rounded border-divider text-action focus:ring-action cursor-pointer">

    <%# 기본 상태 (선택 없음) %>
    <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-tertiary">
      <span><%= t("transactions.index.bulk_select_all") %></span>
    </div>

    <%# 선택 상태 %>
    <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
      <span class="text-sm font-medium text-action mr-2">
        <%= t("transactions.index.bulk_selected_count_html", count: '<span data-bulk-select-target="toolbarCount">0</span>').html_safe %>
      </span>

      <div class="w-px h-5 bg-divider"></div>

      <%# 삭제 %>
      <button type="button" data-action="click->bulk-select#deleteSelected"
              class="tooltip p-1.5 text-tertiary hover:text-danger hover:bg-danger-subtle rounded transition-colors" aria-label="<%= t("transactions.index.bulk_delete") %>">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
      </button>

      <%# 용돈 표시 %>
      <button type="button" data-action="click->bulk-select#markAllowance"
              class="tooltip p-1.5 text-tertiary hover:text-warning hover:bg-warning-subtle rounded transition-colors" aria-label="<%= t("transactions.index.bulk_allowance") %>">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </button>

      <div class="w-px h-5 bg-divider"></div>

      <%# 카테고리 변경 %>
      <div class="flex items-center gap-1">
        <select name="category_id" class="text-xs rounded border-divider py-1 pl-2 pr-6">
          <option value=""><%= t("transactions.index.bulk_category_placeholder") %></option>
          <% @categories.each do |cat| %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% end %>
        </select>
        <button type="button" data-action="click->bulk-select#changeCategory"
                class="px-2 py-1 bg-action text-action-on rounded text-xs hover:bg-action-hover">
          <%= t("transactions.index.bulk_apply") %>
        </button>
      </div>

      <div class="w-px h-5 bg-divider"></div>

      <%# 더보기 메뉴 %>
      <div class="relative">
        <button type="button" data-action="click->bulk-select#toggleMore"
                class="tooltip p-1.5 text-tertiary hover:text-secondary hover:bg-elev rounded transition-colors" aria-label="<%= t("transactions.index.bulk_more") %>">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 12.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5ZM12 18.75a.75.75 0 1 1 0-1.5.75.75 0 0 1 0 1.5Z" />
          </svg>
        </button>

        <div data-bulk-select-target="moreMenu"
             class="hidden absolute top-full mt-1 right-0 z-10
                    bg-surface rounded-lg shadow-xl border border-divider
                    py-1 min-w-[160px] text-secondary">
          <button type="button" data-action="click->bulk-select#deselectAll"
                  class="w-full px-4 py-2 text-left text-sm hover:bg-elev transition-colors">
            <%= t("transactions.index.bulk_clear") %>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Transactions Table -->
  <div class="bg-surface rounded-b-lg shadow overflow-visible">
    <table class="w-full table-fixed divide-y divide-divider">
      <thead class="bg-elev">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider w-36"><%= t("transactions.index.th_date") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider"><%= t("transactions.index.th_merchant") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium text-tertiary uppercase tracking-wider w-52"><%= t("transactions.index.th_amount") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider w-36"><%= t("transactions.index.th_category") %></th>
          <th class="px-2 py-3 text-center text-xs font-medium text-tertiary uppercase tracking-wider w-16"><%= t("transactions.index.th_source") %></th>
          <th class="px-4 py-3 text-center text-xs font-medium text-tertiary uppercase tracking-wider w-16"><%= t("transactions.index.th_comments") %></th>
        </tr>
      </thead>
      <tbody class="bg-surface divide-y divide-divider" id="transactions-list">
        <% @transactions.each do |tx| %>
          <%# Phase 5 slice 3 (Codex PR #182 P2 defense-in-depth): 거래 목록은
              검토 컨텍스트가 아니므로 reviewable: false를 명시. 자동 추론은
              active scope(committed only)에 의존하지만 명시 전달이 더 robust. %>
          <%= render 'transaction_row', transaction: tx, reviewable: false %>
        <% end %>

        <% if @transactions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-tertiary">
              <%= t("transactions.index.empty") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if @pagy.pages > 1 %>
    <div class="mt-6">
      <%== pagy_nav(@pagy, params: request.query_parameters) %>
    </div>
  <% end %>

  <!-- Slideover for category creation -->
  <%= render 'shared/slideover' %>

  <%= render 'transactions/duplicate_modal' %>

  <%= render 'shared/note_panel' %>
  <%= render 'shared/comment_panel' %>
</div>
