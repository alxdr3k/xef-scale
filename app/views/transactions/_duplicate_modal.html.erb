<div class="hidden" data-duplicate-modal-target="modal">
  <div class="fixed inset-0 bg-overlay z-40" data-action="click->duplicate-modal#close"></div>

  <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="bg-surface rounded-2xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
      <div class="px-6 py-4 border-b border-divider">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <button data-duplicate-modal-target="undoBtn"
                    data-action="click->duplicate-modal#undo"
                    class="text-disabled opacity-50 cursor-not-allowed p-1 rounded-lg transition-all"
                    title="<%= t("transactions.duplicate_modal.undo_title") %>"
                    disabled>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a5 5 0 015 5v2M3 10l4 4M3 10l4-4"/>
              </svg>
            </button>
            <h2 class="text-lg font-semibold text-primary"><%= t("transactions.duplicate_modal.title") %></h2>
            <span data-duplicate-modal-target="counter" class="text-sm text-tertiary"></span>
          </div>
          <button data-action="click->duplicate-modal#close" class="text-disabled hover:text-secondary">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="mt-3 h-1.5 bg-elev rounded-full overflow-hidden">
          <div data-duplicate-modal-target="progress" class="h-full bg-action rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <div class="p-6">
        <div data-duplicate-modal-target="loading" class="flex flex-col items-center justify-center py-12">
          <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-action"></div>
          <p class="mt-3 text-sm text-tertiary"><%= t("transactions.duplicate_modal.loading") %></p>
        </div>

        <div data-duplicate-modal-target="empty" class="hidden text-center py-12">
          <svg class="mx-auto h-12 w-12 text-positive" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="mt-3 text-secondary font-medium"><%= t("transactions.duplicate_modal.empty_title") %></p>
          <p class="mt-1 text-sm text-tertiary"><%= t("transactions.duplicate_modal.empty_hint") %></p>
        </div>

        <div data-duplicate-modal-target="content" class="hidden"></div>

        <div data-duplicate-modal-target="summary" class="hidden"></div>
      </div>

      <div data-duplicate-modal-target="footer" class="hidden px-6 py-4 border-t border-divider bg-elev">
        <div class="flex justify-center gap-3">
          <button data-action="click->duplicate-modal#keepLeft"
                  class="px-4 py-2 bg-info text-action-on rounded-lg hover:bg-info text-sm font-medium">
            <%= t("transactions.duplicate_modal.keep_left") %>
          </button>
          <button data-action="click->duplicate-modal#keepRight"
                  class="px-4 py-2 bg-ai text-action-on rounded-lg hover:bg-ai text-sm font-medium">
            <%= t("transactions.duplicate_modal.keep_right") %>
          </button>
          <button data-action="click->duplicate-modal#keepBoth"
                  class="px-4 py-2 bg-elev text-secondary rounded-lg hover:bg-divider text-sm font-medium">
            <%= t("transactions.duplicate_modal.keep_both") %>
          </button>
        </div>
        <div class="mt-2 text-center text-xs text-disabled">
          <%= t("transactions.duplicate_modal.keyboard_hint") %>
        </div>
      </div>
    </div>
  </div>
</div>
