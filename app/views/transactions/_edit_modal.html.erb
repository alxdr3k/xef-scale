<div id="edit-modal"
     class="hidden fixed inset-0 z-50 overflow-y-auto"
     data-edit-modal-target="modal"
     data-i18n-title-edit="<%= t("transactions.edit_modal.title") %>"
     data-i18n-title-new="<%= t("transactions.edit_modal.title_new") %>"
     data-i18n-allowance-toggle="<%= t("transactions.edit_modal.allowance_toggle") %>"
     data-i18n-load-error="<%= t("transactions.edit_modal.load_error") %>"
     data-i18n-loading="<%= t("transactions.edit_modal.loading") %>"
     aria-labelledby="modal-title"
     role="dialog"
     aria-modal="true">
  <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <!-- Background overlay -->
    <div class="fixed inset-0 bg-overlay transition-opacity" data-action="click->edit-modal#close"></div>

    <!-- Modal panel -->
    <div class="relative z-10 inline-block align-bottom bg-surface rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
      <div class="bg-surface px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-primary" id="modal-title" data-edit-modal-target="title"><%= t("transactions.edit_modal.title") %></h3>
          <button type="button" class="text-disabled hover:text-tertiary" data-action="click->edit-modal#close">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Modal content will be loaded here -->
        <div data-edit-modal-target="content" class="space-y-4">
          <div class="text-center py-8 text-tertiary">
            <%= t("transactions.edit_modal.loading") %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
