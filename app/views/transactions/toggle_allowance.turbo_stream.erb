<%= turbo_stream.update "flash", partial: "shared/flash" %>
<% if @source == 'allowance' && !@transaction.allowance? %>
  <%= turbo_stream.remove dom_id(@transaction) %>
<% elsif @source == 'review' %>
  <%= turbo_stream.replace dom_id(@transaction),
      partial: 'transactions/transaction_row',
      locals: {
        transaction: @transaction,
        categories: @categories,
        read_only: @read_only,
        reviewable: true # i18n-allow: Phase 5 slice 3 (Codex PR #182 P1) review 컨텍스트에서 tabindex 보존
      } %>
<% else %>
  <%= turbo_stream.replace dom_id(@transaction),
      partial: 'transactions/transaction_row',
      locals: { transaction: @transaction } %>
<% end %>
