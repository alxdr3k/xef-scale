<%#
  Phase 3.4 (ADR-0004 / ui-redesign-plan §3.4): 카테고리 + 학습된 매핑을 같은
  페이지에 *두 섹션*으로 결합한다 (탭 폐기). 학습된 매핑은 최근 N개 미리보기 +
  전체 보기 CTA로 workspace_category_mappings_path를 노출 — 라우트는 유지.
%>
<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-primary"><%= t("categories.index.title") %></h1>
    <p class="text-secondary text-sm mt-1">
      <%= t("categories.index.summary", count: @categories.size, mapping_count: @total_mappings_count) %>
    </p>
  </div>

  <%# 섹션 1: 내 카테고리 %>
  <section class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-primary"><%= t("categories.index.my_categories") %></h2>
      <%= link_to t("categories.index.add"), new_workspace_category_path(@workspace),
            class: 'inline-flex items-center px-3 py-2 text-sm font-medium rounded-md bg-action text-action-on hover:bg-action-hover' %>
    </div>

    <div class="bg-surface rounded-lg shadow-sm overflow-hidden">
      <table class="min-w-full divide-y divide-divider">
        <thead class="bg-elev">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_color") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_name") %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_keyword") %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_action") %></th>
          </tr>
        </thead>
        <tbody id="categories-list" class="bg-surface divide-y divide-divider">
          <% @categories.each do |category| %>
            <%= render 'category_row', category: category %>
          <% end %>

          <% if @categories.empty? %>
            <tr id="no-categories-row">
              <td colspan="4" class="px-6 py-12 text-center text-secondary"><%= t("categories.index.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# 섹션 2: 학습된 매핑 (최근 N개 미리보기) %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-primary"><%= t("categories.index.mappings_section") %></h2>
      <%= link_to t("categories.index.view_all"), workspace_category_mappings_path(@workspace),
            class: 'text-sm font-medium text-action hover:underline' %>
    </div>

    <% if @recent_mappings.any? %>
      <div class="bg-surface rounded-lg shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-divider">
          <thead class="bg-elev">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_pattern") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_category") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_source") %></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary uppercase"><%= t("categories.index.th_updated") %></th>
            </tr>
          </thead>
          <tbody class="bg-surface divide-y divide-divider">
            <% @recent_mappings.each do |mapping| %>
              <tr id="<%= dom_id(mapping, :preview) %>">
                <td class="px-6 py-3 text-sm text-primary"><%= mapping.merchant_pattern %></td>
                <td class="px-6 py-3 text-sm">
                  <% if mapping.category %>
                    <span class="inline-flex items-center gap-1.5">
                      <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= mapping.category.color %>"></span>
                      <%= mapping.category.name %>
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-3 text-sm">
                  <%# ADR-0011 §Decision 5: 매핑 출처 어휘를 ko.yml로 분리해
                      결정 메커니즘과 단어를 공유하지 않게 한다. %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-elev text-secondary">
                    <%= t("category_mappings.source.#{mapping.source}", default: mapping.source) %>
                  </span>
                </td>
                <td class="px-6 py-3 text-sm text-secondary">
                  <%= t("categories.index.relative_time", relative: time_ago_in_words(mapping.updated_at)) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @total_mappings_count > @recent_mappings.size %>
        <p class="text-meta text-tertiary text-center mt-2">
          <%= t("categories.index.pagination_hint", shown: @recent_mappings.size, total: @total_mappings_count) %>
        </p>
      <% end %>
    <% else %>
      <div class="bg-surface rounded-lg shadow-sm px-6 py-8 text-center text-secondary">
        <%= t("categories.index.empty_mappings_html").html_safe %>
      </div>
    <% end %>
  </section>
</div>
