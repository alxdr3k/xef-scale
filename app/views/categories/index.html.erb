<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">카테고리 관리</h1>
  </div>

  <div data-controller="tabs">
    <%# 탭 헤더 %>
    <div class="border-b border-gray-200 mb-6">
      <nav class="-mb-px flex gap-6" aria-label="탭">
        <button data-tabs-target="tab"
                data-action="click->tabs#switch"
                class="py-3 px-1 border-b-2 font-medium text-sm text-indigo-600 border-indigo-600"
                aria-selected="true">
          카테고리
        </button>
        <button data-tabs-target="tab"
                data-action="click->tabs#switch"
                class="py-3 px-1 border-b-2 font-medium text-sm text-gray-500 hover:text-gray-700 border-transparent"
                aria-selected="false">
          분류 규칙
        </button>
      </nav>
    </div>

    <%# 카테고리 패널 %>
    <div data-tabs-target="panel">
      <div class="flex justify-end mb-4">
        <%= link_to '새 카테고리', new_workspace_category_path(@workspace), class: 'bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700' %>
      </div>

      <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">색상</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">키워드</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">작업</th>
            </tr>
          </thead>
          <tbody id="categories-list" class="bg-white divide-y divide-gray-200">
            <% @categories.each do |category| %>
              <%= render 'category_row', category: category %>
            <% end %>

            <% if @categories.empty? %>
              <tr id="no-categories-row">
                <td colspan="4" class="px-6 py-12 text-center text-gray-500">등록된 카테고리가 없습니다.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# 분류 규칙 패널 %>
    <div data-tabs-target="panel" class="hidden">
      <turbo-frame id="category-mappings-panel" src="<%= workspace_category_mappings_path(@workspace) %>" loading="lazy">
        <div class="flex justify-center py-12">
          <svg class="animate-spin h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </div>
      </turbo-frame>
    </div>
  </div>
</div>
