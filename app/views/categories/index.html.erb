<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">카테고리 관리</h1>
    <%= link_to '새 카테고리', new_workspace_category_path(@workspace), class: 'bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700' %>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">색상</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">키워드</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">작업</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @categories.each do |category| %>
          <tr>
            <td class="px-6 py-4">
              <div class="w-6 h-6 rounded-full" style="background-color: <%= category.color %>"></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-900"><%= category.name %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= category.keyword %></td>
            <td class="px-6 py-4 text-right text-sm">
              <%= link_to '수정', edit_workspace_category_path(@workspace, category), class: 'text-indigo-600 hover:text-indigo-900 mr-3' %>
              <%= link_to '삭제', workspace_category_path(@workspace, category), method: :delete, data: { confirm: '정말 삭제하시겠습니까?' }, class: 'text-red-600 hover:text-red-900' %>
            </td>
          </tr>
        <% end %>

        <% if @categories.empty? %>
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-gray-500">등록된 카테고리가 없습니다.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
