<turbo-frame id="slideover-content">
  <h2 class="text-lg font-semibold text-primary mb-6">새 카테고리</h2>

  <%# Preserve review-context binding in the create POST. Without
      parsing_session_id the controller falls back to workspace scope and the
      re-rendered row uses workspace-level update endpoints, leaking past
      ReviewsController#reject_if_finalized for subsequent edits. %>
  <%= form_with model: [@workspace, @category],
        url: workspace_categories_path(@workspace, slideover: true, transaction_id: @transaction_id, parsing_session_id: @parsing_session&.id),
        class: 'space-y-4',
        data: { turbo_frame: '_top' } do |f| %>

    <% if @category.errors.any? %>
      <div class="bg-danger-subtle border border-danger rounded-md p-4">
        <ul class="text-sm text-danger list-disc list-inside">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">이름 *</label>
      <%= f.text_field :name,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: '예: 식비, 교통비, 쇼핑',
            autofocus: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-secondary mb-1">자동 분류 키워드</label>
      <%= f.text_field :keyword,
            class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action',
            placeholder: '쉼표로 구분 (예: 스타벅스, 카페)' %>
      <p class="mt-1 text-xs text-tertiary">결제 내역에 이 키워드가 포함되면 자동으로 분류됩니다.</p>
    </div>

    <%= render 'shared/color_picker', form: f %>

    <div class="flex justify-end gap-3 pt-4 border-t border-divider">
      <button type="button"
              data-action="click->slideover#close"
              class="px-4 py-2 text-secondary hover:text-primary">
        취소
      </button>
      <%= f.submit '저장', class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover cursor-pointer' %>
    </div>
  <% end %>
</turbo-frame>
