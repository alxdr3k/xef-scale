<turbo-frame id="slideover-content">
  <h2 class="text-lg font-semibold text-gray-900 mb-6">새 카테고리</h2>

  <%= form_with model: [@workspace, @category],
        url: workspace_categories_path(@workspace, slideover: true, transaction_id: @transaction_id),
        class: 'space-y-4',
        data: { turbo_frame: '_top' } do |f| %>

    <% if @category.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">이름 *</label>
      <%= f.text_field :name,
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            placeholder: '예: 식비, 교통비, 쇼핑',
            autofocus: true %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">자동 분류 키워드</label>
      <%= f.text_field :keyword,
            class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500',
            placeholder: '쉼표로 구분 (예: 스타벅스, 카페)' %>
      <p class="mt-1 text-xs text-gray-500">거래 내역에 이 키워드가 포함되면 자동으로 분류됩니다.</p>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">색상</label>
      <div class="flex items-center gap-3">
        <%= f.color_field :color,
              value: @category.color.presence || '#6366F1',
              class: 'h-10 w-20 rounded-md border-gray-300 shadow-sm cursor-pointer' %>
        <span class="text-sm text-gray-500">차트와 배지에 사용됩니다</span>
      </div>
    </div>

    <div class="flex justify-end gap-3 pt-4 border-t border-gray-200">
      <button type="button"
              data-action="click->slideover#close"
              class="px-4 py-2 text-gray-700 hover:text-gray-900">
        취소
      </button>
      <%= f.submit '저장', class: 'bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer' %>
    </div>
  <% end %>
</turbo-frame>
