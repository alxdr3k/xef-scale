<div class="max-w-lg mx-auto">
  <%= link_to t("categories.edit.back"), workspace_categories_path(@workspace), class: 'text-action hover:text-action mb-4 inline-block' %>

  <h1 class="text-2xl font-bold text-primary mb-6"><%= t("categories.edit.title") %></h1>

  <div class="bg-surface rounded-lg shadow p-6">
    <%= form_with model: [@workspace, @category], data: { turbo: false }, class: 'space-y-4' do |f| %>
      <% if @category.errors.any? %>
        <div class="bg-danger-subtle border border-danger rounded-md p-4">
          <h3 class="text-sm font-medium text-danger">
            <%= pluralize(@category.errors.count, "error") %> prevented this category from being saved:
          </h3>
          <ul class="mt-2 text-sm text-danger list-disc list-inside">
            <% @category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("categories.form.name") %></label>
        <%= f.text_field :name, class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
      </div>

      <div>
        <label class="block text-sm font-medium text-secondary mb-1"><%= t("categories.form.keyword") %></label>
        <%= f.text_field :keyword, class: 'block w-full rounded-md border-divider shadow-sm focus:border-action focus:ring-action' %>
        <p class="mt-1 text-sm text-tertiary"><%= t("categories.form.keyword_hint") %></p>
      </div>

      <%= render 'shared/color_picker', form: f %>

      <div class="flex justify-end gap-3">
        <%= link_to t("categories.form.cancel"), workspace_categories_path(@workspace), class: 'px-4 py-2 text-secondary hover:text-primary' %>
        <%= f.submit t("categories.form.submit"), class: 'bg-action text-action-on px-4 py-2 rounded-lg hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>
