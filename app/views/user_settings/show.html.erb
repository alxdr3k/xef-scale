<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-primary mb-6"><%= t("user_settings.title") %></h1>

  <!-- 파싱 설정 -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-2"><%= t("user_settings.parsing_section") %></h2>

    <%= form_with url: user_settings_path, method: :patch, class: 'space-y-6' do |f| %>
      <!-- 제외 거래처 -->
      <div>
        <label class="block text-sm font-medium text-secondary mb-1">
          <%= t("user_settings.excluded_merchants") %>
        </label>
        <textarea name="user[excluded_merchants]"
                  rows="4"
                  placeholder="<%= t("user_settings.excluded_merchants_placeholder") %>"
                  class="w-full max-w-md rounded-md border-divider shadow-sm focus:border-action focus:ring-action text-sm"><%= current_user.excluded_merchants.join("\n") %></textarea>
        <p class="mt-1 text-xs text-tertiary">
          <%= t("user_settings.excluded_merchants_hint") %>
        </p>
      </div>

      <div class="pt-2">
        <%= f.submit t("user_settings.save"), class: 'px-4 py-2 bg-action text-action-on rounded-md hover:bg-action-hover cursor-pointer' %>
      </div>
    <% end %>
  </div>

  <!-- 스크린샷 업로드 가이드 -->
  <div class="bg-surface shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-primary mb-2"><%= t("user_settings.screenshot_section") %></h2>
    <p class="text-sm text-tertiary mb-4">
      <%= t("user_settings.screenshot_description_html").html_safe %>
    </p>
    <div class="text-sm text-secondary space-y-1">
      <p><%= t("user_settings.screenshot_shinhan_html").html_safe %></p>
      <p class="text-xs text-tertiary"><%= t("user_settings.screenshot_other_html").html_safe %></p>
    </div>
  </div>

  <!-- Account Info -->
  <div class="bg-surface shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-primary mb-4"><%= t("user_settings.account_section") %></h2>
    <div class="space-y-3">
      <div class="flex items-center">
        <% if current_user.avatar_url.present? %>
          <img src="<%= current_user.avatar_url %>" class="w-12 h-12 rounded-full mr-4">
        <% else %>
          <span class="w-12 h-12 rounded-full bg-action flex items-center justify-center text-action-on text-lg font-medium mr-4">
            <%= current_user.name&.first&.upcase || current_user.email&.first&.upcase %>
          </span>
        <% end %>
        <div>
          <div class="font-medium text-primary"><%= current_user.name || t("user_settings.no_name") %></div>
          <div class="text-sm text-tertiary"><%= current_user.email %></div>
        </div>
      </div>
    </div>
  </div>
</div>
