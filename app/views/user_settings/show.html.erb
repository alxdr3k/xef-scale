<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">계정 설정</h1>

  <!-- Statement Passwords -->
  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2">명세서 비밀번호</h2>
    <p class="text-sm text-gray-500 mb-4">
      암호화된 PDF 명세서를 파싱하기 위한 비밀번호입니다.
    </p>

    <%= form_with url: user_settings_path, method: :patch, class: 'space-y-4' do |f| %>
      <% User::INSTITUTIONS_WITH_PASSWORD.each do |key, name| %>
        <% has_password = current_user.statement_password(key).present? %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            <%= name %>
            <% if has_password %>
              <span class="ml-2 text-xs text-green-600">✓ 저장됨</span>
            <% end %>
          </label>
          <input type="password"
                 name="user[statement_passwords][<%= key %>]"
                 placeholder="<%= has_password ? '변경하려면 새 비밀번호 입력' : '비밀번호 입력' %>"
                 autocomplete="off"
                 class="w-full max-w-xs rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
          <p class="mt-1 text-xs text-gray-400">
            <% if key == "shinhan_card" %>
              일반적으로 생년월일 6자리 (YYMMDD)
            <% end %>
          </p>
        </div>
      <% end %>

      <div class="pt-4">
        <%= f.submit '저장', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
      </div>
    <% end %>
  </div>

  <!-- Account Info -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">계정 정보</h2>
    <div class="space-y-3">
      <div class="flex items-center">
        <% if current_user.avatar_url.present? %>
          <img src="<%= current_user.avatar_url %>" class="w-12 h-12 rounded-full mr-4">
        <% else %>
          <span class="w-12 h-12 rounded-full bg-indigo-500 flex items-center justify-center text-white text-lg font-medium mr-4">
            <%= current_user.name&.first&.upcase || current_user.email&.first&.upcase %>
          </span>
        <% end %>
        <div>
          <div class="font-medium text-gray-900"><%= current_user.name || "이름 없음" %></div>
          <div class="text-sm text-gray-500"><%= current_user.email %></div>
        </div>
      </div>
    </div>
  </div>
</div>
