<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">계정 설정</h1>

  <!-- 파싱 설정 -->
  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2">파싱 설정</h2>

    <%= form_with url: user_settings_path, method: :patch, class: 'space-y-6' do |f| %>
      <!-- 제외 거래처 -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          제외할 거래처
        </label>
        <textarea name="user[excluded_merchants]"
                  rows="4"
                  placeholder="제외할 거래처를 줄바꿈으로 구분하여 입력&#10;예: 본인이체&#10;토스뱅크이자"
                  class="w-full max-w-md rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"><%= current_user.excluded_merchants.join("\n") %></textarea>
        <p class="mt-1 text-xs text-gray-400">
          파싱 시 제외할 거래처명을 줄바꿈으로 구분하여 입력하세요. 거래처명에 입력한 텍스트가 포함되면 제외됩니다.
        </p>
      </div>

      <div class="pt-2">
        <%= f.submit '저장', class: 'px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 cursor-pointer' %>
      </div>
    <% end %>
  </div>

  <!-- 스크린샷 업로드 가이드 -->
  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-2">스크린샷 업로드 가이드</h2>
    <p class="text-sm text-gray-500 mb-4">
      현재 <strong>신한카드 이용대금 명세서</strong> 스크린샷을 지원합니다. 명세서를 열어 전체가 보이는 화면을 캡처한 뒤 <em>결제 추가</em>에서 이미지(JPG/PNG/WEBP/HEIC)로 업로드하세요.
    </p>
    <div class="text-sm text-gray-600 space-y-1">
      <p><strong>신한카드:</strong> 신한SOL 앱 → 마이 → 이용내역 또는 청구서 → 화면 캡처 → 결제 추가에서 업로드</p>
      <p class="text-xs text-gray-400">다른 기관 명세서는 금융 문자 복사 → <em>문자 붙여넣기</em> 입력창에 붙여넣어 주세요.</p>
    </div>
  </div>

  <!-- Account Info -->
  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">계정 정보</h2>
    <div class="space-y-3">
      <div class="flex items-center">
        <% if current_user.avatar_url.present? %>
          <img src="<%= current_user.avatar_url %>" class="w-12 h-12 rounded-full mr-4">
        <% else %>
          <span class="w-12 h-12 rounded-full bg-indigo-500 flex items-center justify-center text-white text-lg font-medium mr-4">
            <%= current_user.name&.first&.upcase || current_user.email&.first&.upcase %>
          </span>
        <% end %>
        <div>
          <div class="font-medium text-gray-900"><%= current_user.name || "이름 없음" %></div>
          <div class="text-sm text-gray-500"><%= current_user.email %></div>
        </div>
      </div>
    </div>
  </div>
</div>
