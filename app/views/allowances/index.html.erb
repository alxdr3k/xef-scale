<div class="max-w-4xl mx-auto" data-controller="bulk-select" data-action="click@document->bulk-select#closeMore">
  <h1 class="text-2xl font-bold text-primary mb-2">내 용돈</h1>
  <p class="text-secondary mb-6">다른 사람에게 보이지 않는 개인 지출 내역입니다.</p>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to '← 이전 달', allowances_path(year: prev_year, month: prev_month),
        class: 'text-action hover:text-action-hover' %>

    <%= render 'shared/month_picker', year: @year, month: @month, base_path: allowances_path %>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to '다음 달 →', allowances_path(year: next_year, month: next_month),
        class: 'text-action hover:text-action-hover' %>
  </div>

  <!-- Monthly Summary -->
  <div class="bg-surface rounded-lg shadow p-6 mb-8">
    <div class="text-sm font-medium text-tertiary">이번 달 용돈 지출</div>
    <div class="text-3xl font-bold text-primary mt-2">
      <%= number_to_currency(@total_amount, unit: '₩', precision: 0) %>
    </div>
  </div>

  <%# 숨겨진 일괄 처리 폼 %>
  <%= form_with url: bulk_update_allowances_path, method: :post, data: { turbo: false, bulk_form: true } do %>
    <input type="hidden" name="transaction_ids" data-bulk-select-target="ids" value="">
    <input type="hidden" name="bulk_action" value="">
    <input type="hidden" name="year" value="<%= @year %>">
    <input type="hidden" name="month" value="<%= @month %>">
  <% end %>

  <!-- Selection Toolbar -->
  <div data-bulk-select-target="toolbar"
       class="bg-surface rounded-t-lg shadow-sm border-b border-divider px-4 py-2 flex items-center gap-2 min-h-[44px]">
    <input type="checkbox"
           data-bulk-select-target="toolbarCheckbox"
           data-action="change->bulk-select#toggleSelectAll"
           class="h-4 w-4 rounded border-divider text-action focus:ring-action cursor-pointer">

    <div data-bulk-select-target="toolbarDefault" class="flex items-center gap-1 text-sm text-tertiary">
      <span>전체 선택</span>
    </div>

    <div data-bulk-select-target="toolbarSelected" class="hidden flex items-center gap-1">
      <span class="text-sm font-medium text-action mr-2">
        <span data-bulk-select-target="toolbarCount">0</span>개 선택됨
      </span>

      <div class="w-px h-5 bg-divider"></div>

      <button type="button" data-action="click->bulk-select#unmarkAllowance"
              class="tooltip p-1.5 text-tertiary hover:text-danger hover:bg-danger-subtle rounded transition-colors" aria-label="용돈 해제">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
        </svg>
      </button>

      <span class="text-xs text-tertiary">용돈 해제</span>
    </div>
  </div>

  <!-- Transactions -->
  <div class="bg-surface rounded-b-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-divider">
      <thead class="bg-elev">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider">날짜</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider">내역</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-tertiary uppercase tracking-wider">금액</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-tertiary uppercase tracking-wider">카테고리</th>
        </tr>
      </thead>
      <tbody class="bg-surface divide-y divide-divider">
        <% @allowance_transactions.each do |at| %>
          <% transaction = at.expense_transaction %>
          <tr id="<%= dom_id(transaction) %>"
              data-bulk-select-target="row"
              data-transaction-id="<%= transaction.id %>"
              data-action="click->bulk-select#toggleRow"
              class="transition-colors duration-150 cursor-pointer">
            <%= render 'shared/transaction_cells/date_cell', transaction: transaction %>
            <%= render 'shared/transaction_cells/merchant_cell', transaction: transaction %>
            <%= render 'shared/transaction_cells/amount_cell', transaction: transaction %>
            <%= render 'shared/transaction_cells/category_cell', transaction: transaction %>
          </tr>
        <% end %>

        <% if @allowance_transactions.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-tertiary">
              이번 달 용돈 내역이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Monthly Chart -->
  <% if @monthly_totals.any? %>
    <div class="bg-surface rounded-lg shadow p-6 mt-8">
      <h2 class="text-lg font-semibold text-primary mb-4">월별 용돈 지출</h2>
      <div class="space-y-2">
        <% @monthly_totals.sort.each do |month, amount| %>
          <div class="flex items-center">
            <div class="w-20 text-sm text-secondary"><%= month %></div>
            <div class="flex-1 mx-4">
              <div class="bg-divider rounded-full h-4">
                <div class="bg-warning h-4 rounded-full" style="width: <%= @monthly_totals.values.max > 0 ? (amount.to_f / @monthly_totals.values.max * 100).round : 0 %>%"></div>
              </div>
            </div>
            <div class="w-24 text-right text-sm font-medium"><%= number_to_currency(amount, unit: '₩', precision: 0) %></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
