<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">내 용돈</h1>
  <p class="text-gray-600 mb-6">다른 사람에게 보이지 않는 개인 지출 내역입니다.</p>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to '← 이전 달', allowances_path(year: prev_year, month: prev_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>

    <%= render 'shared/month_picker', year: @year, month: @month, base_path: allowances_path %>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to '다음 달 →', allowances_path(year: next_year, month: next_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>
  </div>

  <!-- Monthly Summary -->
  <div class="bg-white rounded-lg shadow p-6 mb-8">
    <div class="text-sm font-medium text-gray-500">이번 달 용돈 지출</div>
    <div class="text-3xl font-bold text-gray-900 mt-2">
      <%= number_to_currency(@total_amount, unit: '₩', precision: 0) %>
    </div>
  </div>

  <!-- Transactions -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">날짜</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">내역</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">금액</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">카테고리</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">금융기관</th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">작업</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @allowance_transactions.each do |at| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= at.expense_transaction.formatted_date %>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm font-medium text-gray-900"><%= at.merchant %></div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
              <%= number_to_currency(at.amount, unit: '₩', precision: 0) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if at.category %>
                <span class="px-2 py-1 text-xs rounded-full" style="background-color: <%= at.category.color %>20; color: <%= at.category.color %>">
                  <%= at.category.name %>
                </span>
              <% else %>
                <span class="text-gray-400 text-sm">미분류</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= at.expense_transaction.financial_institution&.name || '알 수 없음' %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-center">
              <%= button_to '해제', toggle_allowance_workspace_transaction_path(@workspace, at.expense_transaction),
                  method: :post,
                  data: { turbo_confirm: '용돈에서 해제하시겠습니까?' },
                  class: 'text-red-600 hover:text-red-800 text-sm font-medium' %>
            </td>
          </tr>
        <% end %>

        <% if @allowance_transactions.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-500">
              이번 달 용돈 내역이 없습니다.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Monthly Chart -->
  <% if @monthly_totals.any? %>
    <div class="bg-white rounded-lg shadow p-6 mt-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">월별 용돈 지출</h2>
      <div class="space-y-2">
        <% @monthly_totals.sort.each do |month, amount| %>
          <div class="flex items-center">
            <div class="w-20 text-sm text-gray-600"><%= month %></div>
            <div class="flex-1 mx-4">
              <div class="bg-gray-200 rounded-full h-4">
                <div class="bg-yellow-500 h-4 rounded-full" style="width: <%= @monthly_totals.values.max > 0 ? (amount.to_f / @monthly_totals.values.max * 100).round : 0 %>%"></div>
              </div>
            </div>
            <div class="w-24 text-right text-sm font-medium"><%= number_to_currency(amount, unit: '₩', precision: 0) %></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
