<div class="max-w-7xl mx-auto" data-controller="dashboard-category"
     data-dashboard-category-year-value="<%= @year %>"
     data-dashboard-category-month-value="<%= @month %>">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">대시보드</h1>
    <p class="text-gray-600"><%= @workspace.name %> - <%= @year %>년 <%= @month %>월</p>
  </div>

  <%= render 'tabs' %>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to '← 이전 달', monthly_dashboard_path(year: prev_year, month: prev_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>

    <%= render 'shared/month_picker', year: @year, month: @month, base_path: monthly_dashboard_path %>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to '다음 달 →', monthly_dashboard_path(year: next_year, month: next_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>
  </div>

  <!-- Hero Card: 선택한 월 총 지출 -->
  <div class="bg-indigo-600 rounded-2xl shadow-lg p-6 mb-6 text-white">
    <div class="text-sm font-medium text-indigo-200"><%= @year %>년 <%= @month %>월 총 지출</div>
    <div class="text-4xl sm:text-5xl font-bold mt-1">
      <%= number_to_currency(@total_spending, unit: '₩', precision: 0) %>
    </div>
    <div class="flex gap-6 mt-3 text-sm text-indigo-200">
      <span><%= @transactions.count %>건 결제</span>
      <% if @daily_average_denominator.positive? %>
        <span>일 평균 <%= number_to_currency(@daily_average, unit: '₩', precision: 0) %></span>
      <% end %>
    </div>

    <% if @budget_progress %>
      <div class="mt-4">
        <div class="flex justify-between text-xs text-indigo-200 mb-1">
          <span>예산 대비 <%= @budget_progress[:percentage] %>%</span>
          <span><%= number_to_currency(@budget_progress[:budget], unit: '₩', precision: 0) %></span>
        </div>
        <div class="w-full bg-indigo-800 rounded-full h-2">
          <div class="h-2 rounded-full transition-all duration-500 <%= @budget_progress[:percentage] >= 100 ? 'bg-red-400' : @budget_progress[:percentage] >= 80 ? 'bg-yellow-400' : 'bg-white' %>"
               style="width: <%= [@budget_progress[:percentage], 100].min %>%"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-xs font-medium text-gray-500">가장 큰 카테고리</div>
      <% if @top_category %>
        <div class="mt-2 flex items-baseline justify-between gap-3">
          <span class="text-base font-semibold text-gray-900 truncate"><%= @top_category[:name] %></span>
          <span class="text-sm font-semibold text-gray-500"><%= @top_category[:percentage] %>%</span>
        </div>
        <div class="mt-1 text-sm text-gray-500">
          <%= number_to_currency(@top_category[:amount], unit: '₩', precision: 0) %>
        </div>
      <% else %>
        <div class="mt-2 text-sm text-gray-500">이번 달 결제 없음</div>
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-xs font-medium text-gray-500">가장 큰 결제</div>
      <% if @largest_transaction %>
        <div class="mt-2 text-base font-semibold text-gray-900 truncate">
          <%= @largest_transaction.merchant.presence || "내역 없음" %>
        </div>
        <div class="mt-1 text-sm text-gray-500">
          <%= number_to_currency(@largest_transaction.amount, unit: '₩', precision: 0) %>
        </div>
      <% else %>
        <div class="mt-2 text-sm text-gray-500">이번 달 결제 없음</div>
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow p-4">
      <div class="text-xs font-medium text-gray-500">분류 필요</div>
      <div class="mt-2 text-base font-semibold text-gray-900">
        <%= @uncategorized_count %>건
      </div>
      <div class="mt-1 text-sm text-gray-500">
        <% if @uncategorized_count.positive? %>
          카테고리 확인 필요
        <% else %>
          모두 분류됨
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Category Breakdown -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold text-gray-900">카테고리별 지출</h2>
        <%= link_to '카테고리 관리', workspace_categories_path(@workspace), class: 'text-sm text-indigo-600 hover:text-indigo-800' %>
      </div>
      <p class="text-sm text-gray-500 mb-4">카테고리를 클릭하면 해당 결제를 볼 수 있습니다</p>
      <%= render 'category_breakdown' %>
    </div>

    <!-- Transactions Panel (Turbo Frame) -->
    <turbo-frame id="transactions-panel">
      <%= render 'recent_transactions_panel' %>
    </turbo-frame>
  </div>
</div>
