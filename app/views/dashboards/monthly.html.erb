<div class="max-w-7xl mx-auto" data-controller="dashboard-category"
     data-dashboard-category-year-value="<%= @year %>"
     data-dashboard-category-month-value="<%= @month %>">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">대시보드</h1>
    <p class="text-gray-600"><%= @workspace.name %> - <%= @year %>년 <%= @month %>월</p>
  </div>

  <%= render 'tabs' %>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to '← 이전 달', monthly_dashboard_path(year: prev_year, month: prev_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>

    <%= render 'shared/month_picker', year: @year, month: @month, base_path: monthly_dashboard_path %>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to '다음 달 →', monthly_dashboard_path(year: next_year, month: next_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>
  </div>

  <%# Phase 4: shared/_hero_stat 채택 (ADR-0003 / ADR-0006 시맨틱 토큰).
      옛 인디고 그라데이션은 ADR-0006의 컬러 의미축과 충돌하므로 제거. %>
  <% supporting_parts = [] %>
  <% supporting_parts << "#{@transactions.count}건 결제" %>
  <% supporting_parts << "일 평균 #{number_to_currency(@daily_average, unit: '₩', precision: 0)}" if @daily_average_denominator.positive? %>
  <% if @budget_progress %>
    <% supporting_parts << "예산 대비 #{@budget_progress[:percentage]}% (#{number_to_currency(@budget_progress[:budget], unit: '₩', precision: 0)})" %>
  <% end %>

  <div class="mb-4">
    <%= render 'shared/hero_stat',
        label: "#{@year}년 #{@month}월 총 지출",
        value: @total_spending,
        tone: :neutral,
        supporting: supporting_parts.join(" · ") %>
  </div>

  <%# Phase 4 slice 2: VarianceCard — 현재 월 + 전월 데이터 있을 때만 노출. %>
  <% if @variance %>
    <div class="mb-4">
      <%= render 'shared/variance_card',
          variance: @variance,
          workspace: @workspace,
          year: @year,
          month: @month %>
    </div>
  <% end %>

  <%# Phase 4: ReviewInboxCard — N>0일 때만 노출. 사용자 행동 압력. %>
  <div class="mb-6">
    <%= render 'shared/review_inbox_card',
        workspace: @workspace,
        pending_count: @pending_review_count,
        duplicate_count: @pending_duplicate_count %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Category Breakdown -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold text-gray-900">카테고리별 지출</h2>
        <%= link_to '카테고리 관리', workspace_categories_path(@workspace), class: 'text-sm text-indigo-600 hover:text-indigo-800' %>
      </div>
      <p class="text-sm text-gray-500 mb-4">카테고리를 클릭하면 해당 결제를 볼 수 있습니다</p>
      <%= render 'category_breakdown' %>
    </div>

    <!-- Transactions Panel (Turbo Frame) -->
    <turbo-frame id="transactions-panel">
      <%= render 'recent_transactions_panel' %>
    </turbo-frame>
  </div>
</div>
