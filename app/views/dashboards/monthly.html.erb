<div class="max-w-7xl mx-auto" data-controller="dashboard-category"
     data-dashboard-category-year-value="<%= @year %>"
     data-dashboard-category-month-value="<%= @month %>">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-primary"><%= t("dashboards.title") %></h1>
    <p class="text-secondary"><%= t("dashboards.workspace_year_month", workspace: @workspace.name, year: @year, month: @month) %></p>
  </div>

  <%= render 'tabs' %>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to t("dashboards.monthly.prev_month"), monthly_dashboard_path(year: prev_year, month: prev_month),
        class: 'text-action hover:text-action-hover' %>

    <%= render 'shared/month_picker', year: @year, month: @month, base_path: monthly_dashboard_path %>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to t("dashboards.monthly.next_month"), monthly_dashboard_path(year: next_year, month: next_month),
        class: 'text-action hover:text-action-hover' %>
  </div>

  <%# Phase 4: shared/_hero_stat 채택 (ADR-0003 / ADR-0006 시맨틱 토큰).
      옛 인디고 그라데이션은 ADR-0006의 컬러 의미축과 충돌하므로 제거. %>
  <% supporting_parts = [] %>
  <% supporting_parts << t("dashboards.monthly.supporting_count", count: @transactions.count) %>
  <% supporting_parts << t("dashboards.monthly.supporting_daily_avg", amount: number_to_currency(@daily_average, unit: '₩', precision: 0)) if @daily_average_denominator.positive? %>
  <% if @budget_progress %>
    <% supporting_parts << t("dashboards.monthly.supporting_budget_progress",
        percentage: @budget_progress[:percentage],
        budget: number_to_currency(@budget_progress[:budget], unit: '₩', precision: 0)) %>
  <% end %>

  <div class="mb-4">
    <%= render 'shared/hero_stat',
        label: t("dashboards.monthly.hero_label", year: @year, month: @month),
        value: @total_spending,
        tone: :neutral,
        supporting: supporting_parts.join(" · ") %>
  </div>

  <%# Phase 4 slice 2: VarianceCard — 현재 월 + 전월 데이터 있을 때만 노출. %>
  <% if @variance %>
    <div class="mb-4">
      <%= render 'shared/variance_card',
          variance: @variance,
          workspace: @workspace,
          year: @year,
          month: @month %>
    </div>
  <% end %>

  <%# Phase 4: ReviewInboxCard — N>0일 때만 노출. 사용자 행동 압력. %>
  <div class="mb-4">
    <%= render 'shared/review_inbox_card',
        workspace: @workspace,
        pending_count: @pending_review_count,
        duplicate_count: @pending_duplicate_count %>
  </div>

  <%# Phase 4 slice 3: 반복 결제 요약 — patterns 있을 때만 노출. %>
  <div class="mb-6">
    <%= render 'shared/recurring_payment_card',
        patterns: @recurring_preview,
        total_count: @recurring_total_count,
        monthly_estimate: @recurring_monthly_estimate,
        manage_path: recurring_dashboard_path %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Category Breakdown -->
    <div class="bg-surface rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold text-primary"><%= t("dashboards.monthly.breakdown_title") %></h2>
        <%= link_to t("dashboards.monthly.manage_categories"), workspace_categories_path(@workspace), class: 'text-sm text-action hover:text-action-hover' %>
      </div>
      <p class="text-sm text-tertiary mb-4"><%= t("dashboards.monthly.breakdown_hint") %></p>
      <%= render 'category_breakdown' %>
    </div>

    <!-- Transactions Panel (Turbo Frame) -->
    <turbo-frame id="transactions-panel">
      <%= render 'recent_transactions_panel' %>
    </turbo-frame>
  </div>
</div>
