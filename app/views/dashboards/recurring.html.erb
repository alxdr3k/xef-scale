<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">반복 결제</h1>
    <p class="text-gray-600">2개월 이상 동일 상점에서 결제된 거래를 자동으로 감지합니다.</p>
  </div>

  <%= render 'tabs' %>

  <% if @recurring_patterns.any? %>
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500"><%= @recurring_patterns.size %>개 반복 결제 감지됨</span>
          <span class="text-sm text-gray-500">
            월 예상 합계: <%= number_to_currency(@recurring_patterns.sum { |p| p[:average_amount] }, unit: '₩', precision: 0) %>
          </span>
        </div>
      </div>

      <div class="divide-y divide-gray-200">
        <% @recurring_patterns.each do |pattern| %>
          <div class="px-6 py-4 flex items-center justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-medium text-gray-900 truncate"><%= pattern[:merchant] %></span>
                <% if pattern[:consistent_amount] %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">정액</span>
                <% else %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-700">변동</span>
                <% end %>
                <% if pattern[:category] %>
                  <span class="text-xs text-gray-400"><%= pattern[:category] %></span>
                <% end %>
              </div>
              <div class="text-sm text-gray-500 mt-1">
                <%= pattern[:occurrence_count] %>개월 연속 · 마지막 결제 <%= pattern[:last_date].strftime('%Y.%m.%d') %>
              </div>
            </div>
            <div class="text-right ml-4 flex-shrink-0">
              <div class="font-semibold text-gray-900"><%= number_to_currency(pattern[:average_amount], unit: '₩', precision: 0) %>/월</div>
              <div class="text-xs text-gray-400">총 <%= number_to_currency(pattern[:total_spent], unit: '₩', precision: 0) %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow p-12 text-center">
      <p class="text-gray-500">반복 결제가 감지되지 않았습니다.</p>
      <p class="text-sm text-gray-400 mt-1">2개월 이상의 거래 데이터가 쌓이면 자동으로 감지됩니다.</p>
    </div>
  <% end %>
</div>
