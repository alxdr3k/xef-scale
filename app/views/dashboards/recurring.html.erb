<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-primary"><%= t("dashboards.recurring.title") %></h1>
    <p class="text-secondary"><%= t("dashboards.recurring.subtitle") %></p>
  </div>

  <%= render 'tabs' %>

  <% if @recurring_patterns.any? %>
    <div class="bg-surface rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b">
        <div class="flex justify-between items-center">
          <span class="text-sm text-tertiary"><%= t("dashboards.recurring.detected_count", count: @recurring_patterns.size) %></span>
          <span class="text-sm text-tertiary">
            <%= t("dashboards.recurring.monthly_expected", amount: number_to_currency(@recurring_patterns.sum { |p| p[:average_amount] }, unit: '₩', precision: 0)) %>
          </span>
        </div>
      </div>

      <div class="divide-y divide-divider">
        <% @recurring_patterns.each do |pattern| %>
          <div class="px-6 py-4 flex items-center justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-medium text-primary truncate"><%= pattern[:merchant] %></span>
                <% if pattern[:consistent_amount] %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-positive-subtle text-positive"><%= t("dashboards.recurring.fixed_amount") %></span>
                <% else %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-warning-subtle text-warning"><%= t("dashboards.recurring.variable_amount") %></span>
                <% end %>
                <% if pattern[:category] %>
                  <span class="text-xs text-tertiary"><%= pattern[:category] %></span>
                <% end %>
              </div>
              <div class="text-sm text-tertiary mt-1">
                <%= t("dashboards.recurring.occurrence_summary",
                      count: pattern[:occurrence_count],
                      date: pattern[:last_date].strftime('%Y.%m.%d')) %>
              </div>
            </div>
            <div class="text-right ml-4 flex-shrink-0">
              <div class="font-semibold text-primary"><%= t("dashboards.recurring.per_month", amount: number_to_currency(pattern[:average_amount], unit: '₩', precision: 0)) %></div>
              <div class="text-xs text-tertiary"><%= t("dashboards.recurring.total", amount: number_to_currency(pattern[:total_spent], unit: '₩', precision: 0)) %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-surface rounded-lg shadow p-12 text-center">
      <p class="text-tertiary"><%= t("dashboards.recurring.empty_title") %></p>
      <p class="text-sm text-tertiary mt-1"><%= t("dashboards.recurring.empty_hint") %></p>
    </div>
  <% end %>
</div>
