<div class="bg-surface rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold" style="color: <%= @category.color %>">
      <%= @category.name %> 결제
    </h2>
    <div class="flex items-center gap-3">
      <%= link_to '전체 보기 →',
          workspace_transactions_path(@workspace, year: @year, month: @month, category_id: @category.id),
          data: { turbo_frame: '_top' },
          class: 'text-action hover:text-action text-sm' %>
      <button data-action="click->dashboard-category#clearSelection"
              class="text-disabled hover:text-secondary text-lg cursor-pointer"
              title="선택 해제">
        &times;
      </button>
    </div>
  </div>

  <div class="space-y-3">
    <% @transactions.each do |tx| %>
      <div class="flex items-center justify-between py-2 border-b border-divider last:border-0">
        <div>
          <div class="font-medium text-primary"><%= tx.merchant %></div>
          <%= render 'shared/notes_badge', notes: tx.notes, max_width: '12rem' %>
          <div class="text-sm text-tertiary">
            <%= tx.formatted_date %>
          </div>
        </div>
        <div class="text-right">
          <div class="font-semibold text-primary"><%= number_to_currency(tx.amount, unit: '₩', precision: 0) %></div>
        </div>
      </div>
    <% end %>

    <% if @transactions.empty? %>
      <p class="text-tertiary text-center py-4">이 카테고리에 결제 내역이 없습니다.</p>
    <% end %>
  </div>
</div>
