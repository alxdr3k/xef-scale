<div class="bg-white rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold" style="color: <%= @category.color %>">
      <%= @category.name %> 거래
    </h2>
    <div class="flex items-center gap-3">
      <%= link_to '전체 보기 →',
          workspace_transactions_path(@workspace, year: @year, month: @month, category_id: @category.id),
          class: 'text-indigo-600 hover:text-indigo-800 text-sm' %>
      <button data-action="click->dashboard-category#clearSelection"
              class="text-gray-400 hover:text-gray-600 text-lg"
              title="선택 해제">
        &times;
      </button>
    </div>
  </div>

  <div class="space-y-3">
    <% @transactions.each do |tx| %>
      <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
        <div>
          <div class="font-medium text-gray-900"><%= tx.merchant %></div>
          <div class="text-sm text-gray-500">
            <%= tx.formatted_date %>
          </div>
        </div>
        <div class="text-right">
          <div class="font-semibold text-gray-900"><%= number_to_currency(tx.amount, unit: '₩', precision: 0) %></div>
        </div>
      </div>
    <% end %>

    <% if @transactions.empty? %>
      <p class="text-gray-500 text-center py-4">이 카테고리에 거래 내역이 없습니다.</p>
    <% end %>
  </div>
</div>
