<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">대시보드</h1>
    <p class="text-gray-600"><%= @workspace.name %> - <%= @year %>년 <%= @month %>월</p>
  </div>

  <!-- Month Navigation -->
  <div class="flex items-center space-x-4 mb-6">
    <% prev_month = @month == 1 ? 12 : @month - 1 %>
    <% prev_year = @month == 1 ? @year - 1 : @year %>
    <%= link_to '← 이전 달', dashboard_path(year: prev_year, month: prev_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>

    <span class="font-semibold text-lg"><%= @year %>년 <%= @month %>월</span>

    <% next_month = @month == 12 ? 1 : @month + 1 %>
    <% next_year = @month == 12 ? @year + 1 : @year %>
    <%= link_to '다음 달 →', dashboard_path(year: next_year, month: next_month),
        class: 'text-indigo-600 hover:text-indigo-800' %>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <div class="text-sm font-medium text-gray-500">이번 달 총 지출</div>
      <div class="text-3xl font-bold text-gray-900 mt-2">
        <%= number_to_currency(@total_spending, unit: '₩', precision: 0) %>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="text-sm font-medium text-gray-500">거래 건수</div>
      <div class="text-3xl font-bold text-gray-900 mt-2">
        <%= @transactions.count %>건
      </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <div class="text-sm font-medium text-gray-500">일 평균 지출</div>
      <div class="text-3xl font-bold text-gray-900 mt-2">
        <%= number_to_currency(@total_spending / [Date.current.day, 1].max, unit: '₩', precision: 0) %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Category Breakdown -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">카테고리별 지출</h2>
      <div class="space-y-4">
        <% @category_breakdown.sort_by { |_, v| -v }.each do |category_name, amount| %>
          <div class="flex items-center">
            <div class="flex-1">
              <div class="flex justify-between mb-1">
                <span class="text-sm font-medium text-gray-700"><%= category_name %></span>
                <span class="text-sm text-gray-500"><%= number_to_currency(amount, unit: '₩', precision: 0) %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-indigo-600 h-2 rounded-full" style="width: <%= @total_spending > 0 ? (amount.to_f / @total_spending * 100).round : 0 %>%"></div>
              </div>
            </div>
          </div>
        <% end %>

        <% if @category_breakdown.empty? %>
          <p class="text-gray-500 text-center py-4">이번 달 거래 내역이 없습니다.</p>
        <% end %>
      </div>
    </div>

    <!-- Recent Transactions -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-semibold text-gray-900">최근 거래</h2>
        <%= link_to '전체 보기 →', workspace_transactions_path(@workspace), class: 'text-indigo-600 hover:text-indigo-800 text-sm' %>
      </div>

      <div class="space-y-3">
        <% @recent_transactions.each do |tx| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
            <div>
              <div class="font-medium text-gray-900"><%= tx.merchant %></div>
              <div class="text-sm text-gray-500">
                <%= tx.formatted_date %>
                <% if tx.category %>
                  · <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100"><%= tx.category.name %></span>
                <% end %>
              </div>
            </div>
            <div class="text-right">
              <div class="font-semibold text-gray-900"><%= number_to_currency(tx.amount, unit: '₩', precision: 0) %></div>
            </div>
          </div>
        <% end %>

        <% if @recent_transactions.empty? %>
          <p class="text-gray-500 text-center py-4">최근 거래 내역이 없습니다.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
