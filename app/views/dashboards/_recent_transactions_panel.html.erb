<div class="bg-surface rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-primary">최근 결제</h2>
    <%= link_to '전체 보기 →', workspace_transactions_path(@workspace, year: @year, month: @month), data: { turbo_frame: '_top' }, class: 'text-action hover:text-action text-sm' %>
  </div>

  <div class="space-y-3">
    <% @recent_transactions.each do |tx| %>
      <div class="flex items-center justify-between py-2 border-b border-divider last:border-0">
        <div>
          <div class="font-medium text-primary"><%= tx.merchant %></div>
          <div class="text-sm text-tertiary">
            <%= tx.formatted_date %>
            <% if tx.category %>
              · <%= render 'shared/category_badge', category: tx.category %>
            <% end %>
          </div>
        </div>
        <div class="text-right">
          <div class="font-semibold text-primary"><%= number_to_currency(tx.amount, unit: '₩', precision: 0) %></div>
        </div>
      </div>
    <% end %>

    <% if @recent_transactions.empty? %>
      <p class="text-tertiary text-center py-4">최근 결제 내역이 없습니다.</p>
    <% end %>
  </div>
</div>
