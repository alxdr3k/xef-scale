# FastAPI Configuration
PROJECT_NAME="Expense Tracker API"
VERSION="1.0.0"
API_PREFIX="/api"

# Security Settings
# IMPORTANT: Generate a secure key using: openssl rand -hex 32
SECRET_KEY="CHANGE_THIS_IN_PRODUCTION_USE_openssl_rand_hex_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth Settings
# Google Cloud Console에서 생성한 OAuth Client ID로 교체하세요
# 프론트엔드 .env의 VITE_GOOGLE_CLIENT_ID와 동일한 값을 사용하세요
GOOGLE_CLIENT_ID=""
